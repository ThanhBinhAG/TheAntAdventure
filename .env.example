# =============================================================================
# The Ant Adventures CRM v4.3 — Environment variables
# =============================================================================
#
# SETUP:
#   1. Copy this file to `.env.local` in the project root:
#        cp .env.example .env.local        (Mac/Linux)
#        copy .env.example .env.local      (Windows)
#   2. Fill in your Supabase values below (from Supabase → Project Settings → API).
#   3. Restart the dev server after editing: npm run dev
#
# SECURITY:
#   - Never commit `.env.local` (already in .gitignore).
#   - NEXT_PUBLIC_* vars are exposed to the browser — use the anon key only.
#   - Keep SUPABASE_SERVICE_ROLE_KEY server-side only (future API routes / scripts).
#
# =============================================================================

# --- Supabase (required when USE_SUPABASE=true) ---
# Paste from: https://supabase.com/dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — server-side scripts / migrations only (do NOT expose in client code)
SUPABASE_SERVICE_ROLE_KEY=

# --- Data layer ---
# false = Zustand + localStorage only (default, works offline)
# true  = connect to Supabase (accepts true/TRUE/1/yes — no spaces after =)
NEXT_PUBLIC_USE_SUPABASE=false

# Auto push app edits → Supabase (default: on when USE_SUPABASE=true)
# Set false to disable and use manual "Push full snapshot" only
NEXT_PUBLIC_SUPABASE_AUTO_SYNC=true

# --- App metadata ---
NEXT_PUBLIC_APP_NAME="The Ant Adventures CRM"
NEXT_PUBLIC_APP_VERSION="4.3"
