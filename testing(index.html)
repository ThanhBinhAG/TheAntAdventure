let CHAT_MESSAGES = LS.get('ant_chat_v3', SEED_MESSAGES);
let currentChannel = 'general';

function persistChat() { LS.set('ant_chat_v3', CHAT_MESSAGES); }

function updateChatProfile() {
  const name = document.getElementById('chat-my-name')?.value?.trim() || 'Team Member';
  LS.set('ant_chat_name', name);
  const av = document.getElementById('chat-my-avatar');
  if (av) { av.textContent = initials(name); av.style.background = strColor(name); }
}

function switchChannel(ch) {
  currentChannel = ch;
  document.querySelectorAll('.chat-channel').forEach(el => el.classList.toggle('on', el.dataset.ch === ch));
  const meta = CHANNEL_META[ch] || {title:'# '+ch, desc:'', emoji:'💬'};
  const titleEl = document.getElementById('chat-channel-title');
  const descEl  = document.getElementById('chat-channel-desc');
  const inputEl = document.getElementById('chat-input');
  if (titleEl) titleEl.textContent = meta.title;
  if (descEl)  descEl.textContent  = meta.desc;
  if (inputEl) inputEl.placeholder = 'Message ' + meta.title + '...';
  renderMessages();
}

function renderMessages() {
  const el = document.getElementById('chat-messages');
  if (!el) return;
  const msgs = CHAT_MESSAGES[currentChannel] || [];
  if (!msgs.length) {
    el.innerHTML = `<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--m);text-align:center;padding:30px">
      <div style="font-size:36px;margin-bottom:12px">${CHANNEL_META[currentChannel]?.emoji || '💬'}</div>
      <div style="font-size:14px;font-weight:500;margin-bottom:6px">This is the start of ${CHANNEL_META[currentChannel]?.title || currentChannel}</div>
      <div style="font-size:12.5px">Send a message to get the conversation started.</div>
    </div>`;
    return;
  }
  let lastDate = '';
  el.innerHTML = msgs.map(m => {
    const d    = new Date(m.time);
    const dateStr = d.toLocaleDateString('en',{weekday:'long',month:'long',day:'numeric'});
    const timeStr = d.toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'});
    const col  = strColor(m.author);
    const reactionHTML = (m.reactions||[]).length
      ? `<div style="display:flex;flex-wrap:wrap;gap:3px;margin-top:5px">${[...new Set(m.reactions)].map(r => {
          const cnt = m.reactions.filter(x=>x===r).length;
          return `<span class="msg-reaction" onclick="addReaction('${m.id}','${r}')">${r} ${cnt}</span>`;
        }).join('')}</div>` : '';
    const divider = dateStr !== lastDate
      ? `<div class="chat-date-divider" style="margin:10px 0">${dateStr}</div>`
      : '';
    lastDate = dateStr;
    return `${divider}
    <div class="chat-msg" id="msg-${m.id}">
      <div class="chat-avatar" style="background:${col}">${initials(m.author)}</div>
      <div class="msg-bubble">
        <div class="msg-meta">
          <span class="msg-name" style="color:${col}">${m.author}</span>
          <span class="msg-time">${timeStr}</span>
        </div>
        <div class="msg-text">${m.text.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
        ${reactionHTML}
        <div class="msg-actions">
          <button class="msg-action-btn" onclick="addReaction('${m.id}','👍')">👍</button>
          <button class="msg-action-btn" onclick="addReaction('${m.id}','🎉')">🎉</button>
          <button class="msg-action-btn" onclick="addReaction('${m.id}','✅')">✅</button>
          <button class="msg-action-btn" onclick="deleteMsg('${m.id}')">🗑 Delete</button>
        </div>
      </div>
    </div>`;
  }).join('');
  el.scrollTop = el.scrollHeight;
}

function sendChatMessage() {
  const input = document.getElementById('chat-input');
  const text  = input?.value?.trim();
  if (!text) return;
  const myName = document.getElementById('chat-my-name')?.value?.trim() || LS.get('ant_chat_name','Team Member');
  if (!CHAT_MESSAGES[currentChannel]) CHAT_MESSAGES[currentChannel] = [];
  const msg = {
    id:        'msg-' + Date.now(),
    author:    myName,
    text,
    time:      new Date().toISOString(),
    reactions: [],
  };
  CHAT_MESSAGES[currentChannel].push(msg);
  persistChat();
  if (input) { input.value = ''; input.style.height = 'auto'; }
  renderMessages();
}

function chatKeyDown(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendChatMessage();
  }
}

function autoresizeChat(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function addReaction(msgId, emoji) {
  const msgs = CHAT_MESSAGES[currentChannel] || [];
  const msg = msgs.find(m => m.id === msgId);
  if (!msg) return;
  if (!msg.reactions) msg.reactions = [];
  msg.reactions.push(emoji);
  persistChat();
  renderMessages();
}

function deleteMsg(msgId) {
  if (!confirm('Delete this message?')) return;
  if (CHAT_MESSAGES[currentChannel]) {
    CHAT_MESSAGES[currentChannel] = CHAT_MESSAGES[currentChannel].filter(m => m.id !== msgId);
    persistChat();
    renderMessages();
  }
}

function initChat() {
  const savedName = LS.get('ant_chat_name','Tai Pham');
  const nameEl = document.getElementById('chat-my-name');
  if (nameEl) nameEl.value = savedName;
  const av = document.getElementById('chat-my-avatar');
  if (av) { av.textContent = initials(savedName); av.style.background = strColor(savedName); }
  switchChannel('general');
}

