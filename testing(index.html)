function renderSales() {
  // ── Tab switching ─────────────────────────────────────────────
  document.querySelectorAll('[data-sales-tab]').forEach(t => {
    t.addEventListener('click', () => {
      document.querySelectorAll('[data-sales-tab]').forEach(x => x.classList.remove('on'));
      t.classList.add('on');
