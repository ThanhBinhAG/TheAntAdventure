// Move lead to new stage — triggers lost reason modal if moving to Lost
function moveLeadStage(leadId, newStage) {
  const lead = LEADS.find(l => l.id === leadId);
  if (!lead) return;
  if (newStage === 'Lost') {
    openLostReasonModal(leadId, newStage);
  } else {
    lead.stage = newStage;
    lead.probability = STAGE_PROB[newStage] ?? lead.probability;
    persist();
    renderSales();
  }
}

// ── Lost Reason Modal ──────────────────────────────────────────
function openLostReasonModal(leadId, stage) {
  const overlay = document.getElementById('lost-reason-overlay');
  if (!overlay) return;
  const lead = LEADS.find(l => l.id === leadId);
  document.getElementById('lost-lead-id').value   = leadId;
  document.getElementById('lost-reason-sel').value = lead?.lostReason || '';
  document.getElementById('lost-reason-note').value = lead?.lostNote || '';
  overlay.style.display = 'flex';
}

function saveLostReason() {
  const leadId    = document.getElementById('lost-lead-id').value;
  const reason    = document.getElementById('lost-reason-sel').value;
  const note      = document.getElementById('lost-reason-note').value;
  const lead      = LEADS.find(l => l.id === leadId);
  if (lead) {
    lead.stage      = 'Lost';
    lead.probability = 0;
    lead.lostReason = reason;
    lead.lostNote   = note;
    lead.lostAt     = new Date().toISOString().split('T')[0];
    persist();
  }
  document.getElementById('lost-reason-overlay').style.display = 'none';
  renderSales();
}

function closeLostReasonModal() {
  document.getElementById('lost-reason-overlay').style.display = 'none';
  renderSales(); // reset the dropdown
}

