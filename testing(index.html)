}

function updateAIStatus() {
  const saved = LS.get('ant_ai_reqs', {});
  const fields = {rules:'ai-status-rules',suppliers:'ai-status-suppliers',pricing:'ai-status-pricing',design:'ai-status-design',voice:'ai-status-voice'};
  Object.entries(fields).forEach(([k, elId]) => {
