function renderGalleryTagSelector() {
  const el = document.getElementById('gallery-tag-selector');
  if (!el) return;
  el.innerHTML = Object.entries(GALLERY_TAG_TAXONOMY).map(([cat, tags]) => `
    <div style="margin-bottom:10px">
      <div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--m);margin-bottom:5px">${cat}</div>
      <div style="display:flex;flex-wrap:wrap;gap:5px">
        ${tags.map(tag => {
          const sel = _selectedGalleryTags.includes(tag);
          return `<button type="button" onclick="toggleGalleryTag('${tag.replace(/'/g,"\\'")}',this)"
            style="padding:3px 10px;border-radius:14px;border:1px solid ${sel?'#2E7D52':'var(--b)'};
                   background:${sel?'#2E7D52':'#F0F0EE'};color:${sel?'#fff':'var(--m)'};
                   font-size:11px;cursor:pointer;transition:all .12s">${tag}</button>`;
        }).join('')}
      </div>
    </div>`).join('');
}

function toggleGalleryTag(tag, btn) {
  const idx = _selectedGalleryTags.indexOf(tag);
  if (idx === -1) {
    _selectedGalleryTags.push(tag);
    if (btn) { btn.style.background='#2E7D52'; btn.style.color='#fff'; btn.style.borderColor='#2E7D52'; }
  } else {
    _selectedGalleryTags.splice(idx, 1);
    if (btn) { btn.style.background='#F0F0EE'; btn.style.color='var(--m)'; btn.style.borderColor='var(--b)'; }
  }
}

