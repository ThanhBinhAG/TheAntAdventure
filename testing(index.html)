          📧 Email to ${region} Supplier
        </button>
      </div>`;

    container.appendChild(section);

    // ── Fill rows for this region ──────────────────────────────
    const tbody = section.querySelector(`#sbf-tr-tbody-${region}`);
    days.forEach(({ dayObj, i }, rowIdx) => {
      let dateLabel = `Day ${dayObj.day}`;
      if (startDate) {
