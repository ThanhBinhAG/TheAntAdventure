Keep it client-ready and polished.`;
  } else {
    prompt = sysRules + `You are a senior sales consultant at The Ant Adventures, a boutique luxury Vietnam inbound tour company. Write a warm, personalized proposal email.

CLIENT: ${custName} · ${clientType==='b2b'?'Travel Agent / B2B Partner':'Direct Client (B2C)'} · ${pax} pax · ${style} style
TRAVEL MONTH: ${month} 2026 · HOTEL TIER: ${tier}
SPECIAL NOTES: ${special}

SELECTED EXPERIENCES:
${expList}

PRICING: Net cost $${fmt(Math.round(totalC))}/pax · Sell price $${fmt(sellPerPax)}/pax · Group total (${pax} pax): $${groupTotal}

Write a professional proposal email with:
- Subject: line
- Body: warm opening, reference to the specific experiences chosen, pricing clearly stated, next step (30% deposit to confirm)
- Sign-off: "Tai, The Ant Adventures | taipham@theantadventures.com | www.theantadventures.com"

Brand voice: boutique, considered, locally rooted, quietly luxurious. Address by first name.`;
  }

  const box = document.getElementById('ai-box');
  const loading = document.getElementById('ai-loading');
  const errEl = document.getElementById('ai-error');
  const copyBtn = document.getElementById('copy-ai-btn');
  box.style.display='none'; box.textContent='';
  errEl.style.display='none'; copyBtn.style.display='none';
  loading.style.display='flex';

  try {
    const apiKey = LS.get('ant_api_key','');
    if (!apiKey || !apiKey.startsWith('sk-')) {
      loading.style.display='none';
      errEl.style.display='block';
      errEl.innerHTML = '⚡ <b>API key required.</b> Enter your Anthropic API key in the field above and click Save Key, then try again.<br><span style="font-size:11px">Get a free key at <a href="https://console.anthropic.com" target="_blank" style="color:var(--pur)">console.anthropic.com</a></span>';
      return;
    }
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1500,messages:[{role:'user',content:prompt}]})
    });
    const data = await res.json();
    const text = data.content?.filter(b=>b.type==='text').map(b=>b.text).join('\n')||'No response generated.';
    loading.style.display='none';
    box.style.display='block';
    box.textContent = text;
    copyBtn.style.display='inline-flex';
    const pdfBtn=document.getElementById('pdf-export-btn'); if(pdfBtn) pdfBtn.style.display='inline-flex';
    const wordBtn=document.getElementById('word-export-btn'); if(wordBtn) wordBtn.style.display='inline-flex';
    // Check for API errors in the response
    if (!res.ok) {
      const errData = await res.json().catch(() => ({}));
      loading.style.display='none';
      errEl.style.display='block';
      if (res.status === 401) {
        errEl.innerHTML = '🔑 <b>Invalid API key.</b> Please check your key and try again. Make sure it starts with <code>sk-ant-</code>';
      } else if (res.status === 429) {
        errEl.innerHTML = '⏳ <b>Rate limit reached.</b> Please wait a moment and try again.';
      } else {
        errEl.innerHTML = '⚠ API error ' + res.status + ': ' + (errData.error?.message || 'Unknown error');
      }
      return;
    }
  } catch(e) {
    loading.style.display='none';
    errEl.style.display='block';
    if (e.message.includes('fetch') || e.message.includes('network') || e.message.includes('Failed')) {
      errEl.innerHTML = '🌐 <b>No internet connection.</b> The AI export requires internet access. Please connect to Wi-Fi or mobile data and try again.';
    } else {
      errEl.innerHTML = '⚠ Error: ' + e.message;
    }
  }
}

