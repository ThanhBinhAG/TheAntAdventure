// ── PROMPT #5: Pipeline Forecast Breakdown Table ─────────────────────────────
const _FORECAST_PROB = {Inquiry:10, Designing:25, Quoted:50, Negotiation:70};
const _FORECAST_STAGE_BADGE = {
  Inquiry:'bdg-b', Designing:'bdg-p', Quoted:'bdg-a', Negotiation:'bdg-a'
};

function buildForecastBreakdown() {
  try {
    const skip = new Set(['Confirmed','On Tour','Completed','Lost','Cancelled']);
    const deals = (LEADS || [])
      .filter(l => l && !skip.has(l.stage))
      .map(l => {
        const prob = typeof l.probability === 'number'
          ? l.probability
          : (_FORECAST_PROB[l.stage] ?? 30);
        const tv = parseFloat(l.value) || 0;
        return {
          id:           l.id || '—',
          custId:       l.custId || '',
          tour:         (l.tour || '—').slice(0, 34),
          pax:          l.pax || '—',
          tourValue:    tv,
          probability:  prob,
          weightedValue: tv * (prob / 100),
          stage:        l.stage || '—',
          month:        l.month || '—'
        };
      })
      .sort((a, b) => b.weightedValue - a.weightedValue)
      .slice(0, 8);
    return deals;
  } catch { return []; }
}

function renderForecastTable() {
  const container = document.getElementById('forecast-breakdown-card');
  if (!container) return;

  const deals = buildForecastBreakdown();

  if (deals.length < 2) {
    container.innerHTML = `
      <div class="card">
        <div class="card-hd"><span class="card-title">💼 Pipeline Forecast Breakdown</span></div>
        <div class="card-body" style="padding:18px;text-align:center;color:var(--m);font-size:13px">
          Add pipeline deals in the Sales section to see the forecast breakdown.
          <br><button class="btn btn-s btn-sm" style="margin-top:10px" onclick="showPage('pipeline')">→ Go to Pipeline</button>
        </div>
      </div>`;
    return;
  }

  const totalValue    = deals.reduce((s, d) => s + d.tourValue, 0);
  const totalWeighted = deals.reduce((s, d) => s + d.weightedValue, 0);

  const rows = deals.map(d => {
    const cust = (CUSTOMERS || []).find(c => c.id === d.custId);
    const clientName = cust?.name || d.custId || '—';
    const badgeCls = _FORECAST_STAGE_BADGE[d.stage] || 'bdg-w';
    const probBar = `
      <div style="display:flex;align-items:center;gap:6px">
        <div style="width:50px;height:6px;background:#E2E8E4;border-radius:3px;flex-shrink:0">
          <div style="width:${d.probability}%;height:6px;background:#2E7D52;border-radius:3px"></div>
        </div>
        <span style="font-size:11.5px">${d.probability}%</span>
      </div>`;
    return `<tr>
      <td style="font-size:12px;font-weight:600">${clientName}</td>
      <td style="font-size:12px">${d.tour}</td>
      <td style="font-size:12px;text-align:right">$${fmt(Math.round(d.tourValue))}</td>
      <td>${probBar}</td>
      <td style="font-size:12px;font-weight:700;color:#2E7D52;text-align:right">$${fmt(Math.round(d.weightedValue))}</td>
      <td><span class="bdg ${badgeCls}" style="font-size:10.5px">${d.stage}</span></td>
      <td style="font-size:11.5px;color:var(--m)">${d.month}</td>
    </tr>`;
  }).join('');

  container.innerHTML = `
    <div class="card">
      <div class="card-hd" style="display:flex;align-items:center;justify-content:space-between">
        <div>
          <span class="card-title">💼 Pipeline Forecast Breakdown</span>
          <div style="font-size:11px;color:var(--m);margin-top:2px">Top active deals · Sorted by probability-weighted value</div>
        </div>
        <button class="btn btn-s btn-sm" onclick="renderForecastTable()" title="Refresh">↻ Refresh</button>
      </div>
      <div class="card-body" style="padding:0">
        <div style="overflow-x:auto">
          <table style="width:100%;border-collapse:collapse;font-size:12px">
            <thead>
              <tr style="background:var(--s);border-bottom:1px solid var(--b)">
                <th style="padding:8px 12px;text-align:left;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Client</th>
                <th style="padding:8px 12px;text-align:left;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Tour</th>
                <th style="padding:8px 12px;text-align:right;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Tour Value</th>
                <th style="padding:8px 12px;text-align:left;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Probability</th>
                <th style="padding:8px 12px;text-align:right;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Weighted Value</th>
                <th style="padding:8px 12px;text-align:left;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Stage</th>
                <th style="padding:8px 12px;text-align:left;font-size:11px;font-weight:700;color:var(--m);white-space:nowrap">Travel Month</th>
              </tr>
            </thead>
            <tbody>
              ${rows}
            </tbody>
            <tfoot>
              <tr style="background:var(--gl);border-top:2px solid #2E7D52">
                <td style="padding:9px 12px;font-size:12px;font-weight:700" colspan="2">TOTAL</td>
                <td style="padding:9px 12px;font-size:12px;font-weight:700;text-align:right">$${fmt(Math.round(totalValue))}</td>
                <td style="padding:9px 12px">—</td>
                <td style="padding:9px 12px;font-size:12px;font-weight:700;color:#2E7D52;text-align:right">$${fmt(Math.round(totalWeighted))}</td>
                <td colspan="2" style="padding:9px 12px">—</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>`;
}
