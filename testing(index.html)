              <div><label class="sbf-lbl">Disembarkation Date</label><input id="sbf-c-dis" type="date" class="sbf-inp"></div>
              <div><label class="sbf-lbl">Cabin Type</label>
                <select id="sbf-c-cabin" class="sbf-inp"><option>Deluxe Cabin</option><option>Junior Suite</option><option>Suite</option><option>Premium Suite</option><option>Owner's Suite</option></select></div>
              <div><label class="sbf-lbl">No. of Cabins</label><input id="sbf-c-cabins" type="number" class="sbf-inp" placeholder="1"></div>
              <div><label class="sbf-lbl">No. of Guests</label><input id="sbf-c-pax" type="number" class="sbf-inp"></div>
              <div><label class="sbf-lbl">Guest Name(s)</label><input id="sbf-c-guest" class="sbf-inp"></div>
              <div><label class="sbf-lbl">Meal Inclusions</label><input id="sbf-c-meals" class="sbf-inp" placeholder="All meals included, drinks excluded"></div>
              <div><label class="sbf-lbl">Agreed Rate (USD)</label><input id="sbf-c-rate" type="number" class="sbf-inp" placeholder="1200"></div>
