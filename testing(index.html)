        </div>
      </div>
    </div>`;
  }

  // ── Section A: Today's priority actions ──────────────────────────
  const secA = LEADS
    .filter(l => l.followUpDate === today && l.stage !== 'Completed' && l.stage !== 'Lost')
    .sort((a, b) => (b.value || 0) - (a.value || 0));
  const secAEl = document.getElementById('hub-sec-a');
  const secACnt = document.getElementById('hub-sec-a-count');
  if (secAEl) {
    secAEl.innerHTML = secA.length
      ? secA.map(l => leadRow(l, false)).join('')
      : '<div style="padding:16px;text-align:center;color:var(--m);font-size:12.5px">✅ No follow-ups scheduled for today.</div>';
  }
  if (secACnt) secACnt.textContent = secA.length + ' tasks';

  // ── Section B: Overdue follow-ups ────────────────────────────────
  const secB = LEADS
    .filter(l => l.followUpDate && l.followUpDate < today && l.stage !== 'Completed' && l.stage !== 'Lost')
    .sort((a, b) => a.followUpDate.localeCompare(b.followUpDate));
  const secBEl = document.getElementById('hub-sec-b');
  const secBCnt = document.getElementById('hub-sec-b-count');
  if (secBEl) {
    secBEl.innerHTML = secB.length
      ? secB.map(l => leadRow(l, true)).join('')
      : '<div style="padding:16px;text-align:center;color:var(--m);font-size:12.5px">✅ No overdue follow-ups.</div>';
  }
  if (secBCnt) secBCnt.textContent = secB.length + ' overdue';

  // ── Section C: This week's bookings in execution ──────────────────
  const weekEnd = new Date(todayDate); weekEnd.setDate(weekEnd.getDate() + 7);
  const secC = BOOKINGS.filter(b => {
    if (b.status === 'On Tour') return true;
    // Parse "Mar 23" style start dates → check if within next 7 days
    const yr = '2026';
    const parsed = new Date(b.start + ' ' + yr + ' 12:00');
    return !isNaN(parsed) && parsed >= todayDate && parsed <= weekEnd;
  });
  const secCEl = document.getElementById('hub-sec-c');
  const secCCnt = document.getElementById('hub-sec-c-count');
  if (secCEl) {
    secCEl.innerHTML = secC.length
      ? `<table class="tbl"><thead><tr><th>Booking</th><th>Tour</th><th>Pax</th><th>Dates</th><th>Guide</th><th>Status</th></tr></thead><tbody>
          ${secC.map(b => `<tr>
            <td><code style="color:var(--g);font-size:10.5px">${b.id}</code></td>
            <td style="font-size:12px;font-weight:500">${b.tour}</td>
            <td>${b.pax}</td>
            <td style="font-size:11.5px;color:var(--m)">${b.start}–${b.end}</td>
            <td>${b.guide||'—'}</td>
            <td><span class="bdg ${b.status==='Completed'?'bdg-w':b.status==='Fully Paid'?'bdg-g':'bdg-a'}" style="font-size:10px">${b.status}</span></td>
          </tr>`).join('')}
        </tbody></table>`
      : '<div style="padding:16px;text-align:center;color:var(--m);font-size:12.5px">No tours in execution this week.</div>';
  }
  if (secCCnt) secCCnt.textContent = secC.length + ' tours';

  // ── Section D: Urgent — travel date <60 days, not yet Confirmed ──
  const secD = LEADS.filter(l => {
    if (l.stage !== 'Quoted' && l.stage !== 'Negotiation' && l.stage !== 'Designing') return false;
    const travelDate = monthToDate(l.month);
    if (!travelDate) return false;
    const daysOut = Math.round((travelDate - todayDate) / 86400000);
    return daysOut >= 0 && daysOut <= 60;
  }).sort((a, b) => (monthToDate(a.month)||new Date()) - (monthToDate(b.month)||new Date()));
  const secDEl = document.getElementById('hub-sec-d');
  const secDCnt = document.getElementById('hub-sec-d-count');
  if (secDEl) {
    secDEl.innerHTML = secD.length
      ? `<table class="tbl"><thead><tr><th>Lead</th><th>Client</th><th>Tour</th><th>Value</th><th>Travel</th><th>Stage</th><th>Days Out</th></tr></thead><tbody>
          ${secD.map(l => {
            const cust = CUSTOMERS.find(c => c.id === l.custId);
            const td   = monthToDate(l.month);
            const days = td ? Math.round((td - todayDate) / 86400000) : '?';
            return `<tr>
              <td><code style="font-size:10.5px;color:var(--g)">${l.id}</code></td>
              <td style="font-weight:500">${cust?.name||'—'}</td>
              <td style="font-size:12px">${l.tour}</td>
              <td style="color:var(--g);font-weight:600">${l.value>0?'$'+fmt(l.value):'—'}</td>
              <td style="font-size:11.5px">${l.month}</td>
              <td><span class="bdg bdg-a" style="font-size:10px">${l.stage}</span></td>
              <td style="color:${days<30?'var(--red)':'var(--amb)'};font-weight:700">${days}d</td>
            </tr>`;
          }).join('')}
        </tbody></table>`
      : '<div style="padding:16px;text-align:center;color:var(--m);font-size:12.5px">✅ No unconfirmed leads departing within 60 days.</div>';
  }
  if (secDCnt) secDCnt.textContent = secD.length + ' urgent';

  // ── Summary bar ──────────────────────────────────────────────────
  const todayEl   = document.getElementById('hub-today-count');
  const overdueEl = document.getElementById('hub-overdue-count');
  const toursEl2  = document.getElementById('hub-tours-count');
  if (todayEl)   todayEl.textContent   = '📋 ' + secA.length + ' tasks today';
  if (overdueEl) overdueEl.textContent = '⚠️ ' + secB.length + ' overdue';
  if (toursEl2)  toursEl2.textContent  = '✈️ ' + secC.length + ' tours this week';

  updatePlannerBadge();
}
