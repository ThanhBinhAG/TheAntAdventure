function setFinTab(tab) {
  document.querySelectorAll('[data-ftab]').forEach(t => t.classList.toggle('on', t.dataset.ftab === tab));
  ['overview','cashflow','pl','ar','ap'].forEach(t => {
    const el = document.getElementById('fin-tab-' + t);
    if (el) el.style.display = t === tab ? 'block' : 'none';
  });
  if (tab === 'cashflow') renderCashflow();
  if (tab === 'pl')       renderPL();
  if (tab === 'ar')       renderAR();
  if (tab === 'ap')       renderAP();
}

function renderFinance() {
  const tourRecs  = FINANCE.filter(f => f.type !== 'Expense');
  const totalRev  = tourRecs.reduce((s,f) => s + (f.rev||0), 0);
  const totalCashIn  = FINANCE.reduce((s,f) => s + (f.cashIn||0), 0);
  const totalCashOut = FINANCE.reduce((s,f) => s + (f.cashOut||0), 0);
  const cashBalance  = totalCashIn - totalCashOut;
  const totalAR   = FINANCE_AR.filter(r => r.status !== 'Paid').reduce((s,r) => s + (r.balance||0), 0);
  const totalAP   = FINANCE_AP.filter(p => p.status !== 'Paid').reduce((s,p) => s + (p.amount||0), 0);

  document.getElementById('finance-kpis').innerHTML = [
    ['Revenue YTD',    '$'+fmt(totalRev),      'var(--g)',   '▲'],
    ['Cash Balance',   '$'+fmt(cashBalance),   cashBalance>=0?'var(--g)':'var(--red)', '$'],
    ['Outstanding AR', '$'+fmt(totalAR),       'var(--amb)', '⬇'],
    ['Pending AP',     '$'+fmt(totalAP),       'var(--red)', '⬆'],
  ].map(([l,v,c,icon]) => `<div class="fin-k"><div class="fin-k-l">${icon} ${l}</div><div class="fin-k-v" style="color:${c}">${v}</div></div>`).join('');

  const STATUS_C = {'Paid':'bdg-g','Deposit Paid':'bdg-a','Confirmed':'bdg-b','Invoiced':'bdg-p','Overdue':'bdg-r'};
  document.getElementById('finance-tbody').innerHTML = FINANCE.map(f => {
    const profit = (f.rev||0) - (f.cost||0);
    const margin = f.rev > 0 ? Math.round(profit/f.rev*100) : 0;
    return `<tr>
      <td><code style="font-size:10.5px;color:var(--g)">${f.id}</code></td>
      <td style="font-size:12px">${f.custName||'<span style="color:var(--m)">—</span>'}</td>
      <td>${bdg(f.type,'bdg-w')}</td>
      <td style="color:var(--m)">${f.month||'—'}</td>
      <td style="font-weight:600">${f.rev>0?'$'+fmt(f.rev):'—'}</td>
      <td>${f.cost>0?'$'+fmt(f.cost):'—'}</td>
      <td style="color:var(--g);font-weight:600">${profit>0?'$'+fmt(profit):'—'}</td>
      <td style="color:var(--blue)">${f.rev>0?margin+'%':'—'}</td>
      <td style="color:var(--g);font-weight:600">${f.cashIn>0?'$'+fmt(f.cashIn):'—'}</td>
      <td style="color:var(--red)">${f.cashOut>0?'$'+fmt(f.cashOut):'—'}</td>
      <td>${bdg(f.status,STATUS_C[f.status]||'bdg-w')}</td>
      <td style="color:var(--m);font-size:11.5px">${f.inv||f.notes||'—'}</td>
    </tr>`;
  }).join('');
}

// ── CASHFLOW ──────────────────────────────────────────────────────
function renderCashflow() {
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const monthly = {};
  MONTHS.forEach(m => { monthly[m] = { cashIn:0, cashOut:0 }; });
  FINANCE.forEach(f => {
    const mo = (f.month||'').split(' ')[0];
    if (monthly[mo]) { monthly[mo].cashIn += f.cashIn||0; monthly[mo].cashOut += f.cashOut||0; }
  });
  const active = MONTHS.filter(m => monthly[m].cashIn > 0 || monthly[m].cashOut > 0);
  const maxVal = Math.max(...active.map(m => Math.max(monthly[m].cashIn, monthly[m].cashOut)), 1);
  const chartH = 130;

  document.getElementById('cashflow-chart').innerHTML = `
    <div style="display:flex;align-items:flex-end;gap:10px;padding:0 12px;height:${chartH+42}px">
      ${active.map(m => {
        const inH  = Math.max(Math.round(monthly[m].cashIn  / maxVal * chartH), 2);
        const outH = Math.max(Math.round(monthly[m].cashOut / maxVal * chartH), 2);
        const net  = monthly[m].cashIn - monthly[m].cashOut;
        return `<div style="display:flex;flex-direction:column;align-items:center;flex:1;min-width:44px">
          <div style="font-size:9.5px;font-weight:700;color:${net>=0?'var(--g)':'var(--red)'};margin-bottom:3px">${net>=0?'+':''}$${Math.round(Math.abs(net)/1000)}k</div>
          <div style="display:flex;align-items:flex-end;gap:3px;height:${chartH}px">
            <div title="Cash In: $${fmt(monthly[m].cashIn)}"  style="width:20px;height:${inH}px;background:var(--g);border-radius:3px 3px 0 0;cursor:pointer"></div>
            <div title="Cash Out: $${fmt(monthly[m].cashOut)}" style="width:20px;height:${outH}px;background:#C0392B;opacity:.75;border-radius:3px 3px 0 0;cursor:pointer"></div>
          </div>
          <div style="font-size:10.5px;font-weight:600;color:var(--m);margin-top:5px">${m}</div>
        </div>`;
      }).join('')}
      <div style="display:flex;flex-direction:column;justify-content:flex-end;padding-bottom:26px;gap:5px;margin-left:10px;white-space:nowrap">
        <div style="display:flex;align-items:center;gap:5px;font-size:11px"><div style="width:12px;height:12px;background:var(--g);border-radius:2px"></div>Cash In</div>
        <div style="display:flex;align-items:center;gap:5px;font-size:11px"><div style="width:12px;height:12px;background:#C0392B;opacity:.75;border-radius:2px"></div>Cash Out</div>
      </div>
    </div>`;

  let running = 0;
  const rows = active.map(m => {
    const net = monthly[m].cashIn - monthly[m].cashOut;
    running += net;
    return `<tr>
      <td><b>${m} 2026</b></td>
      <td style="color:var(--g);font-weight:600">$${fmt(monthly[m].cashIn)}</td>
      <td style="color:var(--red)">$${fmt(monthly[m].cashOut)}</td>
      <td style="font-weight:700;color:${net>=0?'var(--g)':'var(--red)'}">${net>=0?'+':'−'}$${fmt(Math.abs(net))}</td>
      <td style="font-weight:700;color:${running>=0?'var(--g)':'var(--red)'}">$${fmt(running)}</td>
    </tr>`;
  });
  const tIn=active.reduce((s,m)=>s+monthly[m].cashIn,0);
  const tOut=active.reduce((s,m)=>s+monthly[m].cashOut,0);
  const tNet=tIn-tOut;
  rows.push(`<tr style="background:var(--gl);font-weight:700">
    <td>YTD Total</td>
    <td style="color:var(--g)">$${fmt(tIn)}</td>
    <td style="color:var(--red)">$${fmt(tOut)}</td>
    <td style="color:${tNet>=0?'var(--g)':'var(--red)'}">${tNet>=0?'+':'−'}$${fmt(Math.abs(tNet))}</td>
    <td style="color:${running>=0?'var(--g)':'var(--red)'}">$${fmt(running)}</td>
  </tr>`);
  document.getElementById('cashflow-tbody').innerHTML = rows.join('');
}

// ── P&L ───────────────────────────────────────────────────────────
function renderPL() {
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const mo = {};
  MONTHS.forEach(m => { mo[m] = { rev:0, cost:0, opex:0 }; });
  FINANCE.forEach(f => {
    const m = (f.month||'').split(' ')[0];
    if (!mo[m]) return;
    if (f.type === 'Expense') { mo[m].opex += f.cashOut||0; }
    else { mo[m].rev += f.rev||0; mo[m].cost += f.cost||0; }
  });
  const active = MONTHS.filter(m => mo[m].rev > 0 || mo[m].opex > 0);
  let ytdRev=0, ytdCost=0, ytdOpex=0;
  const rows = active.map(m => {
    const d=mo[m], gp=d.rev-d.cost, net=gp-d.opex;
    const gpM=d.rev>0?Math.round(gp/d.rev*100):0, netM=d.rev>0?Math.round(net/d.rev*100):0;
    ytdRev+=d.rev; ytdCost+=d.cost; ytdOpex+=d.opex;
    return `<tr>
      <td><b>${m} 2026</b></td>
      <td style="font-weight:600">$${fmt(d.rev)}</td>
      <td>$${fmt(d.cost)}</td>
      <td style="color:var(--g);font-weight:600">$${fmt(gp)}</td>
      <td style="color:var(--blue)">${gpM}%</td>
      <td style="color:var(--red)">$${fmt(d.opex)}</td>
      <td style="font-weight:700;color:${net>=0?'var(--g)':'var(--red)'}">$${fmt(Math.abs(net))}${net<0?' ▼':' ▲'}</td>
      <td style="color:${net>=0?'var(--g)':'var(--red)'}">${netM}%</td>
    </tr>`;
  });
  const ytdGP=ytdRev-ytdCost, ytdNet=ytdGP-ytdOpex;
  rows.push(`<tr style="background:var(--gl);font-weight:700">
    <td>YTD Total</td><td>$${fmt(ytdRev)}</td><td>$${fmt(ytdCost)}</td>
    <td style="color:var(--g)">$${fmt(ytdGP)}</td>
    <td style="color:var(--blue)">${ytdRev>0?Math.round(ytdGP/ytdRev*100):0}%</td>
    <td style="color:var(--red)">$${fmt(ytdOpex)}</td>
    <td style="color:${ytdNet>=0?'var(--g)':'var(--red)'}">$${fmt(Math.abs(ytdNet))}</td>
    <td style="color:${ytdNet>=0?'var(--g)':'var(--red)'}">${ytdRev>0?Math.round(ytdNet/ytdRev*100):0}%</td>
  </tr>`);
  document.getElementById('pl-tbody').innerHTML = rows.join('');
}

// ── ACCOUNTS RECEIVABLE ───────────────────────────────────────────
let finARFilter = '';
function setARFilter(f) {
  finARFilter = f;
  document.querySelectorAll('[id^="arf-"]').forEach(b => b.classList.remove('csf-active'));
  document.getElementById(f ? 'arf-'+f : 'arf-all')?.classList.add('csf-active');
  renderAR();
}
function renderAR() {
  const today = new Date();
  const filtered = FINANCE_AR.filter(r => !finARFilter || r.status === finARFilter);
  const outstanding = FINANCE_AR.filter(r=>r.status!=='Paid').reduce((s,r)=>s+(r.balance||0),0);
  const overdue     = FINANCE_AR.filter(r=>r.status==='Overdue').reduce((s,r)=>s+(r.balance||0),0);
  const collected   = FINANCE_AR.filter(r=>r.status==='Paid').reduce((s,r)=>s+(r.invoiceAmt||0),0);
  document.getElementById('ar-summary').innerHTML = [
    ['⬇ Outstanding','$'+fmt(outstanding),'var(--amb)'],
    ['⚠ Overdue',    '$'+fmt(overdue),    'var(--red)'],
    ['✓ Collected YTD','$'+fmt(collected),'var(--g)'],
  ].map(([l,v,c])=>`<div class="fin-k"><div class="fin-k-l">${l}</div><div class="fin-k-v" style="color:${c}">${v}</div></div>`).join('');
  const AR_C = {Outstanding:'bdg-a',Overdue:'bdg-r','Partially Paid':'bdg-b',Paid:'bdg-g'};
  document.getElementById('ar-tbody').innerHTML = filtered.map(r => {
    const days = Math.round((today - new Date(r.dueDate))/(864e5));
    const daysStr = r.status==='Paid'?'—': days>0?`<span style="color:var(--red);font-weight:600">${days}d overdue</span>`:`<span style="color:var(--m)">${Math.abs(days)}d left</span>`;
    return `<tr>
      <td><code style="font-size:10.5px;color:var(--g)">${r.id}</code></td>
      <td>${r.custName}</td><td style="font-size:11.5px;color:var(--m)">${r.tour}</td>
      <td style="font-weight:600">$${fmt(r.invoiceAmt)}</td>
      <td style="color:var(--g)">$${fmt(r.depositPaid)}</td>
      <td style="font-weight:700;color:${r.status==='Paid'?'var(--m)':'var(--red)'}">$${fmt(r.balance)}</td>
      <td style="color:var(--m)">${r.dueDate}</td><td>${daysStr}</td>
      <td>${bdg(r.status,AR_C[r.status]||'bdg-w')}</td>
      <td>${r.status!=='Paid'?`<button onclick="markARPaid('${r.id}')" style="background:var(--gl);border:1px solid var(--g);border-radius:5px;padding:3px 9px;cursor:pointer;font-size:11px;color:var(--gd);font-family:inherit">✓ Mark Received</button>`:'<span style="color:var(--m);font-size:11px">Collected</span>'}</td>
    </tr>`;
  }).join('')||'<tr><td colspan="10" style="text-align:center;color:var(--m);padding:20px">No records</td></tr>';
}
function markARPaid(id) {
  const r = FINANCE_AR.find(x=>x.id===id);
  if (!r||!confirm(`Mark $${fmt(r.balance)} from ${r.custName} as received?`)) return;
  r.status='Paid'; r.depositPaid=r.invoiceAmt; r.balance=0;
  persistFinance(); renderAR();
  _sbfToast(`✓ $${fmt(r.invoiceAmt)} received from ${r.custName}`, 'success');
}

// ── ACCOUNTS PAYABLE ──────────────────────────────────────────────
let finAPFilter = '';
function setAPFilter(f) {
  finAPFilter = f;
  document.querySelectorAll('[id^="apf-"]').forEach(b => b.classList.remove('csf-active'));
  document.getElementById(f ? 'apf-'+f : 'apf-all')?.classList.add('csf-active');
  renderAP();
}
function renderAP() {
  const today = new Date();
  const filtered = FINANCE_AP.filter(p => !finAPFilter || p.status === finAPFilter);
  const pending  = FINANCE_AP.filter(p=>p.status!=='Paid').reduce((s,p)=>s+(p.amount||0),0);
  const overdue  = FINANCE_AP.filter(p=>p.status==='Overdue').reduce((s,p)=>s+(p.amount||0),0);
  const paid     = FINANCE_AP.filter(p=>p.status==='Paid').reduce((s,p)=>s+(p.amount||0),0);
  document.getElementById('ap-summary').innerHTML = [
    ['⬆ Pending Payments','$'+fmt(pending),'var(--amb)'],
    ['⚠ Overdue',         '$'+fmt(overdue),'var(--red)'],
    ['✓ Paid YTD',        '$'+fmt(paid),   'var(--g)'],
  ].map(([l,v,c])=>`<div class="fin-k"><div class="fin-k-l">${l}</div><div class="fin-k-v" style="color:${c}">${v}</div></div>`).join('');
  const AP_C = {Pending:'bdg-a',Overdue:'bdg-r',Paid:'bdg-g'};
  document.getElementById('ap-tbody').innerHTML = filtered.map(p => {
    const days = Math.round((today - new Date(p.dueDate))/(864e5));
    const daysStr = p.status==='Paid'?'—': days>0?`<span style="color:var(--red);font-weight:600">${days}d overdue</span>`:`<span style="color:var(--m)">${Math.abs(days)}d left</span>`;
    return `<tr>
      <td><code style="font-size:10.5px;color:var(--g)">${p.id}</code></td>
      <td><b>${p.supplier}</b></td><td style="font-size:11.5px;color:var(--m)">${p.description}</td>
      <td>${bdg(p.category,'bdg-w')}</td>
      <td style="font-weight:700;color:${p.status==='Paid'?'var(--m)':'var(--red)'}">$${fmt(p.amount)}</td>
      <td style="color:var(--m)">${p.dueDate}</td><td>${daysStr}</td>
      <td>${bdg(p.status,AP_C[p.status]||'bdg-w')}</td>
      <td>${p.status!=='Paid'?`<button onclick="markAPPaid('${p.id}')" style="background:var(--gl);border:1px solid var(--g);border-radius:5px;padding:3px 9px;cursor:pointer;font-size:11px;color:var(--gd);font-family:inherit">✓ Mark Paid</button>`:'<span style="color:var(--m);font-size:11px">Paid</span>'}</td>
    </tr>`;
  }).join('')||'<tr><td colspan="9" style="text-align:center;color:var(--m);padding:20px">No records</td></tr>';
}
function markAPPaid(id) {
  const p = FINANCE_AP.find(x=>x.id===id);
  if (!p||!confirm(`Mark payment to ${p.supplier} ($${fmt(p.amount)}) as paid?`)) return;
  p.status='Paid'; persistFinance(); renderAP();
  _sbfToast(`✓ Payment to ${p.supplier} marked as paid`, 'success');
}

// ── ADD FINANCE RECORD ────────────────────────────────────────────
function openAddFinanceRecord() {
  const el = document.getElementById('fr-date');
  if (el) el.value = new Date().toISOString().split('T')[0];
  document.getElementById('fin-rec-overlay').classList.add('open');
}
function saveFinanceRecord() {
  const date = document.getElementById('fr-date')?.value||'';
  if (!date) { alert('Please select a date.'); return; }
  const d = new Date(date);
  const month = d.toLocaleString('en',{month:'short'})+' '+d.getFullYear();
  const yr = String(new Date().getFullYear()).slice(-2);
  const id = 'FIN-20'+yr+'-'+String(FINANCE.length+1).padStart(3,'0');
  FINANCE.push({
    id, month, date,
    custName:   document.getElementById('fr-client')?.value  ||'',
    bkid:       document.getElementById('fr-bkid')?.value    ||'',
    type:       document.getElementById('fr-type')?.value    ||'Tour',
    rev:        parseFloat(document.getElementById('fr-rev')?.value)     ||0,
    cost:       parseFloat(document.getElementById('fr-cost')?.value)    ||0,
    cashIn:     parseFloat(document.getElementById('fr-cashin')?.value)  ||0,
    cashOut:    parseFloat(document.getElementById('fr-cashout')?.value) ||0,
    status:     document.getElementById('fr-status')?.value  ||'Invoiced',
    inv:        document.getElementById('fr-inv')?.value     ||'',
    notes:      document.getElementById('fr-notes')?.value   ||'',
  });
  persistFinance();
  closeModal('fin-rec-overlay');
  renderFinance();
  _sbfToast('✓ Finance record saved — ' + id, 'success');
}

