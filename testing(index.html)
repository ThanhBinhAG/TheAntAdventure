// ── DELETE CUSTOMER ───────────────────────────────────────────────
function deleteCustomer(id) {
  const c = CUSTOMERS.find(x => x.id === id);
  if (!c) return;
  const linkedLeads    = LEADS.filter(l => l.custId === id);
  const linkedBookings = BOOKINGS.filter(b => b.custId === id || b.customerName === c.name);
  let msg = `Delete client "${c.name}" (${id})?\n\nThis cannot be undone.`;
  if (linkedLeads.length || linkedBookings.length) {
    msg = `⚠ Warning: "${c.name}" has linked data:\n`;
    if (linkedLeads.length)    msg += `  • ${linkedLeads.length} lead(s) in the pipeline\n`;
    if (linkedBookings.length) msg += `  • ${linkedBookings.length} booking(s)\n`;
    msg += `\nAll linked records will also be deleted.\nAre you sure?`;
  }
  if (!confirm(msg)) return;

  // Remove customer
  const idx = CUSTOMERS.findIndex(x => x.id === id);
  if (idx >= 0) CUSTOMERS.splice(idx, 1);
  // Remove linked leads
  linkedLeads.forEach(l => {
    const li = LEADS.findIndex(x => x.id === l.id);
    if (li >= 0) LEADS.splice(li, 1);
  });
  // Remove linked bookings
  linkedBookings.forEach(b => {
    const bi = BOOKINGS.findIndex(x => x.id === b.id);
    if (bi >= 0) BOOKINGS.splice(bi, 1);
  });
  persist();         // saves CUSTOMERS + LEADS
  persistBookings(); // saves BOOKINGS
  renderCustomers();
  populateCustDropdown();
  _sbfToast(`✓ Client "${c.name}" and linked records deleted`, 'success');
}

