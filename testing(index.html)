    }
  });
  if (halfBuf) itinDays.push({ day:dayNum++, dest:halfBuf.dest||'', hotel:'', activities:[{name:halfBuf.n,cat:halfBuf.cat||'Activity'}] });

  const newLead = {
    id: 'LD-'+Date.now(),
    custId, tour: selProds.map(p=>p.n).slice(0,2).join(' + ')+(selProds.length>2?' + more':''),
    pax, value: sellPerPax*pax, month: month+' 2026', stage:'Designing', owner:'Tai',
    itinerary: itinDays  // <!-- stored for Supplier Booking Forms auto-fill -->
  };
  LEADS.push(newLead);
  persist();
  alert(`✓ Saved to Sales Pipeline!\n\nClient: ${custName}\n${selProds.length} experiences · $${fmt(sellPerPax)}/pax · Group total: $${fmt(sellPerPax*pax)}\nStage: Designing`);
}

