      </div>
      <div style="padding:10px 12px" onmouseenter="this.previousElementSibling?.querySelector('.del-btn')?.style.setProperty('display','block')" onmouseleave="this.previousElementSibling?.querySelector('.del-btn')?.style.setProperty('display','none')">
        <div style="font-size:12.5px;font-weight:600;margin-bottom:5px">${p.caption}</div>
        ${tags.length ? `<div style="display:flex;flex-wrap:wrap;gap:4px">${tagPills}${morePill}</div>` : ''}
