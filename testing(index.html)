function getLibPrice(productId) {
  const pax = parseInt(document.getElementById('d-pax')?.value) || 2;
  const pn = Math.min(Math.max(pax, 1), 10);
  const t = TAA_TOURS.find(x => x.id === productId);
  if (t && t['p'+pn] > 0) return '$' + t['p'+pn] + '/pax';
  const prod = PRODUCTS.find(x => x.id === productId);
  if (prod && prod.cost > 0) return '$' + prod.cost + '/pax';
  return 'Price on request';
}

