function parseBookingDate(str) {
  if (!str) return '';
  const MON = {Jan:'01',Feb:'02',Mar:'03',Apr:'04',May:'05',Jun:'06',Jul:'07',Aug:'08',Sep:'09',Oct:'10',Nov:'11',Dec:'12'};
  const m = str.trim().match(/^([A-Za-z]+)\s+(\d+)$/);
  if (!m) return '';
  const mo = MON[m[1]]; const day = m[2].padStart(2,'0');
  if (!mo) return '';
  return `2026-${mo}-${day}`;
}

