// ── Hotel cost calculator (indexed per hotel block) ───────────────
function calcHotelCost(n) {
  const cin  = document.getElementById(`sbf-hotel-${n}-cin`)?.value;
  const cout = document.getElementById(`sbf-hotel-${n}-cout`)?.value;
  const rate = parseFloat(document.getElementById(`sbf-hotel-${n}-rate`)?.value || 0);
  let nights = '', total = '', vat = '';
  if (cin && cout) {
    const ms = new Date(cout) - new Date(cin);
    const nn = Math.round(ms / 86400000);
    if (nn > 0) {
      nights = nn;
      const t = nn * rate;
      total  = rate > 0 ? `USD ${t.toLocaleString('en-US',{minimumFractionDigits:2})}` : '';
      vat    = rate > 0 ? `USD ${(t*1.1).toLocaleString('en-US',{minimumFractionDigits:2})}` : '';
    }
  }
  const setRO = (id, val) => { const el = document.getElementById(id); if (el) el.value = val; };
  setRO(`sbf-hotel-${n}-nights`, nights);
  setRO(`sbf-hotel-${n}-total`,  total);
  setRO(`sbf-hotel-${n}-vat`,    vat);
}

