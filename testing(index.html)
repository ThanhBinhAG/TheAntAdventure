function editGuide(id) { openAddGuideModal(id); }

function saveNewGuide() {
  const id       = document.getElementById('ag-id')?.value?.trim();
  const fullname = document.getElementById('ag-fullname')?.value?.trim();
  const langs    = document.getElementById('ag-langs')?.value?.trim();
  if (!id || !fullname || !langs) { alert('Guide ID, Full Name, and Languages are required.'); return; }
  const modal    = document.getElementById('add-guide-modal');
  const editId   = modal?.dataset?.editId;
  const guide = {
    id,
    fullname,
    ename:      document.getElementById('ag-ename')?.value?.trim() || fullname,
    region:     document.getElementById('ag-region')?.value || 'North',
    langs,
    specialty:  document.getElementById('ag-specialty')?.value?.trim() || 'Culture',
    license:    document.getElementById('ag-license')?.value || 'National',
    rate:       parseFloat(document.getElementById('ag-rate')?.value||'0')||0,
    rating:     document.getElementById('ag-rating')?.value || '★★★★',
    status:     document.getElementById('ag-status')?.value || 'Available',
    photo:'',
    years:      parseInt(document.getElementById('ag-years')?.value||'0')||0,
    location:   document.getElementById('ag-location')?.value?.trim()||'',
    phone:      document.getElementById('ag-phone')?.value?.trim()||'',
    email:      document.getElementById('ag-email')?.value?.trim()||'',
    shirtSize:  document.getElementById('ag-shirtsize')?.value||'',
    bankAccount:document.getElementById('ag-bank')?.value?.trim()||'',
    address:    document.getElementById('ag-address')?.value?.trim()||'',
    bio:        document.getElementById('ag-bio')?.value?.trim()||'',
    reviews:[],
  };
  // Load from localStorage or seed
  let guides = LS.get('ant_guides_v3', SEED_GUIDES);
  if (editId) {
    const idx = guides.findIndex(g=>g.id===editId);
    if (idx>=0) { guides[idx]={...guides[idx],...guide}; }
  } else {
    if (guides.find(g=>g.id===id)) { alert('Guide ID "'+id+'" already exists. Please use a unique ID.'); return; }
    guides.push(guide);
  }
  LS.set('ant_guides_v3', guides);
  GUIDES = guides;
  modal.style.display = 'none';
  renderGuides();
  if (document.getElementById('guide-bio-view')?.style.display!=='none') renderGuideBios();
  const verb = editId ? 'updated' : 'added';
  const info = document.getElementById('guides-kpi-bar');
  if (info) { info.textContent = '✅ Guide '+guide.fullname+' '+verb+' successfully.'; setTimeout(()=>{info.textContent='';},3000); }
}

