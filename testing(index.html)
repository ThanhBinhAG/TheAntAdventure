function goStep(n) {
  curStep = n;
  renderSteps();
  for (let i=1;i<=4;i++) {
    const el = document.getElementById('ds'+i);
    if (el) el.style.display = i===n?'block':'none';
  }
  if (n===2) { renderLibrary(); updateBriefBar(); setLibTab(currentLibTab||'pkg'); renderPkgList(); }
  if (n===3) renderPricingStep();
  if (n===4) { document.getElementById('ai-box').style.display='none'; document.getElementById('ai-error').style.display='none'; document.getElementById('copy-ai-btn').style.display='none'; }
}



document.querySelectorAll('#ds1 select, #ds1 textarea, #ds1 input[type="text"], #ds1 input[type="date"]').forEach(el => el.addEventListener('change', updateBriefBarFull));

function populateBriefStaffDropdown() {
  const sel = document.getElementById('d-salesperson');
  if (!sel) return;
  const current = sel.value;
  sel.innerHTML = '<option value="">— Not assigned —</option>';
  STAFF.filter(s => s.status === 'Active').forEach(s => {
    const opt = document.createElement('option');
    opt.value = s.ename || s.name;
    opt.textContent = (s.ename || s.name) + ' · ' + s.pos;
    sel.appendChild(opt);
  });
  if (current) sel.value = current;
}

function autoFillBrief(sel) {
  const id = sel?.value;
  if (!id) { updateBriefBar(); return; }
  const c = CUSTOMERS.find(x => x.id === id);
  if (!c) { updateBriefBar(); return; }

  // Helper: only set if the element exists AND the value is non-empty
  const set = (elId, val) => {
    const el = document.getElementById(elId);
    if (el && val !== undefined && val !== null && String(val) !== '') el.value = String(val);
  };

  // ── Client Type & Assignment ──────────────────────────────────────
  set('d-type',      c.clientType || 'b2c');
  toggleB2BField();
  set('d-agent',     c.agentName  || '');
  populateBriefStaffDropdown();
  set('d-salesperson', c.salesPerson || '');

  // ── Profile fields — auto-fill from Customer record ──────────────
  set('d-pax',       c.numAdults  || '2');
  set('d-style',     c.style      || 'Luxury');
  set('d-lang',      c.lang       || 'English');
  set('d-tier',      c.tier       || 'Boutique 4★');
  set('d-budget',    c.budget     || '');
  set('d-month',     c.month      || '');
  set('d-nationality', c.nat || c.country || '');
  set('d-firsttime',    c.firstTime   || '');
  set('d-flights',      c.flights     || 'yes');
  set('d-intl-flights', c.intlFlights || 'not-included');
  set('d-visa',         c.visa        || 'exempt');
  set('d-interests',    c.interests   || '');
  set('d-donts',        c.donts       || '');

  // ── Children — auto-fill + trigger toggle ────────────────────────
  set('d-children', String(c.numChildren || 0));
  toggleChildAges(); // show/hide age/diet/prefs fields
  set('d-child-ages',  c.childAges  || '');
  set('d-child-diet',  c.childDiet  || '');
  set('d-child-prefs', c.childPrefs || '');

  updateBriefBar();
  _sbfToast(`✓ Brief filled from ${c.name}'s profile`, 'success');
}

