    cats.includes(s.cat) &&
    (!q || s.name.toLowerCase().includes(q) || s.desc.toLowerCase().includes(q) || s.location.toLowerCase().includes(q)) &&
    (!region || s.region===region) &&
    (!tier || (s.tags||[]).some(t=>t.toLowerCase()===tier))
