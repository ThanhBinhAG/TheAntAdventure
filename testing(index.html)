function renderGuideCal() {
  initCalDropdowns();
  const guideF = document.getElementById('cal-guide-f')?.value || '';
  const guides = getGuides().filter(g => !guideF || g.id === guideF);

  const year  = calCurrentDate.getFullYear();
  const month = calCurrentDate.getMonth();
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const label = document.getElementById('cal-month-label');
  if (label) label.textContent = monthNames[month] + ' ' + year;

  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const todayStr = new Date().toISOString().split('T')[0];

  // Build day headers
  const dayHeaders = [];
  for (let d = 1; d <= daysInMonth; d++) {
    const dt = new Date(year, month, d);
    const dow = ['Su','Mo','Tu','We','Th','Fr','Sa'][dt.getDay()];
    const isWeekend = dt.getDay() === 0 || dt.getDay() === 6;
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = dateStr === todayStr;
    dayHeaders.push({d, dow, dateStr, isWeekend, isToday});
  }

  // Build rows
  const rows = guides.map(g => {
    const gEvents = CAL_EVENTS.filter(e => e.guideId === g.id);
    const REG_COLORS = {North:'#2E7D52', Central:'#856404', South:'#1565C0'};
    const avatarBg = REG_COLORS[g.region] || '#2E7D52';

    const cells = dayHeaders.map(dh => {
      // Find events overlapping this day
      const dayEvents = gEvents.filter(e => dh.dateStr >= e.start && dh.dateStr <= e.end);
      const isStart = gEvents.some(e => e.start === dh.dateStr);
      let cellContent = '';
      if (dayEvents.length) {
        cellContent = dayEvents.map(ev => {
          const st = CAL_STATUS_STYLES[ev.status] || CAL_STATUS_STYLES.ontour;
          const dispCode = ev.bookingCode || ev.tour || '';
          const shortLabel = dispCode.substring(0,14);
          const showLabel = ev.start === dh.dateStr;
          const tooltip = [ev.bookingCode, ev.tour, ev.clients].filter(Boolean).join(' | ');
          return `<div class="cal-event ${st.cls}" title="${tooltip}" onclick="editCalEvent('${ev.id}')">${showLabel ? st.emoji+' '+shortLabel : ''}</div>`;
        }).join('');
      } else {
        cellContent = '<div class="cal-avail-dot"></div>';
      }
      const todayCls = dh.isToday ? ' today-col' : (dh.isWeekend ? ' weekend-col' : '');
      return `<td class="${todayCls}">${cellContent}</td>`;
    }).join('');

    return `<tr>
      <td class="guide-name-col">
        <div style="display:flex;align-items:center;gap:7px">
          <div style="width:28px;height:28px;border-radius:6px;background:${avatarBg};color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">${g.ename.charAt(0)}</div>
          <div>
            <div style="font-size:12px;font-weight:600">${g.ename}</div>
            <div style="font-size:10px;color:var(--m)">${g.region}</div>
          </div>
        </div>
      </td>
      ${cells}
    </tr>`;
  }).join('');

  // Day header row
  const headerCells = dayHeaders.map(dh => {
    const cls = dh.isToday ? ' today-col' : '';
    return `<th class="${cls}" style="min-width:32px"><div>${dh.dow}</div><div>${dh.d}</div></th>`;
  }).join('');

  const container = document.getElementById('guide-cal-grid');
  if (!container) return;
  container.innerHTML = `<div style="overflow-x:auto;border:1px solid var(--b);border-radius:11px;overflow:hidden">
    <table class="cal-grid-table">
      <thead><tr>
        <th class="guide-col">Guide</th>
        ${headerCells}
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>
  </div>
  <div style="margin-top:10px;font-size:11.5px;color:var(--m)">
    💡 Click any event to edit or delete · Green dots = Available · Click "+ Log Tour" to add a booking
  </div>`;
}

