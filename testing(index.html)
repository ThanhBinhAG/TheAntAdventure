// DASHBOARD UPGRADES
// ══════════════════════════════════════════════════════════════════
const FX = { USD: 1, EUR: 0.92, VND: 25000 };
const FX_SYM = { USD: '$', EUR: '€', VND: '₫' };
// ── Dashboard chart instances (destroyed before re-render)
let _dashMktChart = null;
let _dashFunnelChart = null;
let _dashTrendChart = null;


function renderDashboard() {
  const typeF     = document.getElementById('dash-type-f')?.value || '';
  const marketF   = document.getElementById('dash-market-f')?.value || '';
  const currency  = document.getElementById('dash-currency-f')?.value || 'USD';
  const sym       = FX_SYM[currency];
  const rate      = FX[currency];

  // Filter label
  const lbl   = document.getElementById('dash-filter-label');
  const parts = [];
  if (typeF)   parts.push(typeF === 'b2b' ? 'B2B Agents' : 'B2C Direct');
  if (marketF) parts.push(marketF);
  if (lbl) lbl.textContent = parts.length ? 'Filtering: ' + parts.join(' · ') : 'Showing all data';

  // ── KPI calculations — corrected v22 ──────────────────────────────
  const allLeads  = LEADS.filter(l => !typeF || l.clientType === typeF || (typeF === 'b2b' && !l.clientType && l.id.includes('ILV')));

  // Active Quotes = Designing + Quoted + Pending (Negotiation treated as Pending)
  const drafted   = allLeads.filter(l => l.stage === 'Designing').length;
  const sent      = allLeads.filter(l => l.stage === 'Quoted').length;
  const pending   = allLeads.filter(l => l.stage === 'Negotiation').length;
  const activeQuoteCount = drafted + sent + pending;

  // Confirmed Bookings = Confirmed + On Tour
  const confirmed = allLeads.filter(l => l.stage === 'Confirmed' || l.stage === 'On Tour');
  const totalPax  = confirmed.reduce((s, l) => s + (parseInt(l.pax) || 0), 0);
  const totalVal  = confirmed.reduce((s, l) => s + (l.value || 0), 0);

  // Realized Revenue = Completed leads + Fully Paid bookings (no double-count: leads first, then orphan bookings)
  const completedLeads    = allLeads.filter(l => l.stage === 'Completed');
  const completedLeadsBkIds = completedLeads.map(l => l.id);
  const realizedFromLeads  = completedLeads.reduce((s, l) => s + (l.value || 0), 0);
  const realizedFromBk     = BOOKINGS.filter(b => (b.status === 'Fully Paid' || b.status === 'Completed') && !completedLeadsBkIds.some(lid => b.id.includes(lid.replace('LD-','')))).reduce((s, b) => s + (b.total || 0), 0);
  const realized           = realizedFromLeads + realizedFromBk;

  // Weighted forecast — corrected probabilities per Alex Chen audit
  const STAGE_PROB_V22 = {Inquiry:10, Designing:25, Quoted:40, Negotiation:40, Pending:70, Confirmed:90, 'On Tour':95, Completed:100, Lost:0};
  const weightedForecast = allLeads
    .filter(l => l.stage !== 'Lost' && l.stage !== 'Completed')
    .reduce((s, l) => s + ((l.value || 0) * ((l.probability ?? STAGE_PROB_V22[l.stage] ?? 10) / 100)), 0);

  const setEl = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  setEl('kpi-drafted',       drafted);
  setEl('kpi-sent',          sent);
  setEl('kpi-pending',       pending);
  setEl('kpi-confirmed',     confirmed.length);
  setEl('kpi-confirmed-pax', totalPax + ' pax secured');
  setEl('kpi-confirmed-val', sym + fmt(Math.round(totalVal * rate)) + ' confirmed value');
  setEl('kpi-revenue',       sym + fmt(Math.round(realized * rate)));
  setEl('kpi-revenue-sub',   completedLeads.length + ' completed tours · ' + BOOKINGS.filter(b=>b.status==='Fully Paid').length + ' fully paid');

  // ── YTD Revenue vs Target progress bar (v22) ──────────────────────
  const YTD_TARGET = 250000;
  const ytdPct     = Math.min(100, Math.round(realized / YTD_TARGET * 100));
  const ytdEl      = document.getElementById('dash-ytd-bar');
  if (ytdEl) {
    const remaining = Math.max(0, YTD_TARGET - realized);
    ytdEl.innerHTML = `
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px">
        <span style="font-size:13px;font-weight:600;color:var(--t)">YTD Revenue vs. Annual Target</span>
        <span style="font-size:11px;color:var(--m)">${sym}${fmt(Math.round(YTD_TARGET * rate))} target</span>
      </div>
      <div style="background:var(--bg);border-radius:6px;height:22px;overflow:hidden;margin-bottom:7px;border:1px solid var(--b)">
        <div style="width:${ytdPct}%;height:100%;background:${ytdPct>=80?'var(--g)':ytdPct>=40?'var(--amb)':'var(--blue)'};border-radius:6px;transition:width .4s;display:flex;align-items:center;justify-content:flex-end;padding-right:8px">
          ${ytdPct > 8 ? `<span style="font-size:11px;font-weight:700;color:#fff">${ytdPct}%</span>` : ''}
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:12px">
        <span><b style="color:var(--g)">${sym}${fmt(Math.round(realized * rate))}</b> realized</span>
        <span style="color:var(--m)"><b>${sym}${fmt(Math.round(remaining * rate))}</b> remaining</span>
      </div>`;
  }

  // ── Weighted forecast KPI ────────────────────────────────────────
  const wfEl = document.getElementById('kpi-weighted-forecast');
  if (wfEl) wfEl.innerHTML = `
    <div style="font-size:26px;font-weight:700;font-family:'DM Serif Display',Georgia,serif;color:var(--pur)">${sym}${fmt(Math.round(weightedForecast * rate))}</div>
    <div style="font-size:11px;color:var(--m);margin-top:3px">Probability-weighted pipeline</div>`;

  // ── Revenue by Market chart (Chart.js) ───────────────────────────
  // Build from LEADS + CUSTOMERS; fall back to demo if sparse
  const mktMap = {};
  allLeads.forEach(l => {
    if (!l.value || l.value <= 0) return;
    const cust = CUSTOMERS.find(c => c.id === l.custId);
    const country = cust?.country || 'Other';
    mktMap[country] = (mktMap[country] || 0) + (l.value || 0);
  });
  // Demo fallback if no real data
  const DEMO_MKT = {USA:94000, Australia:74000, France:55000, UK:41000, Germany:20000};
  const mktData = Object.keys(mktMap).length >= 2 ? mktMap : DEMO_MKT;
  const filtered = marketF
    ? Object.fromEntries(Object.entries(mktData).filter(([m]) => m === marketF))
    : mktData;
  const mktLabels = Object.keys(filtered);
  const mktVals   = mktLabels.map(m => Math.round(filtered[m] * rate));

  const chartEl = document.getElementById('dash-chart');
  if (chartEl) {
    chartEl.innerHTML = '<canvas id="canvas-mkt" height="160"></canvas>';
    if (_dashMktChart) { _dashMktChart.destroy(); _dashMktChart = null; }
    const ctx = document.getElementById('canvas-mkt');
    if (ctx && typeof Chart !== 'undefined') {
      _dashMktChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: mktLabels,
          datasets: [{
            label: 'Revenue ' + sym,
            data: mktVals,
            backgroundColor: ['#2E7D52','#5AA87A','#C9A84C','#1565C0','#6B21A8','#C0392B'],
            borderRadius: 5,
            borderSkipped: false,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: ctx => ' ' + sym + fmt(ctx.parsed.x) } }
          },
          scales: {
            x: { grid: { display: false }, ticks: { callback: v => sym + fmt(v), font: {size:11} } },
            y: { grid: { display: false }, ticks: { font: {size:12} } }
          }
        }
      });
    } else if (ctx) {
      // Chart.js not loaded yet — render plain bars
      chartEl.innerHTML = mktLabels.map((m, i) => {
        const maxV = Math.max(...mktVals, 1);
        const pct  = Math.round(mktVals[i] / maxV * 100);
        return `<div style="display:flex;align-items:center;gap:10px;font-size:12px;margin-bottom:9px">
          <span style="width:85px;text-align:right;color:var(--m)">${m}</span>
          <div style="flex:1;background:var(--bg);border-radius:4px;height:24px;overflow:hidden">
            <div style="width:${pct}%;height:100%;background:var(--g);border-radius:4px;display:flex;align-items:center;padding-left:9px;color:#fff;font-size:11.5px;font-weight:500">${sym}${fmt(mktVals[i])}</div>
          </div>
        </div>`;
      }).join('');
    }
  }

  // ── Monthly Revenue Trend chart (v22) ───────────────────────────
  const trendEl = document.getElementById('dash-trend');
  if (trendEl) {
    const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    // Realized = Completed leads per month
    const realizedByMonth = MONTHS.map(m =>
      LEADS.filter(l => l.stage === 'Completed' && (l.month||'').startsWith(m)).reduce((s,l) => s + (l.value||0), 0)
    );
    // Forecast = Confirmed + Quoted leads per month (not yet realized)
    const forecastByMonth = MONTHS.map(m =>
      LEADS.filter(l => (l.stage === 'Confirmed' || l.stage === 'Quoted') && (l.month||'').startsWith(m)).reduce((s,l) => s + (l.value||0), 0)
    );
    trendEl.innerHTML = '<canvas id="canvas-trend" height="160"></canvas>';
    if (_dashTrendChart) { _dashTrendChart.destroy(); _dashTrendChart = null; }
    const tCtx = document.getElementById('canvas-trend');
    if (tCtx && typeof Chart !== 'undefined') {
      _dashTrendChart = new Chart(tCtx, {
        type: 'bar',
        data: {
          labels: MONTHS,
          datasets: [
            {
              label: 'Realized Revenue',
              data: realizedByMonth.map(v => Math.round(v * rate)),
              backgroundColor: '#2E7D52',
              borderRadius: 4,
              borderSkipped: false,
            },
            {
              label: 'Forecast (Confirmed + Quoted)',
              data: forecastByMonth.map(v => Math.round(v * rate)),
              backgroundColor: '#FDE68A',
              borderColor: '#D97706',
              borderWidth: 1,
              borderRadius: 4,
              borderSkipped: false,
            }
          ]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: true, position: 'top', labels: { font: { size: 11 }, boxWidth: 12 } },
            tooltip: { callbacks: { label: c => ' ' + c.dataset.label + ': ' + sym + fmt(c.parsed.y) } }
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { size: 11 } } },
            y: { grid: { color: '#f0f0f0' }, ticks: { callback: v => sym + fmt(v), font: { size: 11 } }, stacked: false }
          }
        }
      });
    }
  }

  // ── Conversion Funnel chart (Chart.js) ──────────────────────────
  const stageNames  = ['Inquiry','Designing','Quoted','Negotiation','Confirmed','Completed'];
  const stageCounts = stageNames.map(s => LEADS.filter(l => l.stage === s).length);
  const stageColors = ['#1565C0','#6B21A8','#D97706','#D97706','#2E7D52','#6B7F74'];

  const funnelEl = document.getElementById('dash-funnel');
  if (funnelEl) {
    funnelEl.innerHTML = '<canvas id="canvas-funnel" height="140"></canvas>';
    if (_dashFunnelChart) { _dashFunnelChart.destroy(); _dashFunnelChart = null; }
    const fCtx = document.getElementById('canvas-funnel');
    if (fCtx && typeof Chart !== 'undefined') {
      _dashFunnelChart = new Chart(fCtx, {
        type: 'bar',
        data: {
          labels: stageNames,
          datasets: [{
            data: stageCounts,
            backgroundColor: stageColors,
            borderRadius: 5,
            borderSkipped: false,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ' ' + c.parsed.y + ' leads' } } },
          scales: {
            x: { grid: { display: false }, ticks: { font: {size:11} } },
            y: { grid: { color: '#f0f0f0' }, ticks: { stepSize: 1, font: {size:11} } }
          }
        }
      });
    } else if (fCtx) {
      const maxS = Math.max(...stageCounts, 1);
      funnelEl.innerHTML = stageNames.map((s, i) => `
        <div style="display:flex;align-items:center;gap:10px;font-size:12px;margin-bottom:8px">
          <span style="width:80px;color:var(--m)">${s}</span>
          <div style="flex:1;background:var(--bg);border-radius:4px;height:20px;overflow:hidden">
            <div style="width:${Math.round(stageCounts[i]/maxS*100)}%;height:100%;background:${stageColors[i]};border-radius:4px"></div>
          </div>
          <span style="width:24px;text-align:right;font-weight:600">${stageCounts[i]}</span>
        </div>`).join('');
    }
  }

  // ── Pipeline by Stage ──────────────────────────────────────────
  const pipeEl = document.getElementById('dash-pipeline');
  const STAGE_C = {Inquiry:'bdg-b',Designing:'bdg-p',Quoted:'bdg-a',Negotiation:'bdg-a',Confirmed:'bdg-g',Completed:'bdg-w',Lost:'bdg-r'};
  if (pipeEl) pipeEl.innerHTML = stageNames.map(s => {
    const cnt    = LEADS.filter(l => l.stage === s).length;
    const stgVal = LEADS.filter(l => l.stage === s).reduce((acc, l) => acc + (l.value || 0), 0);
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--b);font-size:12.5px">
      <span>${s}</span>
      <div style="display:flex;gap:6px;align-items:center">
        ${stgVal > 0 ? `<span style="font-size:11px;color:var(--m)">${sym}${fmt(Math.round(stgVal * rate))}</span>` : ''}
        ${bdg(cnt, STAGE_C[s]||'bdg-w')}
      </div>
    </div>`;
  }).join('');

  // ── Top Tours YTD (from LEADS with value) ──────────────────────
  const toursEl = document.getElementById('dash-tours');
  if (toursEl) {
    const topLeads = [...allLeads]
      .filter(l => l.value > 0)
      .sort((a, b) => b.value - a.value)
      .slice(0, 5);
    if (topLeads.length) {
      toursEl.innerHTML = topLeads.map(l =>
        `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--b);font-size:12px">
          <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding-right:8px">${l.tour}</span>
          <span style="font-weight:600;color:var(--g);white-space:nowrap">${sym}${fmt(Math.round(l.value * rate))}</span>
        </div>`).join('');
    } else {
      toursEl.innerHTML = [['Vietnam Full 14D',22000],['North Classic 12D',12800],['Central Heritage 7D',8200],['Mekong Delta 4D',5600]].map(([t,v])=>
        `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--b);font-size:12px"><span>${t}</span><span style="font-weight:600;color:var(--g)">${sym}${fmt(Math.round(v*rate))}</span></div>`).join('');
    }
  }

  // ── B2B vs B2C split ───────────────────────────────────────────
  const splitEl = document.getElementById('dash-split');
  if (splitEl) {
    const b2b   = LEADS.filter(l => l.clientType === 'b2b' || (l.notes || '').includes('B2B') || (l.notes || '').includes('ILV') || (l.notes || '').includes('agent')).length;
    const b2c   = Math.max(0, LEADS.length - b2b);
    const total = LEADS.length || 1;
    splitEl.innerHTML = `
      <div style="display:flex;gap:0;border-radius:8px;overflow:hidden;height:28px;margin-bottom:10px">
        <div style="flex:${b2b||1};background:var(--pur);display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600">B2B ${Math.round(b2b/total*100)}%</div>
        <div style="flex:${b2c||1};background:var(--g);display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600">B2C ${Math.round(b2c/total*100)}%</div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:12px">
        <span><span style="color:var(--pur);font-weight:600">●</span> ${b2b} agent leads</span>
        <span><span style="color:var(--g);font-weight:600">●</span> ${b2c} direct clients</span>
      </div>`;
  }

  // ── B2B Agent Pipeline widget ──────────────────────────────────
  renderDashboardAgents();

  // ── NPS & Satisfaction widget ───────────────────────────────────
  renderDashboardNPS();

  // ── KPI Delta badges — vs previous 30-day period (v46) ──────────
  try {
    const deltas = calcKPIDeltas();
    renderDeltaBadge(deltas.quotesDelta,   'kpi-drafted');
    renderDeltaBadge(deltas.bookingsDelta, 'kpi-confirmed');
    renderDeltaBadge(deltas.revenueDelta,  'kpi-revenue');
  } catch {}

  // ── Forecast Breakdown Table (v48 Prompt #5) ─────────────────────
  try { renderForecastTable(); } catch {}
}


