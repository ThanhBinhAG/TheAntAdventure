// Stage priority order for "most advanced" logic
const STAGE_ORDER = ['Completed','Confirmed','Negotiation','Quoted','Designing','Inquiry'];

function getClientPipeline(custId) {
  const allLeads = LEADS.filter(l => l.custId === custId);
  const active   = allLeads.filter(l => l.stage !== 'Lost');
  if (!active.length) return { stage: null, value: 0, count: 0 };
  // Most advanced stage
  let bestStage = null;
  for (const s of STAGE_ORDER) {
    if (active.find(l => l.stage === s)) { bestStage = s; break; }
  }
  // Value = sum of non-Completed, non-Lost leads
  const openLeads = active.filter(l => l.stage !== 'Completed');
  const totalVal  = openLeads.reduce((s,l) => s + (l.value||0), 0);
  return { stage: bestStage, value: totalVal, count: active.length };
}

let custStageFilter = '';

function setCustStageFilter(stage) {
  custStageFilter = stage;
  // Update active button style
  document.querySelectorAll('.csf-btn').forEach(b => b.classList.remove('csf-active'));
  const btnId = stage === '' ? 'csf-all' : stage === 'none' ? 'csf-none' : 'csf-' + stage;
  const activeBtn = document.getElementById(btnId);
  if (activeBtn) activeBtn.classList.add('csf-active');
  renderCustomers();
}

function renderCustomers() {
  const q  = (document.getElementById('cust-search')?.value||'').toLowerCase();
  const sf = document.getElementById('cust-source-f')?.value||'';
  const cf = document.getElementById('cust-country-f')?.value||'';

  let filtered = CUSTOMERS.filter(c =>
    (!q  || c.name.toLowerCase().includes(q) || c.email.toLowerCase().includes(q)) &&
    (!sf || c.source === sf) &&
    (!cf || c.country === cf)
  );

  // Stage filter
  if (custStageFilter === 'none') {
    filtered = filtered.filter(c => LEADS.filter(l => l.custId === c.id && l.stage !== 'Lost').length === 0);
  } else if (custStageFilter) {
    filtered = filtered.filter(c => {
      const p = getClientPipeline(c.id);
      return p.stage === custStageFilter;
    });
  }

  // Update count badge
  const countBadge = document.getElementById('cust-count-badge');
  if (countBadge) countBadge.textContent = `${filtered.length} client${filtered.length!==1?'s':''}`;

  const tbody = document.getElementById('cust-tbody');
  if (!tbody) return;
  tbody.innerHTML = filtered.map(c => {
    // NPS badge
    let npsBadge = `<span class="bdg bdg-w">—</span>`;
    try {
      const cfb = getClientFeedback(c);
      if (cfb.length) {
        const avg = cfb.reduce((s,f)=>s+(f.nps||0),0)/cfb.length;
        const avgR = Math.round(avg*10)/10;
        npsBadge = `<span class="bdg ${_npsClass(avg)}" title="${cfb.length} survey(s)">${_npsIcon(avg)} ${avgR}</span>`;
      }
    } catch {}

    // Client type badge
    const isB2B = c.clientType === 'b2b';
    const typeBadge = isB2B
      ? `<span class="bdg" style="background:#F3E5F5;color:#6B21A8;font-size:10px">B2B</span>`
      : `<span class="bdg bdg-b" style="font-size:10px">B2C</span>`;

    // Pipeline badge + value
    const p = getClientPipeline(c.id);
    let pipelineBadge = `<span class="bdg bdg-w" style="font-size:10px">No Activity</span>`;
    if (p.stage) {
      const cls = STAGE_COLORS[p.stage] || 'bdg-w';
      pipelineBadge = `<span class="bdg ${cls}" style="font-size:10px">${p.stage}</span>`;
    }
    const valueStr = p.value > 0 ? `<div style="font-size:10.5px;color:var(--g);font-weight:600;margin-top:2px">$${p.value.toLocaleString()}</div>` : '';
    const leadsStr = p.count > 0 ? p.count : `<span style="color:var(--m)">0</span>`;

    return `<tr style="cursor:pointer" onclick="openProfile('${c.id}')">
      <td><code style="font-size:10.5px;color:var(--g)">${c.id}</code></td>
      <td><b>${c.name}</b>${c.agentName ? `<div style="font-size:10px;color:var(--pur);margin-top:1px">★ ${c.agentName}</div>` : ''}</td>
      <td style="color:var(--m)">${c.email}</td>
      <td>${c.country}</td>
      <td>${typeBadge}</td>
      <td>${bdg(c.source, SRC_COLORS[c.source]||'bdg-w')}</td>
      <td>${pipelineBadge}</td>
      <td style="font-weight:600;color:var(--g)">${p.value > 0 ? '$'+p.value.toLocaleString() : '<span style="color:var(--m)">—</span>'}</td>
      <td style="text-align:center">${leadsStr}</td>
      <td>${npsBadge}</td>
      <td style="white-space:nowrap">
        <button onclick="event.stopPropagation();openProfile('${c.id}')" style="background:none;border:1px solid var(--b);border-radius:6px;padding:4px 9px;cursor:pointer;font-size:11.5px;color:var(--m);margin-right:4px">View</button>
        <button onclick="event.stopPropagation();openEditCustomer('${c.id}')" style="background:none;border:1px solid var(--g);border-radius:6px;padding:4px 9px;cursor:pointer;font-size:11.5px;color:var(--g);margin-right:4px">✎ Edit</button>
        <button onclick="event.stopPropagation();deleteCustomer('${c.id}')" style="background:none;border:1px solid var(--red);border-radius:6px;padding:4px 9px;cursor:pointer;font-size:11.5px;color:var(--red)">✕ Delete</button>
      </td>
    </tr>`;
  }).join('');
}

