// ── Auto-create hotel blocks from itinerary ──────────────────────
// Groups consecutive days with the same hotel name → one block per group.
// Skips cruise vessels (name contains "Cruise" / "cruise").
function autoCreateHotelBlocks(itinerary, cinISO, guestName, pax) {
  const setH = (id, val) => { const el = document.getElementById(id); if (el && val !== undefined && val !== '') el.value = val; };
  const startDate = cinISO ? new Date(cinISO) : null;

  // ── Build hotel groups from itinerary ──────────────────────
  const groups = []; // { name, dest, cinIdx, coutIdx }
  let curHotel = null, curDest = '', cinIdx = 0;

  const flush = (endIdx) => {
    if (curHotel && !/cruise/i.test(curHotel)) {
      // Clean up dest: if it has arrows take the last segment
      const cleanDest = curDest.includes('→')
        ? curDest.split('→').pop().replace(/\(.*?\)/g,'').trim()
        : curDest.replace(/\(.*?\)/g,'').trim();
      groups.push({ name: curHotel, dest: cleanDest, cinIdx, coutIdx: endIdx });
    }
    curHotel = null; curDest = ''; cinIdx = 0;
  };

  (itinerary || []).forEach((dayObj, i) => {
    const hotel = (dayObj.hotel || '').trim();
    if (!hotel) { flush(i); return; }
    if (hotel !== curHotel) {
      flush(i);
      curHotel = hotel;
      curDest  = dayObj.dest || '';
      cinIdx   = i;
    }
  });
  flush((itinerary || []).length); // close final group

  // ── Fallback: one empty block ──────────────────────────────
  if (!groups.length) {
    addHotelEntry();
    if (guestName) setH('sbf-hotel-1-guest', guestName);
    if (pax)       setH('sbf-hotel-1-pax',   pax);
    if (cinISO)    setH('sbf-hotel-1-cin',    cinISO);
    return;
  }

  // ── Create one block per hotel group ──────────────────────
  groups.forEach((grp) => {
    addHotelEntry();
    const n = _hotelCount;
    setH(`sbf-hotel-${n}-name`,  grp.name);
    setH(`sbf-hotel-${n}-city`,  grp.dest);
    setH(`sbf-hotel-${n}-guest`, guestName || '');
    setH(`sbf-hotel-${n}-pax`,   pax || '');
    if (startDate) {
      const cin  = new Date(startDate); cin.setDate(cin.getDate()  + grp.cinIdx);
      const cout = new Date(startDate); cout.setDate(cout.getDate() + grp.coutIdx);
      setH(`sbf-hotel-${n}-cin`,  cin.toISOString().slice(0,10));
      setH(`sbf-hotel-${n}-cout`, cout.toISOString().slice(0,10));
      calcHotelCost(n);
    }
  });

  sbfMarkActive(1); // first block stays active for day-clicks
}

