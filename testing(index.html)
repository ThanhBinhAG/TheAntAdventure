// Toggle the inline follow-up form on a Kanban card
function toggleFollowUpForm(leadId) {
  const form = document.getElementById('fup-form-' + leadId);
  if (form) form.style.display = form.style.display === 'none' ? 'block' : 'none';
}

// Save follow-up date + next action to the lead and persist
function saveFollowUp(leadId) {
  const lead = LEADS.find(l => l.id === leadId);
  if (!lead) return;
  const dateVal   = document.getElementById('fup-date-' + leadId)?.value || '';
  const actionVal = document.getElementById('fup-action-' + leadId)?.value || '';
  lead.followUpDate = dateVal;
  lead.nextAction   = actionVal;
  persist();
  updatePlannerBadge();
  renderSales(); // re-render cards to show updated pill
}

// Mark a follow-up as done (clears the date, keeps action as note)
function markFollowUpDone(leadId) {
  const lead = LEADS.find(l => l.id === leadId);
  if (!lead) return;
  lead.followUpDate = '';
  persist();
  updatePlannerBadge();
  renderLiveActionHub();
}

// Snooze a follow-up by 1 day
function snoozeFollowUp(leadId) {
  const lead = LEADS.find(l => l.id === leadId);
  if (!lead || !lead.followUpDate) return;
  const d = new Date(lead.followUpDate + 'T12:00:00');
  d.setDate(d.getDate() + 1);
  lead.followUpDate = d.toISOString().split('T')[0];
  persist();
  updatePlannerBadge();
  renderLiveActionHub();
}

// Update the red overdue badge in the sidebar
function updatePlannerBadge() {
  const today    = new Date().toISOString().split('T')[0];
  const overdue  = LEADS.filter(l => l.followUpDate && l.followUpDate < today && l.stage !== 'Completed' && l.stage !== 'Lost').length;
  const badgeEl  = document.getElementById('planner-overdue-badge');
  if (badgeEl) {
    if (overdue > 0) {
      badgeEl.textContent = overdue;
      badgeEl.style.display = 'inline-block';
    } else {
      badgeEl.style.display = 'none';
    }
  }
}

// Render the 4-section Live Action Hub inside the Daily Planner
function renderLiveActionHub() {
  const today     = new Date().toISOString().split('T')[0];
  const todayDate = new Date(today + 'T12:00:00');

  // Helper: travel month string → approximate date for comparison (assume 1st of the month)
  function monthToDate(m) {
    if (!m) return null;
    const parts = m.trim().split(' ');
    const months = {Jan:'01',Feb:'02',Mar:'03',Apr:'04',May:'05',Jun:'06',Jul:'07',Aug:'08',Sep:'09',Oct:'10',Nov:'11',Dec:'12'};
    const mo = months[parts[0]] || '06';
    const yr = parts[1] || '2026';
    return new Date(yr + '-' + mo + '-01T12:00:00');
  }

  // Helper: render a lead action row
  function leadRow(l, showOverdue) {
    const cust    = CUSTOMERS.find(c => c.id === l.custId);
    const name    = cust?.name || l.notes?.split('·')[0]?.trim() || 'Client';
    const isOd    = l.followUpDate && l.followUpDate < today;
    const daysDue = l.followUpDate ? Math.round((new Date(today) - new Date(l.followUpDate)) / 86400000) : 0;
    return `<div style="display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(--b);font-size:12.5px;${isOd&&showOverdue?'background:#FFF8F7':''}">
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${name}</div>
        <div style="font-size:11.5px;color:var(--m);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${l.tour} · ${l.pax>0?l.pax+' pax · ':''}${l.value>0?'$'+fmt(l.value):'—'}</div>
        ${l.nextAction?`<div style="font-size:11.5px;color:var(--gd);margin-top:2px">→ ${l.nextAction}</div>`:''}
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0">
        <span class="bdg ${l.followUpDate&&l.followUpDate<today?'bdg-r':'bdg-a'}" style="font-size:10px">${l.followUpDate||'—'}${isOd&&daysDue>0?' ('+daysDue+'d late)':''}</span>
        <span class="bdg bdg-w" style="font-size:10px">${l.stage}</span>
        <div style="display:flex;gap:4px;margin-top:2px">
          <button onclick="markFollowUpDone('${l.id}')" style="background:var(--gl);color:var(--g);border:1px solid var(--gm);border-radius:4px;padding:2px 7px;cursor:pointer;font-size:10px;font-family:inherit">✓ Done</button>
