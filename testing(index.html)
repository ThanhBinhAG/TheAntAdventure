          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:5px">
            <span style="font-size:11.5px;color:var(--g);font-weight:600">${l.value > 0 ? '$' + fmt(l.value) : '—'}</span>
            <span style="font-size:10.5px;color:var(--pur)">~${prob}% → ${l.value > 0 ? '$' + fmt(weighted) : '—'}</span>
          </div>
