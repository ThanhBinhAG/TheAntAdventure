// GUEST PANEL: Renders sticky guest card in Step 2 right panel
// DB TABLE NEEDED: guest_profiles (linked to booking/lead)
// ══════════════════════════════════════════════════════════════
function updateGuestPanel() {
  const panel = document.getElementById('guest-panel-body');
  if (!panel) return;

  const type      = document.getElementById('d-type')?.value || 'b2c';
  const custSel   = document.getElementById('d-cust');
  const custName  = custSel?.value ? custSel.options[custSel.selectedIndex].text.split(' (')[0] : '';
  const agentName = (document.getElementById('d-agent')?.value||'').trim();
  const pax       = parseInt(document.getElementById('d-pax')?.value)||2;
  const nChildren = parseInt(document.getElementById('d-children')?.value||0);
  const childAges = (document.getElementById('d-child-ages')?.value||'').trim();
  const travelRaw = document.getElementById('d-travel-date')?.value||'';
  const nat       = (document.getElementById('d-nationality')?.value||'').trim();
  const lang      = document.getElementById('d-lang')?.value||'';
  const style2    = document.getElementById('d-style')?.value||'';
  const tier      = document.getElementById('d-tier')?.value||'';
  const budget    = document.getElementById('d-budget')?.value||'';
  const interests = (document.getElementById('d-interests')?.value||'').trim();
  const donts     = (document.getElementById('d-donts')?.value||'').trim();

  // Format travel date
  let travelStr = 'Date TBC';
  if (travelRaw) {
    const d = new Date(travelRaw + 'T00:00:00');
    if (!isNaN(d.getTime())) {
      const DW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const MN = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      travelStr = DW[d.getDay()] + ', ' + d.getDate() + ' ' + MN[d.getMonth()] + ' ' + d.getFullYear();
    }
  }

  const displayName = type === 'b2b'
    ? (agentName ? 'Agent: ' + agentName : 'B2B Agent (name TBC)')
    : (custName || 'Direct Client (TBC)');

  const paxLine = nChildren > 0
    ? pax + ' adults + ' + nChildren + ' child' + (nChildren>1?'ren':'') + (childAges?' ('+childAges+')':'')
    : pax + ' adults';

  const bookingLine = type === 'b2b'
    ? 'B2B Agent' + (agentName?' · '+agentName:'')
    : 'Direct · ' + (custName||'TBC');

  const rows = [
    ['Travel Date', travelStr],
    ['Booking',     bookingLine],
    ['Guests',      paxLine],
  ];
  if (nat)       rows.push(['Nationality', nat]);
  if (lang)      rows.push(['Language',    lang]);
  if (style2)    rows.push(['Style',       style2]);
  if (tier)      rows.push(['Hotel',       tier]);
  if (budget)    rows.push(['Budget',      budget]);
  if (interests) rows.push(['Interests',   interests]);
  if (donts)     rows.push(['Avoid',       donts]);

  panel.innerHTML =
    '<div style="font-size:12.5px;font-weight:700;color:var(--t);margin-bottom:8px">' + displayName + '</div>' +
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:3px 12px">' +
    rows.map(function(r) {
      return '<div style="display:flex;gap:4px;align-items:baseline;min-width:0">' +
             '<span style="font-size:9.5px;color:var(--gd);white-space:nowrap;font-weight:700;flex-shrink:0">' + r[0] + ':</span>' +
             '<span style="font-size:11px;color:var(--t);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + r[1] + '</span>' +
             '</div>';
    }).join('') +
    '</div>';
}

