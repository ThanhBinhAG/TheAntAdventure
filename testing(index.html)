  const [tbg,tfg] = tagColors[p.tag]||['#f0f0ee','#555'];

  // ── Compute departure date for day labels ─────────────────
  const _DOW    = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const _MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const _MMAP   = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  let _pkgStart = null, _pkgEst = false;
  const _rawDate = document.getElementById('d-travel-date')?.value || '';
  if (_rawDate) {
    const ts = new Date(_rawDate + 'T00:00:00');
    if (!isNaN(ts.getTime())) _pkgStart = ts;
  }
  if (!_pkgStart) {
    const selMon = document.getElementById('d-month')?.value || '';
    if (selMon && _MMAP[selMon] !== undefined) {
      const now = new Date();
      let yr = now.getFullYear();
      if (_MMAP[selMon] < now.getMonth()) yr++;
      _pkgStart = new Date(yr, _MMAP[selMon], 1);
      _pkgEst = true;
    }
  }
  function _pkgDayLabel(n) {
    if (!_pkgStart) return `Day ${n}`;
    const dd = new Date(_pkgStart);
    dd.setDate(dd.getDate() + n - 1);
    const est = _pkgEst ? ' <span style="font-size:9px;opacity:.65">(est.)</span>' : '';
    return `Day ${n} · ${_DOW[dd.getDay()]}, ${dd.getDate()} ${_MONTHS[dd.getMonth()]} ${dd.getFullYear()}${est}`;
  }

  const daysHtml = p.days.map(d => {
    const _dp = getDayPhotos(d.title, p.tag, d.hotel, d.n, 2);
    return `
    <div style="border-left:3px solid var(--g);padding-left:14px;margin-bottom:22px">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;flex-wrap:wrap">
