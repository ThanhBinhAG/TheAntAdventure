// SECTION: KPI DELTA INDICATORS — vs previous 30-day period (v46)
// Compares current 30-day window to prior 30-day window using
// LEADS.month field ("May 2026") as the date proxy (no createdAt).
// BACKEND NEEDED: Replace with real createdAt timestamps from DB.
// ══════════════════════════════════════════════════════════════════

// Parse a lead's representative date from its month field ("May 2026")
function _parseLeadDate(lead) {
  try {
    if (lead.month) {
      const parts = (lead.month || '').trim().split(' ');
      if (parts.length === 2) return new Date(parts[0] + ' 1 ' + parts[1]);
    }
  } catch {}
  return null;
}

// Returns aggregated data for leads whose month falls within [now - startDaysAgo, now - endDaysAgo]
function getPeriodData(startDaysAgo, endDaysAgo) {
  if (endDaysAgo === undefined) endDaysAgo = 0;
  try {
    const now   = new Date();
    const start = new Date(now); start.setDate(start.getDate() - startDaysAgo);
    const end   = new Date(now); end.setDate(end.getDate() - endDaysAgo);

    const inRange = lead => {
      const d = _parseLeadDate(lead);
      return d !== null && d >= start && d <= end;
    };

    const confirmedCount = LEADS.filter(l =>
      (l.stage === 'Confirmed' || l.stage === 'On Tour') && inRange(l)
    ).length;

    const totalRevenue = LEADS.filter(l =>
      l.stage === 'Completed' && inRange(l)
    ).reduce((s, l) => s + (parseFloat(l.value) || 0), 0);

    const quotesCount = LEADS.filter(l =>
      ['Designing', 'Quoted', 'Negotiation', 'Inquiry'].includes(l.stage) && inRange(l)
    ).length;

    return { confirmedCount, totalRevenue, quotesCount };
  } catch {
    return { confirmedCount: 0, totalRevenue: 0, quotesCount: 0 };
  }
}

// Calculate % change between this period and last period
function calcKPIDeltas() {
  try {
    const curr = getPeriodData(30, 0);
    const prev = getPeriodData(60, 31);

    const pct = (c, p) => (p === 0 ? null : (c - p) / p);

    return {
      bookingsDelta: pct(curr.confirmedCount, prev.confirmedCount),
      revenueDelta:  pct(curr.totalRevenue,   prev.totalRevenue),
      quotesDelta:   pct(curr.quotesCount,    prev.quotesCount),
    };
  } catch {
    return { bookingsDelta: null, revenueDelta: null, quotesDelta: null };
  }
}

// Render a delta badge immediately after the target element
function renderDeltaBadge(deltaValue, targetElementId) {
  try {
    const target = document.getElementById(targetElementId);
    if (!target) return;

    // Remove existing badge first to prevent duplication on re-render
    document.getElementById('delta-' + targetElementId)?.remove();

    const div   = document.createElement('div');
    div.id      = 'delta-' + targetElementId;
    div.title   = 'Compared to the previous 30-day period';
    div.style.cssText = 'font-size:11px;margin-top:3px;line-height:1.3';

    if (deltaValue === null || deltaValue === undefined) {
      div.textContent = '— no prior data';
      div.style.color = '#6B7F74';
    } else if (deltaValue > 0) {
      div.textContent      = `▲ +${(deltaValue * 100).toFixed(1)}% vs last 30d`;
      div.style.color      = '#2E7D52';
      div.style.fontWeight = '600';
    } else if (deltaValue < 0) {
      div.textContent      = `▼ ${(Math.abs(deltaValue) * 100).toFixed(1)}% vs last 30d`;
      div.style.color      = '#C0392B';
      div.style.fontWeight = '600';
    } else {
      div.textContent = '→ same as last 30d';
      div.style.color = '#6B7F74';
    }

    // Insert immediately after the target element
    target.parentNode?.insertBefore(div, target.nextSibling);
  } catch {}
}

// ── PROMPT #6: Post-Tour ↔ Client Profile Link ───────────────────────────────

// Helper: get NPS color + badge class from numeric score
function _npsClass(avg) {
  if (avg === null || avg === undefined || isNaN(avg)) return 'bdg-w';
  if (avg >= 9) return 'bdg-g';
  if (avg >= 7) return 'bdg-a';
  return 'bdg-r';
}
function _npsIcon(avg) {
  if (avg === null || avg === undefined || isNaN(avg)) return '—';
  if (avg >= 9) return '⭐';
  if (avg >= 7) return '👍';
  return '⚠';
}

// Get all client-type feedback records for a customer (by feedbackIds OR name fallback)
function getClientFeedback(cust) {
  try {
    const fb = FEEDBACK_LOG.filter(f => f.type === 'client' && f.nps !== undefined);
    if (cust.feedbackIds && cust.feedbackIds.length) {
      const ids = new Set(cust.feedbackIds);
      return fb.filter(f => ids.has(f.id));
    }
    // Fallback: name match
    const nm = (cust.name || '').toLowerCase().trim();
    return fb.filter(f => (f.client || '').toLowerCase().trim() === nm);
  } catch { return []; }
}

// Link a saved feedback record to CUSTOMERS (feedbackIds) and BOOKINGS (feedbackId)
function linkFeedbackToClient(feedbackRecord) {
  try {
    if (!feedbackRecord || feedbackRecord.type !== 'client') return;
    const nm = (feedbackRecord.client || '').toLowerCase().trim();
    if (nm) {
      const cust = CUSTOMERS.find(c => (c.name || '').toLowerCase().trim() === nm);
      if (cust) {
        if (!Array.isArray(cust.feedbackIds)) cust.feedbackIds = [];
        if (!cust.feedbackIds.includes(feedbackRecord.id)) {
          cust.feedbackIds.push(feedbackRecord.id);
        }
        persist(); // saves CUSTOMERS
      }
    }
    const bkid = feedbackRecord.bkid;
    if (bkid) {
      const bk = BOOKINGS.find(b => b.id === bkid);
      if (bk) {
        bk.feedbackId = feedbackRecord.id;
        persistBookings();
      }
    }
  } catch(e) { console.warn('linkFeedbackToClient:', e); }
}
