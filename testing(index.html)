        el.textContent = '✓ Set';
        el.style.color = 'var(--g)';
      } else {
        el.textContent = '— Empty';
        el.style.color = 'var(--m)';
      }
    }
  });
  const lastEl = document.getElementById('ai-last-saved');
  if (lastEl) lastEl.textContent = saved.savedAt || 'Never';
}

// ── Inject AI requirements into AI export prompts ──────────────
function getAISystemRules() {
  var saved = LS.get('ant_ai_reqs', {});
  var parts = [];
  if (saved.rules) parts.push('BUSINESS RULES:\n' + saved.rules);
  if (saved.suppliers) parts.push('SUPPLIER PREFERENCES:\n' + saved.suppliers);
  if (saved.pricing) parts.push('PRICING RULES:\n' + saved.pricing);
  if (saved.design) parts.push('TOUR DESIGN LOGIC:\n' + saved.design);
  if (saved.voice) parts.push('BRAND VOICE:\n' + saved.voice);
  if (saved.extra) parts.push('ADDITIONAL NOTES:\n' + saved.extra);
  return parts.length ? '\n\n=== SYSTEM REQUIREMENTS ===\n' + parts.join('\n\n') + '\n=== END REQUIREMENTS ===\n\n' : '';
}

