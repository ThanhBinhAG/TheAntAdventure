// SECTION: GLOBAL SEARCH (v25)
// ══════════════════════════════════════════════════════════════════
let _gsActiveIdx = -1;
let _gsResults   = [];

function runGlobalSearch(q) {
  const drop = document.getElementById('gsearch-dropdown');
  if (!drop) return;
  q = (q||'').trim();
  if (q.length < 2) { drop.style.display = 'none'; _gsResults=[]; _gsActiveIdx=-1; return; }
  const ql = q.toLowerCase();

  // ─ Clients ─
  const clients = CUSTOMERS.filter(c =>
    (c.name||'').toLowerCase().includes(ql) ||
    (c.email||'').toLowerCase().includes(ql) ||
    (c.notes||'').toLowerCase().includes(ql)
  );
  // ─ Leads ─
  const leads = LEADS.filter(l =>
    (l.tour||'').toLowerCase().includes(ql) ||
    (l.notes||'').toLowerCase().includes(ql) ||
    (l.owner||'').toLowerCase().includes(ql) ||
    (l.id||'').toLowerCase().includes(ql)
  );
  // ─ Bookings ─
  const bookings = BOOKINGS.filter(b =>
    (b.id||'').toLowerCase().includes(ql) ||
    (b.tour||'').toLowerCase().includes(ql) ||
    (b.guide||'').toLowerCase().includes(ql)
  );
  // ─ Guides ─
  const guides = GUIDES.filter(g =>
    (g.fullname||'').toLowerCase().includes(ql) ||
    (g.specialty||'').toLowerCase().includes(ql) ||
    (g.location||'').toLowerCase().includes(ql)
  );

  _gsResults = [];
  let html = '';

  function section(label, items, renderFn, allCount) {
    if (!items.length) return;
    html += `<div style="padding:6px 12px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--m);background:#F7F8F6;border-bottom:1px solid #eee">${label}</div>`;
    const shown = items.slice(0, 4);
    shown.forEach((item, i) => {
      const idx = _gsResults.length;
      _gsResults.push({ type: label, item });
      html += renderFn(item, idx);
    });
    if (allCount > 4) {
      html += `<div style="padding:6px 12px;font-size:11px;color:var(--g);cursor:pointer;border-top:1px solid #f0f0f0" onclick="closeGlobalSearch()">${allCount - 4} more — refine your search</div>`;
    }
  }

  section('Clients', clients, (c, idx) => {
    const styleMap = {Adventure:'#2E7D52',Cultural:'#6B21A8',Beach:'#1565C0',Family:'#D97706',Luxury:'#C9A84C'};
    const sc = styleMap[c.style]||'#6B7F74';
    return `<div class="gs-row" data-idx="${idx}" onclick="gsOpen(${idx})" style="padding:9px 14px;cursor:pointer;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:10px">
      <div style="width:30px;height:30px;border-radius:50%;background:#E8F5EE;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">👤</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.name}</div>
        <div style="font-size:11px;color:var(--m)">${c.country||''} · ${c.email||''}</div>
      </div>
      <span style="background:${sc}22;color:${sc};border-radius:10px;padding:1px 8px;font-size:10px;font-weight:700;white-space:nowrap">${c.style||'—'}</span>
    </div>`;
  }, clients.length);

  section('Leads', leads, (l, idx) => {
    const cust = CUSTOMERS.find(c=>c.id===l.custId);
    const stageColors = {Inquiry:'#1565C0',Designing:'#6B21A8',Quoted:'#D97706',Negotiation:'#D97706',Confirmed:'#2E7D52',Completed:'#2E7D52',Lost:'#C0392B'};
    const sc = stageColors[l.stage]||'#6B7F74';
    return `<div class="gs-row" data-idx="${idx}" onclick="gsOpen(${idx})" style="padding:9px 14px;cursor:pointer;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:10px">
      <div style="width:30px;height:30px;border-radius:50%;background:#E8F5EE;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">📋</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${l.tour||l.id}</div>
        <div style="font-size:11px;color:var(--m)">${cust?.name||l.custId} · $${fmt(l.value||0)}</div>
      </div>
      <span style="background:${sc}22;color:${sc};border-radius:10px;padding:1px 8px;font-size:10px;font-weight:700;white-space:nowrap">${l.stage}</span>
    </div>`;
  }, leads.length);

  section('Bookings', bookings, (b, idx) => {
    const cust = CUSTOMERS.find(c=>c.id===b.custId);
    return `<div class="gs-row" data-idx="${idx}" onclick="gsOpen(${idx})" style="padding:9px 14px;cursor:pointer;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:10px">
      <div style="width:30px;height:30px;border-radius:50%;background:#E8F5EE;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">🗓</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${b.id} — ${b.tour}</div>
        <div style="font-size:11px;color:var(--m)">${cust?.name||b.custId} · ${b.start}–${b.end} 2026</div>
      </div>
      <span style="background:#E8F5EE;color:var(--g);border-radius:10px;padding:1px 8px;font-size:10px;font-weight:700;white-space:nowrap">${b.guide||'—'}</span>
    </div>`;
  }, bookings.length);

  section('Guides', guides, (g, idx) => {
    const stars = '★'.repeat(Math.round(g.rating||0))+'☆'.repeat(5-Math.round(g.rating||0));
    return `<div class="gs-row" data-idx="${idx}" onclick="gsOpen(${idx})" style="padding:9px 14px;cursor:pointer;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:10px">
      <div style="width:30px;height:30px;border-radius:50%;background:#E8F5EE;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">🧭</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${g.fullname}</div>
        <div style="font-size:11px;color:var(--m)">${g.location||''} · ${g.specialty||''}</div>
      </div>
      <span style="color:var(--gold);font-size:11px;white-space:nowrap">${stars}</span>
    </div>`;
  }, guides.length);

  if (!html) {
    html = `<div style="padding:18px 14px;color:var(--m);text-align:center;font-size:13px">No results for "<b>${q}</b>"</div>`;
  }
  drop.innerHTML = html;
  drop.style.display = 'block';
  _gsActiveIdx = -1;
}

function gsOpen(idx) {
  closeGlobalSearch();
  const r = _gsResults[idx];
  if (!r) return;
  if (r.type === 'Clients')  { nav('customers'); setTimeout(()=>openProfile(r.item.id), 150); }
  if (r.type === 'Leads')    { nav('sales'); setTimeout(()=>{ const el=document.querySelector(`[data-lead-id="${r.item.id}"]`); if(el){el.scrollIntoView({behavior:'smooth',block:'center'});el.style.outline='3px solid var(--g)';setTimeout(()=>el.style.outline='',1500);} },200); }
  if (r.type === 'Bookings') { nav('bookings'); }
  if (r.type === 'Guides')   { nav('guides'); setTimeout(()=>openGuideModal(r.item.id),150); }
}

function handleSearchKey(e) {
  const rows = document.querySelectorAll('.gs-row');
  if (!rows.length) return;
  if (e.key === 'Escape') { closeGlobalSearch(); return; }
  if (e.key === 'ArrowDown') { _gsActiveIdx = Math.min(_gsActiveIdx+1, rows.length-1); }
  else if (e.key === 'ArrowUp') { _gsActiveIdx = Math.max(_gsActiveIdx-1, 0); }
  else if (e.key === 'Enter') { if (_gsActiveIdx >= 0) { rows[_gsActiveIdx].click(); } return; }
  else return;
  e.preventDefault();
  rows.forEach((r,i) => r.style.background = i===_gsActiveIdx ? '#E8F5EE' : '');
  if (rows[_gsActiveIdx]) rows[_gsActiveIdx].scrollIntoView({block:'nearest'});
}

function closeGlobalSearch() {
  const drop = document.getElementById('gsearch-dropdown');
  const inp  = document.getElementById('gsearch-input');
  if (drop) drop.style.display = 'none';
  if (inp)  inp.value = '';
  _gsResults = []; _gsActiveIdx = -1;
}

// Close on outside click
document.addEventListener('click', e => {
  const wrap = document.getElementById('gsearch-wrap');
  if (wrap && !wrap.contains(e.target)) closeGlobalSearch();
});

