function deleteAgent(id) {
  const a=AGENTS.find(x=>x.id===id);
  if(!a) return;
  if(!confirm(`Delete agent "${a.name}"?\n\nThis cannot be undone. Any leads linked to this agent will be unaffected.`)) return;
  AGENTS=AGENTS.filter(x=>x.id!==id);
  LS.set('ant_agents_v3', AGENTS);
  closeAgentModal();
  renderAgents();
}

function saveAgent() {
  const name=document.getElementById('aa-name')?.value.trim();
  if(!name) { alert('Agent name is required.'); return; }
  const existingId=document.getElementById('aa-id')?.value;
  const agentData={
    name,
    country:document.getElementById('aa-country')?.value.trim()||'—',
    tier:document.getElementById('aa-tier')?.value||'Bronze',
    commissionPct:parseFloat(document.getElementById('aa-comm')?.value)||0,
    contactName:document.getElementById('aa-contact')?.value.trim()||'—',
    email:document.getElementById('aa-email')?.value.trim()||'—',
    phone:document.getElementById('aa-phone')?.value.trim()||'—',
    currency:document.getElementById('aa-curr')?.value||'USD',
    status:'Active',
    notes:document.getElementById('aa-notes')?.value.trim()||''
  };
  if(existingId) {
    const idx=AGENTS.findIndex(a=>a.id===existingId);
    if(idx>-1) AGENTS[idx]={...AGENTS[idx],...agentData};
  } else {
    agentData.id='AGT-'+String(Date.now()).slice(-4);
    AGENTS.push(agentData);
  }
  LS.set('ant_agents_v3', AGENTS);
  closeAddAgentModal();
  renderAgents();
}

