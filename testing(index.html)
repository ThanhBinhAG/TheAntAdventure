  const ev = {
    id:      'CE-' + Date.now(),
    guideId,
    bookingCode,
    tour,
    clients,
    start, end,
    status:  document.getElementById('ev-status')?.value || 'booked',
    notes:   document.getElementById('ev-notes')?.value || '',
  };
  CAL_EVENTS.push(ev);
  persistCal();
  document.getElementById('cal-event-modal').style.display = 'none';
  ['ev-bookingcode','ev-tour','ev-clients','ev-notes'].forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
  renderGuideCal();
}

function editCalEvent(id) {
  const ev = CAL_EVENTS.find(e => e.id === id);
  if (!ev) return;
  const g = getGuides().find(x => x.id === ev.guideId);
  const st = CAL_STATUS_STYLES[ev.status] || CAL_STATUS_STYLES.ontour;
  const info = 'Guide: ' + (g?.fullname || ev.guideId) + ' | Tour: ' + ev.tour + ' | ' + ev.start + ' to ' + ev.end + ' | ' + st.label;
  if (confirm(info + ' -- Delete this event?')) {
    CAL_EVENTS = CAL_EVENTS.filter(e => e.id !== id);
    persistCal();
    renderGuideCal();
  }
}

// Updated setGuideTab to include calendar
function setGuideTab(tab) {
  document.getElementById('guide-roster-view').style.display  = tab === 'roster'   ? 'block' : 'none';
  document.getElementById('guide-bio-view').style.display     = tab === 'bios'     ? 'block' : 'none';
  document.getElementById('guide-calendar-view').style.display= tab === 'calendar' ? 'block' : 'none';
  document.querySelectorAll('#guide-tabs .tab').forEach((t,i) => {
    t.classList.toggle('on', (i===0&&tab==='roster')||(i===1&&tab==='bios')||(i===2&&tab==='calendar'));
  });
  if (tab === 'bios')     renderGuideBios();
  if (tab === 'roster')   renderGuides();
  if (tab === 'calendar') renderGuideCal();
}

