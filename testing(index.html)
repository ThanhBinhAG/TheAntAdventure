// ── RENDER ATTRACTIONS ──────────────────────────────────────────
function renderAttractions() {
  const region = document.getElementById('att-region')?.value || '';
  const type = document.getElementById('att-type')?.value || '';
  const q = (document.getElementById('att-q')?.value || '').toLowerCase();
  
  let filtered = ATTRACTION_DATA.filter(a =>
    (!region || a.region === region) &&
    (!type || a.type === type) &&
    (!q || a.name.toLowerCase().includes(q) || a.dest.toLowerCase().includes(q) || a.notes.toLowerCase().includes(q))
  );
  
  // Highlight today closure alerts
  const today = new Date().toLocaleDateString('en-US',{weekday:'long'});
  const alerts = ATTRACTION_DATA.filter(a => {
    const c = a.closed.toUpperCase();
    return c.includes(today.toUpperCase().substring(0,3)) || c.includes('ALWAYS') || c.includes('MAINTENANCE');
  });
  
  const alertBar = document.getElementById('att-alert-bar');
  if (alertBar) {
    const closedToday = filtered.filter(a => {
      const c = a.closed.toUpperCase();
      return c.includes(today.toUpperCase().substring(0,3));
    });
    if (closedToday.length) {
      alertBar.style.display = 'block';
      alertBar.innerHTML = '⚠ Today is ' + today + '. Closed: ' + closedToday.map(a=>'<b>'+a.name+'</b>').join(', ');
    } else {
      alertBar.style.display = 'none';
    }
  }
  
  const grid = document.getElementById('att-grid');
  if (!grid) return;
  
  if (!filtered.length) { grid.innerHTML = '<div style="text-align:center;color:var(--m);padding:40px">No attractions found.</div>'; return; }
  
  // Group by region
  const regGroups = {north:'🏔 Northern Vietnam',central:'🏯 Central Vietnam',south:'🌿 Southern Vietnam'};
  const regions = region ? [region] : ['north','central','south'];
  
  grid.innerHTML = regions.map(r => {
    const ra = filtered.filter(a => a.region === r);
    if (!ra.length) return '';
    const regColors = {north:['#E8F5EE','#1a5c38'],central:['#FFF3CD','#856404'],south:['#E1F0FF','#0c5464']};
    const [rbg,rfg] = regColors[r] || ['#f5f5f5','#333'];
    return '<div style="margin-bottom:20px">' +
      '<div style="margin-bottom:10px"><span style="background:'+rbg+';color:'+rfg+';padding:4px 14px;border-radius:12px;font-size:12px;font-weight:700">'+regGroups[r]+'</span><span style="font-size:11.5px;color:var(--m);margin-left:10px">'+ra.length+' attractions</span></div>' +
      '<div class="card"><div class="card-body" style="padding:0;overflow-x:auto"><table class="tbl">' +
      '<thead><tr><th>Name</th><th>Destination</th><th>Type</th><th>Hours</th><th>Closed</th><th>Admission</th><th>Visit Time</th><th>Best Time</th><th>Crowd Tips</th><th>Book?</th><th>Seasonal Notes</th></tr></thead>' +
      '<tbody>' + ra.map(a => {
        const hasAlert = a.alert && (a.alert.includes('CLOSED') || a.alert.includes('BOOK'));
        return '<tr style="'+(hasAlert?'background:var(--red-l)':'')+'">' +
          '<td><b style="font-size:12.5px">' + a.name + '</b>' +
          (a.alert ? '<br><span style="font-size:10px;color:var(--red);font-weight:700">⚠ '+a.alert+'</span>' : '') + '</td>' +
          '<td style="white-space:nowrap">' + a.dest + '</td>' +
          '<td><span style="background:var(--bg);padding:2px 7px;border-radius:4px;font-size:10.5px;text-transform:capitalize">' + a.type + '</span></td>' +
          '<td style="font-size:11.5px;white-space:nowrap">' + a.hours + '</td>' +
          '<td style="color:var(--red);font-weight:600;font-size:11.5px">' + a.closed + '</td>' +
          '<td style="font-size:11.5px">' + a.admission + '</td>' +
          '<td style="white-space:nowrap;font-size:11.5px">' + a.duration + ' min</td>' +
          '<td style="font-size:11.5px;color:var(--m)">' + a.best_time + '</td>' +
          '<td style="font-size:11.5px;color:var(--m);max-width:160px">' + a.crowd + '</td>' +
          '<td style="text-align:center">' + (a.book_req ? '✅ Yes' : '—') + '</td>' +
          '<td style="font-size:11px;color:var(--m);max-width:180px">' + a.seasonal + '</td>' +
          '</tr>';
      }).join('') +
      '</tbody></table></div></div></div>';
  }).join('');
}

