        <button onclick="downloadTransportRegion('${region}')"
          style="display:flex;align-items:center;gap:6px;padding:7px 14px;background:${color};color:#fff;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit">
          📄 Download ${region} Schedule
