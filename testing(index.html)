// ── RESTAURANT: auto-create + add-entry (one block per culinary item) ──
function autoCreateRestaurantBlocks(itinerary, cinISO, pax) {
  if (!itinerary || !itinerary.length) { addRestaurantEntry(); return; }
  const startDate = cinISO ? new Date(cinISO) : null;
  let created = 0;
  itinerary.forEach((dayObj, i) => {
    (dayObj.activities || []).forEach(a => {
      if (a.cat !== 'Culinary') return;
      addRestaurantEntry();
      const n = _restaurantCount;
      const set = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
      set(`sbf-res-${n}-name`,     a.name);
      set(`sbf-res-${n}-location`, dayObj.dest ? dayObj.dest.split('→')[0].trim() : '');
      set(`sbf-res-${n}-pax`,      pax || '');
      if (startDate) {
        const d = new Date(startDate); d.setDate(d.getDate() + i);
        set(`sbf-res-${n}-date`, d.toISOString().slice(0,10));
      }
      // Auto-guess type from activity name
      const nm = a.name.toLowerCase();
      const typeMap = [
        ['cooking class','Cooking Class'],['market','Market Tour + Cooking'],
        ['street food','Street Food Tour'],['private dining','Private Dining'],
        ['dinner','Restaurant Dinner'],['lunch','Restaurant Lunch']
      ];
      const typeEl = document.getElementById(`sbf-res-${n}-type`);
      if (typeEl) {
        const match = typeMap.find(([kw]) => nm.includes(kw));
        if (match) { for (const opt of typeEl.options) if (opt.value === match[1]) { opt.selected = true; break; } }
      }
      created++;
    });
  });
  if (!created) addRestaurantEntry();
}

