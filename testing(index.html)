// ── PURE API CALLER — no UI side effects, reusable anywhere ──────
// Returns the assistant reply string. Throws a descriptive Error on failure.
async function callAICopilot(userMessage, conversationHistory) {
  const apiKey = LS.get('ant_api_key','');
  if (!apiKey || !apiKey.startsWith('sk-')) {
    throw new Error('NO_API_KEY');
  }

  // Build full system prompt: dynamic header + rich static knowledge base + live CRM snapshot
  let systemPrompt = buildAISystemPrompt();
  systemPrompt += '\n\n' + buildCRMContext(); // fresh snapshot on every send
  if (_aiCtx) {
    systemPrompt += `\n\n## CURRENT PAGE CONTEXT: ${_aiCtx.page}\n${_aiCtx.summary}`;
    if (_aiCtx.data) systemPrompt += `\n\nDetailed data:\n${_aiCtx.data}`;
  }

  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true'
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 2000,
      system: systemPrompt,
      messages: conversationHistory
    })
  });

  if (!res.ok) {
    const err = await res.json().catch(()=>({}));
    throw new Error(`API Error ${res.status}: ${err.error?.message || 'Check your API key and try again.'}`);
  }

  const data = await res.json();
  return data.content?.[0]?.text || '(No response)';
}

// ── UI HANDLER — manages typing indicator, message display, history ──
async function sendAIMessage(overrideText) {
  const input = document.getElementById('ai-input');
  const text  = overrideText || input?.value?.trim();
  if (!text) return;
  if (input && !overrideText) input.value = '';

  // Check key before touching UI
  const apiKey = LS.get('ant_api_key','');
  if (!apiKey || !apiKey.startsWith('sk-')) {
    appendAIMsg('error','⚠ No API key found. Go to ⚡ AI Requirements in the sidebar → paste your Anthropic API key and save it.');
    return;
  }

  appendAIMsg('user', text);
  _aiHistory.push({role:'user', content:text});
  showAITyping();

  try {
    const reply = await callAICopilot(text, _aiHistory);
    removeAITyping();
    _aiHistory.push({role:'assistant', content:reply});
    appendAIMsg('assistant', reply);
  } catch(e) {
    removeAITyping();
    _aiHistory.pop();
    if (e.message === 'NO_API_KEY') {
      appendAIMsg('error','⚠ No API key found. Go to ⚡ AI Requirements in the sidebar → paste your Anthropic API key and save it.');
    } else {
      appendAIMsg('error', e.message.startsWith('API Error') ? e.message : `Connection error: ${e.message}`);
    }
  }
}

