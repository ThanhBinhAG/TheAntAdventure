function renderPricingStep() {
  // ── Live pricing from TAA_TOURS + Pricing module overrides ────────
  // selProds[].id === TAA_TOURS[].id — the link is direct.
  // getSpUSD(t, n) reads priceOverrides first, so any edit in the
  // Pricing module flows here instantly (same priceOverrides object).
  // BACKEND NEEDED: persist priceOverrides to DB table tour_product_prices

  const briefPax  = parseInt(document.getElementById('d-pax')?.value) || 2;
  const container = document.getElementById('price-tbl-container');
  const pkgEl     = document.getElementById('pkg-summary');
  if (!container) return;

  // ── Inject markup control row ─────────────────────────────────────
  const markupRow = document.getElementById('markup-control-row');
  if (markupRow) {
    markupRow.innerHTML = `
      <div style="display:flex;align-items:center;gap:14px;background:var(--gl);border:1px solid #C8E6D4;border-radius:9px;padding:10px 14px;margin-bottom:14px;flex-wrap:wrap">
        <div style="display:flex;align-items:center;gap:6px;flex:1;min-width:220px">
          <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--gd)">✓ Auto-populated from Step 2</span>
          <span style="font-size:11px;color:var(--m)">· Review and adjust below</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <label style="font-size:11.5px;font-weight:600;color:var(--gd)">Markup %</label>
          <input type="range" min="10" max="60" step="1" value="${_step3Markup}"
            oninput="adjustMarkup(this.value)"
            style="width:110px;accent-color:var(--g);cursor:pointer">
          <span id="markup-pct-display" style="font-size:13px;font-weight:700;color:var(--g);min-width:36px">${_step3Markup}%</span>
          <button onclick="adjustMarkup(30)" style="padding:3px 9px;font-size:11px;border:1px solid var(--g);background:#fff;color:var(--g);border-radius:6px;cursor:pointer;font-family:inherit">Reset 30%</button>
        </div>
      </div>`;
  }

  if (!selProds.length) {
    container.innerHTML = `<div style="padding:20px;text-align:center;color:var(--m);font-size:13px">
      ℹ️ No products selected. Go back to Step 2 and add experiences to your itinerary.
    </div>`;
    if (pkgEl) pkgEl.innerHTML = '';
    return;
  }

  const totalD = selProds.reduce((s,p) => s + parseFloat(p.d || 0), 0);

  // 6 presentation tiers → [TAA_TOURS price index n, display label]
  // p1=solo, p2=2pax, p3=3pax, p4=4pax, p5=5pax, p6=6pax, p7=7pax, p8=8pax, p9=9pax, p10=10+pax
  const TIERS = [
    [1, 'Solo'],
    [2, '2 Pax'],
    [3, '3-4 Pax'],
    [5, '5-6 Pax'],
    [7, '7-9 Pax'],
    [10, '10+ Pax']
  ];

  // Map briefPax to nearest tier column highlight
  const activeTierN = briefPax <= 1 ? 1 : briefPax === 2 ? 2 : briefPax <= 4 ? 3 : briefPax <= 6 ? 5 : briefPax <= 9 ? 7 : 10;
  const curN        = briefPax >= 10 ? 10 : briefPax <= 0 ? 1 : briefPax;  // exact n for cost calc

  // Grand totals per tier (sell price sum across all selected products)
  const grandSellTotals = TIERS.map(() => 0);
  let notFound = 0;
  let productRows = '';

  selProds.forEach((sp, idx) => {
    const t = TAA_TOURS.find(x => x.id === sp.id);
    if (!t) { notFound++; return; }
    const tierPrices = TIERS.map(([n], i) => {
      const price = getAdjustedSell(t, n);
      grandSellTotals[i] += price;
      return price;
    });
    const truncName = (sp.n || t.name || '').length > 48
      ? (sp.n || t.name).substring(0, 46) + '…'
      : (sp.n || t.name);
    const cells = TIERS.map(([n], i) => {
      const hl = n === activeTierN;
      return `<td style="text-align:right;${hl ? 'color:var(--g);font-weight:700;background:var(--gl)' : ''}">$${tierPrices[i]}</td>`;
    }).join('');
    productRows += `<tr>
      <td style="font-size:11.5px;color:var(--t2)">${idx+1}. ${truncName}</td>
      ${cells}
    </tr>`;
  });

  // Grand total row
  const totalCells = TIERS.map(([n], i) => {
    const hl = n === activeTierN;
    return `<td style="text-align:right;font-weight:700;${hl ? 'color:var(--g);background:var(--gl)' : 'color:var(--gd)'}">$${fmt(grandSellTotals[i])}</td>`;
  }).join('');

  // Cost & margin for active pax count
  const activeIdx   = TIERS.findIndex(([n]) => n === activeTierN);
  const grandSell   = grandSellTotals[activeIdx] || 0;
  const grandCost   = selProds.reduce((s, sp) => {
    const t = TAA_TOURS.find(x => x.id === sp.id);
    return s + (t ? getCostUSD(t, curN) : 0);
  }, 0);
  const grandMargin = grandSell - grandCost;
  const marginPct   = grandSell > 0 ? Math.round(grandMargin / grandSell * 100) : 0;
  const afterComm   = Math.round(grandSell * 0.85);
  const groupTotal  = grandSell * briefPax;
  const afterCommGrp = Math.round(afterComm * briefPax);

  const notFoundNote = notFound > 0
    ? `<div style="color:var(--amb);font-size:11px;margin-bottom:6px">⚠️ ${notFound} product(s) not found in pricing library.</div>`
    : '';

  const thCells = TIERS.map(([n, lbl]) => {
    const hl = n === activeTierN;
    return `<th style="text-align:right;${hl ? 'background:var(--gl);color:var(--g)' : ''}">${lbl}${hl ? ' ★' : ''}</th>`;
  }).join('');

  container.innerHTML = `
    ${notFoundNote}
    <div style="background:var(--bg);border-radius:7px;padding:9px 12px;margin-bottom:10px;font-size:11.5px;color:var(--gd)">
      <b>Live pricing from Pricing Library</b> · Edits in the Pricing module update instantly · Sell prices include 30% markup
    </div>
    <div style="overflow-x:auto">
    <table class="tbl">
      <thead><tr>
        <th>Experience</th>
        ${thCells}
      </tr></thead>
      <tbody>
        ${productRows}
        <tr style="border-top:2px solid var(--g);background:#e8f5ee44">
          <td style="font-weight:700;color:var(--gd)">Total (per pax)</td>
          ${totalCells}
        </tr>
      </tbody>
    </table>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:10px;font-size:11.5px">
      <div style="background:var(--bg);border-radius:7px;padding:9px 12px">
        <div style="color:var(--m);margin-bottom:2px">Cost/pax (${briefPax} pax)</div>
        <div style="font-size:14px;font-weight:700;color:var(--gd)">$${fmt(grandCost)}</div>
      </div>
      <div style="background:var(--bg);border-radius:7px;padding:9px 12px">
        <div style="color:var(--m);margin-bottom:2px">Sell/pax (${briefPax} pax)</div>
        <div style="font-size:14px;font-weight:700;color:var(--g)">$${fmt(grandSell)}</div>
      </div>
      <div style="background:var(--bg);border-radius:7px;padding:9px 12px">
        <div style="color:var(--m);margin-bottom:2px">Margin</div>
        <div style="font-size:14px;font-weight:700;color:var(--blue)">$${fmt(grandMargin)} <span style="font-size:11px">(${marginPct}%)</span></div>
      </div>
      <div style="background:var(--bg);border-radius:7px;padding:9px 12px">
        <div style="color:var(--m);margin-bottom:2px">After 15% Comm</div>
        <div style="font-size:14px;font-weight:700;color:var(--amb)">$${fmt(afterComm)}/pax</div>
      </div>
    </div>`;

  // ── Package Summary ───────────────────────────────────────────────
  if (pkgEl) {
    pkgEl.innerHTML = `
    <div style="background:var(--gl);border-radius:8px;padding:13px;margin-top:14px">
      <div style="font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--gd);margin-bottom:9px">Package Summary — ${briefPax} Pax</div>
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px">
        ${[
          ['Experiences', selProds.length],
          ['Duration',    totalD + 'D'],
          ['Sell/pax',    '$' + fmt(grandSell)],
          ['Group Total', '$' + fmt(groupTotal)],
          ['After Comm',  '$' + fmt(afterCommGrp)]
        ].map(([l,v]) => `
        <div>
          <div style="font-size:10.5px;color:var(--gd);opacity:.75">${l}</div>
          <div style="font-size:15px;font-weight:700;color:var(--g);font-family:'DM Serif Display',Georgia,'Times New Roman',serif">${v}</div>
        </div>`).join('')}
      </div>
    </div>`;
  }
}

