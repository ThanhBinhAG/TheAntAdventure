// ─── Sub-tab wiring for logistics / water / adventure / experience / personnel ───
function wireSubTabs(attrName, panelPrefix, panels) {
  document.querySelectorAll(`[data-${attrName}-tab]`).forEach(t=>{
    t.onclick = ()=>{
      document.querySelectorAll(`[data-${attrName}-tab]`).forEach(x=>x.classList.remove('on'));
      t.classList.add('on');
      panels.forEach(p=>{
        const el=document.getElementById(panelPrefix+p);
        if(el) el.style.display=(p===t.dataset[attrName.replace(/-([a-z])/g,(_,c)=>c.toUpperCase())+'Tab'])?'block':'none';
      });
    };
  });
}

