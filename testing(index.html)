      (dayObj.activities || []).forEach(a => { if (a.cat === 'Flight') notes.push(`✈ ${a.name}`); });
      const prevHotel = i > 0 ? (itinerary[i-1].hotel || '') : '';
      const curHotel  = dayObj.hotel || '';
      if (curHotel && curHotel !== prevHotel && !/cruise/i.test(curHotel)) notes.push(`🏨 Check-in: ${curHotel}`);
      if (prevHotel && prevHotel !== curHotel && !/cruise/i.test(prevHotel)) notes.push(`Check-out: ${prevHotel}`);

      const tr = document.createElement('tr');
      tr.style.cssText = `background:${rowIdx%2===0?'#fff':'#F7F8F6'};border-bottom:1px solid #E2E8E4`;
      tr.innerHTML = `
        <td style="padding:6px 8px;font-weight:600;color:${color};white-space:nowrap;vertical-align:top">${dateLabel}</td>
        <td style="padding:4px 6px;vertical-align:top">
          <input value="${dayObj.dest||''}" data-region="${region}" data-idx="${i}" data-col="dest"
            style="width:100%;font-size:11.5px;border:1px solid #E2E8E4;border-radius:5px;padding:3px 6px;font-family:inherit;background:transparent"></td>
        <td style="padding:4px 6px;vertical-align:top">
          <textarea rows="2" data-region="${region}" data-idx="${i}" data-col="brief"
            style="width:100%;font-size:11.5px;border:1px solid #E2E8E4;border-radius:5px;padding:3px 6px;font-family:inherit;background:transparent;resize:vertical">${brief}</textarea></td>
        <td style="padding:4px 6px;vertical-align:top">
          <input value="${guideDisp}" data-region="${region}" data-idx="${i}" data-col="guide"
            style="width:100%;font-size:11.5px;border:1px solid #E2E8E4;border-radius:5px;padding:3px 6px;font-family:inherit;background:transparent"></td>
        <td style="padding:4px 6px;vertical-align:top">
          <textarea rows="2" data-region="${region}" data-idx="${i}" data-col="notes"
            style="width:100%;font-size:11.5px;border:1px solid #E2E8E4;border-radius:5px;padding:3px 6px;font-family:inherit;background:transparent;resize:vertical">${notes.join('\n')}</textarea></td>`;
      tbody.appendChild(tr);
    });
  });

  // Insert container before the footer
  const footer = panel.querySelector('.sbf-footer');
  if (footer) panel.insertBefore(container, footer);
  else panel.appendChild(container);

  // Hide old single tbody table wrapper
  const oldWrapper = document.getElementById('sbf-tr-tbody')?.closest('div[style*="overflow-x"]');
  if (oldWrapper) oldWrapper.style.display = 'none';
  // Also hide top-level header (now per-region)
  const topHeader = document.querySelector('#sbf-panel-transport > div:first-child');
  if (topHeader) topHeader.style.display = 'none';
}

// ── TRANSPORT: download Word doc for a single region ──────────────────────────
function downloadTransportRegion(region) {
  if (!_sbfBookingId) return;
  const regionColors = { North:'#1565C0', Central:'#2E7D52', South:'#C0392B', Other:'#6B21A8' };
  const regionEmoji  = { North:'🔵', Central:'🟢', South:'🔴', Other:'⭐' };
  const color   = regionColors[region] || '#2E7D52';
  const emoji   = regionEmoji[region] || '🚐';

  const gr = id => document.getElementById(id)?.value?.trim() || '—';
  const company    = gr(`sbf-tr-${region}-company`);
  const vehicle    = gr(`sbf-tr-${region}-vehicle`);
  const guide      = gr(`sbf-tr-${region}-guide`);
  const phone      = gr(`sbf-tr-${region}-phone`);
  const inclusions = gr(`sbf-tr-${region}-inclusions`);

  let rowsHTML = '';
  const tbody = document.getElementById(`sbf-tr-tbody-${region}`);
  if (tbody) {
    tbody.querySelectorAll('tr').forEach(tr => {
      const cells = tr.querySelectorAll('td');
      if (!cells.length) return;
      const dateCell  = cells[0]?.innerHTML?.replace(/<span[^>]*>/gi,'(').replace(/<\/span>/gi,')').replace(/<[^>]+>/g,'').trim() || '';
      const dest      = cells[1]?.querySelector('input')?.value?.trim()    || '';
      const brief     = cells[2]?.querySelector('textarea')?.value?.trim() || '';
      const guideCell = cells[3]?.querySelector('input')?.value?.trim()    || '';
      const notes     = cells[4]?.querySelector('textarea')?.value?.trim() || '';
      rowsHTML += `<tr>
        <td style="padding:6px 8px;white-space:nowrap;font-weight:600;color:${color}">${dateCell}</td>
        <td style="padding:6px 8px">${dest}</td>
        <td style="padding:6px 8px;white-space:pre-line">${brief}</td>
        <td style="padding:6px 8px">${guideCell}</td>
        <td style="padding:6px 8px;white-space:pre-line;font-size:11px;color:#6B7F74">${notes}</td>
      </tr>`;
    });
  }

  const bookings = LS.get('ant_bookings_v2', []);
  const bk = bookings.find(b => b.id === _sbfBookingId) || {};

  const docHTML = `<!DOCTYPE html><html><head><meta charset="utf-8">
  <style>
    body{font-family:Calibri,Arial,sans-serif;font-size:12pt;margin:30px;color:#1a2e23}
    table{width:100%;border-collapse:collapse;margin-bottom:16px}
    td,th{border:1px solid #ccc;padding:7px 10px;vertical-align:top}
    th{background:${color};color:#fff;font-weight:700;text-align:left}
    tr:nth-child(even){background:#F7F8F6}
    h1{color:${color};font-size:16pt;margin-bottom:4px}
    h2{color:${color};font-size:13pt;margin-bottom:6px}
    .meta{font-size:10pt;color:#6B7F74;margin-bottom:20px}
  </style></head><body>
  <h1>${emoji} ${region} Vietnam — Transport Booking Request</h1>
  <div class="meta">
    Booking: <b>${_sbfBookingId}</b> &nbsp;·&nbsp; Tour: <b>${bk.tourName||'—'}</b> &nbsp;·&nbsp;
    Pax: <b>${bk.pax||'—'}</b> &nbsp;·&nbsp; Dates: <b>${bk.travelDate||'—'}</b>
  </div>
  <h2>Provider Details</h2>
  <table>
    <tr><th colspan="2">${emoji} ${region} Vietnam — Transport Provider</th></tr>
    <tr><td style="width:38%"><b>Transport Company</b></td><td>${company}</td></tr>
    <tr><td><b>Vehicle Type</b></td><td>${vehicle}</td></tr>
    <tr><td><b>Assigned Guide</b></td><td>${guide}</td></tr>
    <tr><td><b>Guide Phone</b></td><td>${phone}</td></tr>
    <tr><td><b>Standard Inclusions</b></td><td>${inclusions}</td></tr>
  </table>
  <h2>📅 Daily Schedule</h2>
  <table>
    <tr style="background:${color};color:#fff">
      <th>Date</th><th>Destination</th><th>Itinerary Brief</th><th>Guide</th><th>Notes</th>
    </tr>
    ${rowsHTML}
  </table>
  <p style="font-size:10pt;color:${color};margin-top:16px">
    <b>Please confirm driver name, vehicle plate number, and WhatsApp contact 24h before service begins.</b><br>
    This is an official transport booking request from <b>The Ant Adventures Co., Ltd.</b>
  </p>
  </body></html>`;

  const blob = new Blob([docHTML], {type:'application/msword'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${_sbfBookingId}_Transport_${region}.doc`;
  a.click();
  URL.revokeObjectURL(a.href);
}

