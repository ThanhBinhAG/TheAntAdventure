// ── renderPlannerGrid — Member × Task list (5 columns) ─────────────────────
// BACKEND NEEDED: replace TASKS array with live API fetch filtered by team/date
function renderPlannerGrid() {
  const container = document.getElementById('planner-team-grid');
  if (!container) return;
  const teamF = document.getElementById('planner-team-f')?.value || '';

  // ── Color maps ────────────────────────────────────────────────
  const DEPT_C = {
    'Sales':      ['#E8F5EE','#1a5c38'],
    'Operations': ['#E1F0FF','#1565C0'],
    'Finance':    ['#FEF3C7','#D97706'],
    'Marketing':  ['#F3E5F5','#6B21A8'],
  };
  const PRI_HEX = {high:'#C0392B', medium:'#D97706', low:'#2E7D52'};
  const ini = n => (n||'?').split(' ').map(w=>w[0]||'').join('').substring(0,2).toUpperCase();

  // ── Status → label + colour ───────────────────────────────────
  function getStatus(t) {
    if (t.priority === 'high' && t.status !== 'done')
      return {label:'Urgent',      bg:'#FDECEA', fg:'#C0392B'};
    const MAP = {
      todo:       {label:'To Do',       bg:'#F0F0EE', fg:'#6B7F74'},
      inprogress: {label:'In Progress', bg:'#E1F0FF', fg:'#1565C0'},
      review:     {label:'In Progress', bg:'#E1F0FF', fg:'#1565C0'},
      done:       {label:'Done',        bg:'#E8F5EE', fg:'#2E7D52'},
    };
    return MAP[t.status] || {label:'To Do', bg:'#F0F0EE', fg:'#6B7F74'};
  }

  // ── Filter & sort (member asc → date asc) ─────────────────────
  const filtered = (teamF ? TASKS.filter(t => t.assignee === teamF) : [...TASKS])
    .sort((a,b) => {
      if (a.assignee < b.assignee) return -1;
      if (a.assignee > b.assignee) return  1;
      return (a.date||'').localeCompare(b.date||'');
    });

  if (!filtered.length) {
    container.innerHTML = '<div style="padding:48px;text-align:center;color:var(--m);font-size:13px">No tasks found for this view.</div>';
    return;
  }

  // ── Group by member (preserving sort order) ───────────────────
  const byMember = {}, memberOrder = [];
  filtered.forEach(t => {
    if (!byMember[t.assignee]) { byMember[t.assignee] = []; memberOrder.push(t.assignee); }
    byMember[t.assignee].push(t);
  });

  // ── Build table ───────────────────────────────────────────────
  let tbl = `<div style="overflow-x:auto">
<table style="width:100%;border-collapse:collapse;border-radius:10px;overflow:hidden;min-width:680px">
<thead><tr>
  <th style="width:150px;background:var(--g);color:#fff;padding:11px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.9px;border-right:1px solid rgba(255,255,255,.15)">MEMBER</th>
  <th style="background:var(--g);color:#fff;padding:11px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.9px;border-right:1px solid rgba(255,255,255,.15)">TASK</th>
  <th style="width:130px;background:var(--g);color:#fff;padding:11px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.9px;border-right:1px solid rgba(255,255,255,.15)">DEPARTMENT</th>
  <th style="width:120px;background:var(--g);color:#fff;padding:11px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.9px;border-right:1px solid rgba(255,255,255,.15)">STATUS</th>
  <th style="background:var(--g);color:#fff;padding:11px 14px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.9px">NOTES &amp; DUE DATE</th>
</tr></thead>
<tbody>`;

  memberOrder.forEach((member, mi) => {
    const tasks   = byMember[member];
    const rowBg   = mi % 2 === 0 ? 'var(--s)' : 'var(--bg)';
    const isLastM = mi === memberOrder.length - 1;

    tasks.forEach((t, ti) => {
      const isFirst = ti === 0;
      const isLastT = ti === tasks.length - 1;
      // Border after last task of member = thick green divider; within member = light
      const borderB = isLastT
        ? (isLastM ? 'none' : '2px solid #c4dfd0')
        : '1px solid var(--b)';
      const pHex        = PRI_HEX[t.priority] || '#6B7F74';
      const [dbg, dfg]  = DEPT_C[t.dept] || ['#F0F0EE','#6B7F74'];
      const st          = getStatus(t);
      const noteText    = (t.notes || '').trim();
      const dueDate     = t.date || '';

      tbl += `<tr>`;

      // ── Col 1: Member cell (rowspan on first row only) ────────
      if (isFirst) {
        tbl += `<td rowspan="${tasks.length}" style="padding:14px 12px;background:${rowBg};border-bottom:${isLastM ? 'none' : '2px solid #c4dfd0'};border-right:1px solid var(--b);vertical-align:middle;text-align:center">
  <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
    <div style="width:40px;height:40px;background:var(--gl);border:2px solid var(--g);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--g)">${ini(member)}</div>
    <span style="font-size:11.5px;font-weight:600;color:var(--t);line-height:1.3">${member}</span>
    <span style="font-size:9.5px;color:var(--m)">${tasks.length} task${tasks.length>1?'s':''}</span>
  </div>
</td>`;
      }

      // ── Col 2: Task title ─────────────────────────────────────
      tbl += `<td style="padding:11px 14px;background:${rowBg};border-bottom:${borderB};border-right:1px solid var(--b)">
  <div style="display:flex;align-items:flex-start;gap:8px">
    <div style="width:3px;min-height:20px;align-self:stretch;background:${pHex};border-radius:2px;flex-shrink:0"></div>
    <div style="font-size:12.5px;font-weight:600;color:var(--t);line-height:1.45">${t.title || '—'}</div>
  </div>
</td>`;

      // ── Col 3: Department ──────────────────────────────────────
      tbl += `<td style="padding:11px 14px;background:${rowBg};border-bottom:${borderB};border-right:1px solid var(--b);vertical-align:middle">
  <span style="background:${dbg};color:${dfg};font-size:10.5px;font-weight:700;padding:4px 10px;border-radius:12px;white-space:nowrap">${t.dept || '—'}</span>
</td>`;

      // ── Col 4: Status ─────────────────────────────────────────
      tbl += `<td style="padding:11px 14px;background:${rowBg};border-bottom:${borderB};border-right:1px solid var(--b);vertical-align:middle">
  <span style="background:${st.bg};color:${st.fg};font-size:10.5px;font-weight:700;padding:4px 10px;border-radius:12px;white-space:nowrap">${st.label}</span>
</td>`;

      // ── Col 5: Notes + Due Date ───────────────────────────────
      tbl += `<td style="padding:11px 14px;background:${rowBg};border-bottom:${borderB};vertical-align:middle">`;
      if (noteText)
        tbl += `<div style="font-size:11.5px;color:var(--t);margin-bottom:5px;line-height:1.5">${noteText}</div>`;
      if (dueDate)
        tbl += `<div style="font-size:10px;color:var(--m);display:inline-flex;align-items:center;gap:4px;background:var(--s);padding:2px 8px;border-radius:10px"><span>&#128197;</span> Due: ${dueDate}</div>`;
      if (!noteText && !dueDate)
        tbl += `<span style="color:var(--m);font-size:11.5px">—</span>`;
      tbl += `</td>`;

      tbl += `</tr>`;
    });
  });

  tbl += `</tbody></table></div>`;
  container.innerHTML = tbl;
}

function plannerNav(dir) {
  plannerCurrentDate.setDate(plannerCurrentDate.getDate() + dir * 7);
  renderPlanner();
}

function plannerGoToday() {
  plannerCurrentDate = new Date();
  renderPlanner();
}

function getWeekDates(base) {
  const dates = [];
  const day = new Date(base);
  day.setDate(day.getDate() - day.getDay() + 1); // Monday
  for (let i = 0; i < 7; i++) {
    dates.push(new Date(day));
    day.setDate(day.getDate() + 1);
  }
  return dates;
}

function fmtDate(d) {
  return d.toISOString().split('T')[0];
}

function renderPlanner() {
  const teamF = document.getElementById('planner-team-f')?.value || '';
  const weekDates = getWeekDates(plannerCurrentDate);
  const dayNames = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const today = fmtDate(new Date());

  // Update header label
  const label = document.getElementById('planner-date-label');
  if (label) {
    const start = weekDates[0];
    const end = weekDates[6];
    const opts = {month:'short', day:'numeric'};
    label.textContent = start.toLocaleDateString('en',opts) + ' – ' + end.toLocaleDateString('en',opts) + ' ' + end.getFullYear();
  }

  // Week grid
  const grid = document.getElementById('planner-grid');
  if (grid) {
    grid.innerHTML = weekDates.map((d, i) => {
      const ds = fmtDate(d);
      const isToday = ds === today;
      const dayTasks = TASKS.filter(t => t.date === ds && (!teamF || t.assignee === teamF));
      const done = dayTasks.filter(t => t.status === 'done').length;
      return `<div style="background:${isToday ? 'var(--gl)' : 'var(--s)'};border:${isToday ? '2px solid var(--g)' : '1px solid var(--b)'};border-radius:10px;padding:10px;cursor:pointer;min-height:110px" onclick="plannerSelectDay('${ds}')">
        <div style="font-size:11px;font-weight:700;color:${isToday ? 'var(--g)' : 'var(--m)'};text-transform:uppercase;letter-spacing:.8px">${dayNames[i]}</div>
        <div style="font-size:20px;font-weight:700;color:${isToday ? 'var(--g)' : 'var(--t)'};margin:3px 0 7px">${d.getDate()}</div>
        ${dayTasks.map(t => `<div style="font-size:10.5px;background:${TASK_STATUS[t.status]?.bg||'#f0f0ee'};color:${TASK_STATUS[t.status]?.fg||'#666'};border-radius:5px;padding:2px 6px;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${PRIORITY_DOTS[t.priority]||''} ${t.title}</div>`).join('')}
        ${dayTasks.length > 3 ? `<div style="font-size:10px;color:var(--m);margin-top:2px">+${dayTasks.length - 3} more</div>` : ''}
        ${dayTasks.length === 0 ? '<div style="font-size:10.5px;color:var(--b);margin-top:4px">No tasks</div>' : ''}
      </div>`;
    }).join('');
  }

  // Today's tasks detail
  renderTodayTasks(today, teamF);

  // Progress
  const allVisible = TASKS.filter(t => !teamF || t.assignee === teamF);
  const progressEl = document.getElementById('planner-progress');
  if (progressEl) {
    const statuses = ['todo','inprogress','review','done'];
    progressEl.innerHTML = statuses.map(s => {
      const cnt = allVisible.filter(t => t.status === s).length;
      const pct = allVisible.length ? Math.round(cnt / allVisible.length * 100) : 0;
      const st = TASK_STATUS[s];
      return `<div style="margin-bottom:9px">
        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
          <span style="color:${st.fg};font-weight:500">${st.label}</span>
          <span style="font-weight:600">${cnt}</span>
        </div>
        <div style="background:var(--b);border-radius:4px;height:7px;overflow:hidden">
          <div style="width:${pct}%;height:100%;background:${st.fg};border-radius:4px"></div>
        </div>
      </div>`;
    }).join('') + `<div style="margin-top:10px;padding-top:9px;border-top:1px solid var(--b);font-size:12px;display:flex;justify-content:space-between"><span style="color:var(--m)">Total tasks</span><span style="font-weight:600">${allVisible.length}</span></div>`;
  }

  // Upcoming deadlines
  const deadlinesEl = document.getElementById('planner-deadlines');
  if (deadlinesEl) {
    const upcoming = TASKS
      .filter(t => t.status !== 'done' && t.date >= today && (!teamF || t.assignee === teamF))
      .sort((a,b) => a.date.localeCompare(b.date))
      .slice(0,5);
    deadlinesEl.innerHTML = upcoming.length === 0
      ? '<div style="font-size:12.5px;color:var(--m);text-align:center;padding:10px">No upcoming deadlines.</div>'
      : upcoming.map(t => `<div style="padding:8px 0;border-bottom:1px solid var(--b);font-size:12px">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:2px">
            <span>${PRIORITY_DOTS[t.priority]}</span>
            <span style="font-weight:600;flex:1">${t.title}</span>
          </div>
          <div style="color:var(--m);font-size:11px">${t.date} · ${t.assignee}</div>
        </div>`).join('');
  }

  // Update today badge
  const badge = document.getElementById('today-date-badge');
  if (badge) {
    const d = new Date(today);
    badge.textContent = d.toLocaleDateString('en',{weekday:'long',month:'long',day:'numeric'});
  }
  // Sync grid view if active
  if (plannerViewMode === 'grid') renderPlannerGrid();
}

function plannerSelectDay(ds) {
  const teamF = document.getElementById('planner-team-f')?.value || '';
  renderTodayTasks(ds, teamF);
  const badge = document.getElementById('today-date-badge');
  if (badge) {
    const d = new Date(ds + 'T12:00:00');
    badge.textContent = d.toLocaleDateString('en',{weekday:'long',month:'long',day:'numeric'});
  }
}

function renderTodayTasks(ds, teamF) {
  const el = document.getElementById('today-tasks-list');
  if (!el) return;
  const dayTasks = TASKS.filter(t => t.date === ds && (!teamF || t.assignee === teamF))
    .sort((a,b) => {const p={high:0,medium:1,low:2}; return (p[a.priority]||1)-(p[b.priority]||1);});
  if (!dayTasks.length) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--m);font-size:12.5px">No tasks for this day.</div>';
    return;
  }
  el.innerHTML = dayTasks.map(t => {
    const st = TASK_STATUS[t.status] || TASK_STATUS.todo;
    const statusOpts = Object.entries(TASK_STATUS).map(([k,v]) => `<option value="${k}" ${k===t.status?'selected':''}>${v.label}</option>`).join('');
    return `<div style="padding:13px 16px;border-bottom:1px solid var(--b);display:flex;gap:12px;align-items:flex-start">
      <div style="flex:1">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
          <span>${PRIORITY_DOTS[t.priority]}</span>
          <span style="font-size:13px;font-weight:600;${t.status==='done'?'text-decoration:line-through;color:var(--m)':''}">${t.title}</span>
        </div>
        <div style="font-size:11.5px;color:var(--m)">${t.assignee} · ${t.dept}${t.notes?' · '+t.notes.substring(0,50)+(t.notes.length>50?'...':''):''}</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:5px;align-items:flex-end">
        <select onchange="updateTaskStatus('${t.id}',this.value)" style="padding:3px 7px;border:1px solid var(--b);border-radius:6px;font-family:inherit;font-size:11.5px;background:${st.bg};color:${st.fg};font-weight:500">
          ${statusOpts}
        </select>
        <button onclick="deleteTask('${t.id}')" style="background:none;border:none;cursor:pointer;font-size:11px;color:var(--red);padding:0">Delete</button>
      </div>
    </div>`;
  }).join('');
}

function updateTaskStatus(id, status) {
  const t = TASKS.find(x => x.id === id);
  if (t) { t.status = status; persistTasks(); renderPlanner(); }
}

function deleteTask(id) {
  if (!confirm('Delete this task?')) return;
  TASKS = TASKS.filter(t => t.id !== id);
  persistTasks();
  renderPlanner();
}

function openAddTask() {
  const modal = document.getElementById('task-modal');
  if (modal) {
    document.getElementById('tk-date').value = fmtDate(plannerCurrentDate);
    modal.style.display = 'flex';
  }
}

function closeTaskModal() {
  const modal = document.getElementById('task-modal');
  if (modal) modal.style.display = 'none';
}

function saveTask() {
  const title = document.getElementById('tk-title')?.value?.trim();
  if (!title) { alert('Please enter a task title.'); return; }
  const task = {
    id: 'TK-' + Date.now(),
    title,
    assignee: document.getElementById('tk-assignee')?.value || 'Tai Pham',
    date:     document.getElementById('tk-date')?.value || fmtDate(new Date()),
    priority: document.getElementById('tk-priority')?.value || 'medium',
    dept:     document.getElementById('tk-dept')?.value || 'Sales',
    status:   document.getElementById('tk-status')?.value || 'todo',
    notes:    document.getElementById('tk-notes')?.value || '',
  };
  TASKS.push(task);
  persistTasks();
  closeTaskModal();
  document.getElementById('tk-title').value = '';
  document.getElementById('tk-notes').value = '';
  renderPlanner();
}

