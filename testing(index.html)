  const pricingHtml = `<table style="width:100%;border-collapse:collapse;font-size:11.5px;margin-top:6px">
    <thead><tr style="background:var(--bg)">
      <th style="padding:6px 10px;text-align:left;font-size:10px;font-weight:600;color:var(--m);text-transform:uppercase;border-bottom:1px solid var(--b)">Pax</th>
      <th style="padding:6px 10px;text-align:right;font-size:10px;font-weight:600;color:var(--m);text-transform:uppercase;border-bottom:1px solid var(--b)">Peak (Oct–Mar)</th>
      <th style="padding:6px 10px;text-align:right;font-size:10px;font-weight:600;color:var(--m);text-transform:uppercase;border-bottom:1px solid var(--b)">Off-Season (Apr–Sep)</th>
    </tr></thead>
    <tbody>${p.pricing.map(r => `<tr style="${r.pax===4?'background:var(--gl);font-weight:700':''}">
      <td style="padding:6px 10px;border-bottom:1px solid var(--b)">${r.pax} pax${r.pax===4?' ⭐':''}</td>
      <td style="padding:6px 10px;text-align:right;border-bottom:1px solid var(--b);color:var(--g)">$${r.peak.toLocaleString()}/pp</td>
      <td style="padding:6px 10px;text-align:right;border-bottom:1px solid var(--b)">$${r.off.toLocaleString()}/pp</td>
    </tr>`).join('')}</tbody>
  </table>`;

  const _heroBg = getDayPhotos(p.days[0].title, p.tag, p.days[0].hotel, 0, 1)[0];
  document.getElementById('pkg-preview-body').innerHTML = `
    <!-- Hero Banner -->
    <div style="border-radius:10px;overflow:hidden;margin-bottom:18px;position:relative;height:190px">
      <img src="${_heroBg}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy" onerror="this.style.background='linear-gradient(135deg,#2E7D52,#1a5c38)';this.style.display='none'">
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0.04) 30%,rgba(0,0,0,0.70))"></div>
      <div style="position:absolute;bottom:0;left:0;right:0;padding:16px 18px">
        <div style="color:rgba(255,255,255,0.78);font-size:9.5px;font-weight:600;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:5px">${p.subtitle}</div>
        <div style="color:#fff;font-size:18px;font-weight:700;font-family:'DM Serif Display',Georgia,serif;line-height:1.2">${p.name}</div>
        <div style="color:rgba(255,255,255,0.75);font-size:11px;margin-top:5px">📍 ${p.route} &nbsp;·&nbsp; ${p.format}</div>
      </div>
    </div>

    <!-- Header -->
    <div style="border-bottom:1px solid var(--b);padding-bottom:14px;margin-bottom:16px">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px">
        <div>
          <span style="background:${tbg};color:${tfg};font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;margin-bottom:6px;display:inline-block">${p.badge}</span>
          <div style="font-size:15px;font-weight:700;color:var(--g);line-height:1.3">${p.name}</div>
          <div style="font-size:11.5px;color:var(--m);margin-top:2px">${p.subtitle}</div>
        </div>
      </div>
      <div style="font-size:11.5px;color:var(--t);font-style:italic;background:var(--gl);border-left:3px solid var(--g);padding:8px 12px;border-radius:0 6px 6px 0;margin-bottom:10px;line-height:1.5">${p.tagline}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:11.5px">
        <div><span style="color:var(--m)">📍 Route:</span> <b>${p.route}</b></div>
        <div><span style="color:var(--m)">⏱ Format:</span> <b>${p.format}</b></div>
        <div style="grid-column:1/-1"><span style="color:var(--m)">🏨 Hotels:</span> ${p.hotels}</div>
        ${p.flights.map(f=>`<div style="grid-column:1/-1;color:var(--pur);font-weight:500">✈ ${f}</div>`).join('')}
      </div>
    </div>

    <!-- Day by Day -->
    <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--m);margin-bottom:12px">📅 Detailed Programme</div>
    ${daysHtml}

    <!-- Inclusions -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px;margin-bottom:18px">
      <div style="background:var(--gl);border-radius:8px;padding:12px">
        <div style="font-size:10px;font-weight:700;color:var(--g);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">✓ Included</div>
        ${p.incl.map(i=>`<div style="font-size:11px;color:var(--t);margin-bottom:4px;padding-left:4px">• ${i}</div>`).join('')}
      </div>
      <div style="background:#FFF5F5;border-radius:8px;padding:12px">
        <div style="font-size:10px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">✗ Excluded</div>
        ${p.excl.map(i=>`<div style="font-size:11px;color:var(--t);margin-bottom:4px;padding-left:4px">• ${i}</div>`).join('')}
      </div>
    </div>

    <!-- Pricing -->
    <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--m);margin-bottom:8px">💵 Sample Quotation — Premium Boutique 4★</div>
    ${pricingHtml}
    <div style="font-size:10.5px;color:var(--m);margin-top:8px">Peak season (Oct–Mar) +20% · Off-season (Apr–Sep) −10% · Group discount: 3–5 pax = 15% off · 6–10 pax = 25% off</div>

    <!-- Use This Package button -->
    <div style="margin-top:16px;text-align:center">
      <button onclick="usePackageAsBase('${p.id}')" class="btn btn-p" style="width:100%;justify-content:center;padding:10px">
        ✓ Use This Package — Save to Pipeline
      </button>
    </div>
  `;
  document.getElementById('right-pkg-panel').style.display = 'block';
}

function usePackageAsBase(pkgId) {
  const p = TOUR_PACKAGES.find(x => x.id === pkgId);
  if (!p) return;
  const custSel = document.getElementById('d-cust');
  const custName = custSel?.value ? custSel.options[custSel.selectedIndex].text.split(' (')[0] : 'New Client';
  const custId = custSel?.value || '';
  const pax = parseInt(document.getElementById('d-pax')?.value) || 4;
  const month = document.getElementById('d-month')?.value || 'Oct';

  // Find peak pricing for pax
  const pr = p.pricing.find(r=>r.pax===pax) || p.pricing.find(r=>r.pax===4) || {peak:0};
  const newLead = {
    id:'LD-'+Date.now(),
    custId, tour: p.name,
    pax, value: pr.peak * pax,
    month: month + ' 2026', stage:'Designing', owner:'Tai',
    notes: 'Package: ' + p.id + ' · ' + p.route
  };
  LEADS.push(newLead);
  persist();
  alert(`✓ Saved to Sales Pipeline!\n\nPackage: ${p.name}\nClient: ${custName}\nPax: ${pax} · Travel: ${month} 2026\nEst. Value: $${(pr.peak*pax).toLocaleString()}\nStage: Designing`);
}

function renderLibrary() {
  const rf = document.getElementById('lib-rf')?.value||'';
  const df = document.getElementById('lib-df')?.value||'';
  const cf = document.getElementById('lib-cf')?.value||'';
  const q  = (document.getElementById('lib-q')?.value||'').toLowerCase().trim();

  const filtered = PRODUCTS.filter(p => {
    if (p.status !== 'active') return false;
    if (rf && p.r !== rf) return false;
    if (df && p.d !== df) return false;
    if (cf && (p.cat||'').toLowerCase() !== cf) return false;
    if (q) {
      const hay = ((p.n||'') + ' ' + (p.dest||'') + ' ' + (p.cat||'') + ' ' + (p.desc||'')).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });

  const countEl = document.getElementById('lib-count');
  if (countEl) countEl.textContent = filtered.length + ' experience' + (filtered.length !== 1 ? 's' : '') + ' found';

  const list = document.getElementById('lib-list');
  if (!list) return;

  if (filtered.length === 0) {
    list.innerHTML = '<div style="color:var(--m);text-align:center;padding:24px;font-size:12.5px">No experiences found. Try adjusting the filters.</div>';
    return;
  }

  list.innerHTML = filtered.map(p => {
    const isSel = selProds.find(s => s.id === p.id);
    const [rbg, rfg] = REG_COLORS[p.r] || ['#f0f0ee','#666'];
    const catLabel = p.cat ? p.cat.charAt(0).toUpperCase() + p.cat.slice(1) : '';
    const destLabel = p.dest ? ` · ${p.dest}` : '';
    const shortDesc = (p.desc || '').replace(/\*\*/g, '').substring(0, 110) + ((p.desc||'').length > 110 ? '…' : '');

    return `<div class="prd-pick ${isSel ? 'sel' : ''}" onclick="toggleProd('${p.id}')" style="${isSel ? 'background:var(--gl);border-color:var(--g)' : ''}">
      <div class="prd-icon" style="${isSel ? 'background:var(--g)' : ''}">${isSel ? '✓' : '+'}</div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:5px;margin-bottom:3px;flex-wrap:wrap">
          <span style="background:${rbg};color:${rfg};padding:1px 7px;border-radius:4px;font-size:10px;font-weight:700;white-space:nowrap">${p.dl || 'Experience'}</span>
          ${catLabel ? `<span style="background:#F0F0EE;color:#555;padding:1px 6px;border-radius:4px;font-size:10px;font-weight:500">${catLabel}</span>` : ''}
          <span style="font-size:12.5px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:240px" title="${p.n}">${p.n}</span>
        </div>
        ${p.dest ? `<div style="font-size:10.5px;color:var(--g);font-weight:500;margin-bottom:2px">📍 ${p.dest}</div>` : ''}
        <div style="font-size:11.5px;color:var(--m);line-height:1.45;margin-bottom:3px">${shortDesc}</div>
        <div style="font-size:11.5px;color:var(--g);font-weight:600">${getLibPrice(p.id)}</div>
      </div>
    </div>`;
  }).join('');
}

function toggleProd(id) {
  const p = PRODUCTS.find(x=>x.id===id);
  if (!p) return;
  selProds = selProds.find(s=>s.id===id) ? selProds.filter(s=>s.id!==id) : [...selProds, p];
  renderLibrary();
  renderSelected();
}

function renderSelected() {
  const totalD = selProds.reduce((s,p)=>s+parseFloat(p.d),0);
  const pax = parseInt(document.getElementById('d-pax')?.value)||2;
  const pn  = Math.min(Math.max(pax,1),10);

  document.getElementById('sel-count').textContent = '('+selProds.length+')';
  document.getElementById('sel-days').textContent = totalD;

  // Real totals from TAA_TOURS per pax count
  const totalSell = selProds.reduce((s,p)=>{
    const t = TAA_TOURS.find(x=>x.id===p.id);
    return s + (t ? (t['p'+pn]||0) : (p.cost||0));
  }, 0);
  const totalCost = selProds.reduce((s,p)=>{
    const t = TAA_TOURS.find(x=>x.id===p.id);
    return s + (t ? (t['c'+pn]||0) : Math.round((p.cost||0)*0.72));
  }, 0);

  const list = document.getElementById('sel-list');
  if (!list) return;

  if (!selProds.length) {
    list.innerHTML = `<div style="color:var(--m);text-align:center;padding:24px 16px;font-size:12.5px;border:1.5px dashed var(--b);border-radius:8px">
      <div style="font-size:22px;margin-bottom:8px">🗺</div>
      Click experiences on the left to build your tailor-made tour.<br>
      <span style="font-size:11px">A day-by-day draft itinerary will appear here automatically.</span>
    </div>`;
    document.getElementById('qp-card').style.display='none';
    return;
  }

  // ── Real travel date logic ──────────────────────────────
  const travelDateRaw = document.getElementById('d-travel-date')?.value || '';
  const MONTH_MAP = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  let travelStart = null;
  if (travelDateRaw) {
    const ts = new Date(travelDateRaw + 'T00:00:00');
    if (!isNaN(ts.getTime())) travelStart = ts;
  }
  // Fallback: use Travel Month (1st of that month in the next upcoming year)
  if (!travelStart) {
    const selMonth = document.getElementById('d-month')?.value || '';
    if (selMonth && MONTH_MAP[selMonth] !== undefined) {
      const now = new Date();
      let yr = now.getFullYear();
      const mIdx = MONTH_MAP[selMonth];
      if (mIdx < now.getMonth()) yr++; // month already passed this year → next year
      travelStart = new Date(yr, mIdx, 1);
      travelStart._isEstimate = true; // flag: not exact
    }
  }
  const DOW    = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  function dayDateLabel(dayN) {
    if (!travelStart) return `Day ${dayN}`;
    const d = new Date(travelStart);
    d.setDate(d.getDate() + dayN - 1);
    const est = travelStart._isEstimate ? ' <span style="font-size:9px;opacity:.7">(est.)</span>' : '';
    return `Day ${dayN} &mdash; ${DOW[d.getDay()]}, ${d.getDate()} ${MONTHS[d.getMonth()]} ${d.getFullYear()}${est}`;
  }

  // ── Build day groups ─────────────────────────────────────
  let days = [];
  let dayNum = 1;
  let halfDayBuffer = null;
  selProds.forEach(p => {
    const dur = parseFloat(p.d) || 0.5;
    if (dur >= 2) {
      if (halfDayBuffer) {
        days.push({ n: dayNum++, items: [halfDayBuffer], label: halfDayBuffer.dest || '' });
        halfDayBuffer = null;
      }
      for (let i = 0; i < dur; i++) {
        days.push({ n: dayNum++, items: [p], multiDay: true, dayOf: i+1, totalDays: dur, label: p.dest||'' });
      }
    } else if (dur === 0.5) {
      if (halfDayBuffer) {
        days.push({ n: dayNum++, items: [halfDayBuffer, p], label: halfDayBuffer.dest || p.dest || '' });
        halfDayBuffer = null;
      } else {
        halfDayBuffer = p;
      }
    } else {
      if (halfDayBuffer) {
        days.push({ n: dayNum++, items: [halfDayBuffer], label: halfDayBuffer.dest || '' });
        halfDayBuffer = null;
      }
      days.push({ n: dayNum++, items: [p], label: p.dest || '' });
    }
  });
  if (halfDayBuffer) days.push({ n: dayNum++, items: [halfDayBuffer], label: halfDayBuffer.dest || '' });

  // ── Draft itinerary HTML ─────────────────────────────────
  const draftHtml = days.map(day => {
    const itemsHtml = day.items.map(item => {
      const shortDesc = (item.desc||'').replace(/\*\*/g,'').substring(0,130) + ((item.desc||'').length>130?'…':'');
      const [rbg,rfg] = REG_COLORS[item.r]||['#f0f0ee','#666'];
      const tItem = TAA_TOURS.find(x=>x.id===item.id);
      const itemSell = tItem ? (tItem['p'+pn]||0) : (item.cost||0);
      const itemCost = tItem ? (tItem['c'+pn]||0) : Math.round((item.cost||0)*0.72);
      const itemMk   = (itemSell>0 && itemCost>0) ? Math.round((itemSell-itemCost)/itemSell*100) : 0;
      const mkColor  = itemMk>=30?'#2E7D52':(itemMk>=20?'#D97706':'#C0392B');
      return `<div style="margin-bottom:6px">
        <div style="display:flex;align-items:center;gap:5px;margin-bottom:3px;flex-wrap:wrap">
          <span style="background:${rbg};color:${rfg};font-size:9.5px;font-weight:700;padding:1px 6px;border-radius:3px">${item.dl||'Experience'}</span>
          <span style="font-size:12px;font-weight:700;color:var(--t)">${item.n}</span>
        </div>
        ${item.dest?`<div style="font-size:10.5px;color:var(--g);font-weight:500;margin-bottom:3px">📍 ${item.dest}</div>`:''}
        <div style="font-size:11px;color:var(--m);line-height:1.5">${shortDesc}</div>
        ${itemSell>0?`<div style="font-size:10.5px;font-weight:600;margin-top:3px;display:flex;gap:10px;flex-wrap:wrap">
          <span style="color:var(--g)">$${itemSell}/pax</span>
          <span style="color:#9CA3AF">Cost: $${itemCost}/pax</span>
          <span style="color:${mkColor}">Markup: ${itemMk}%</span>
        </div>`:''}
      </div>`;
    }).join('<div style="height:6px;border-top:1px dashed var(--b);margin:8px 0"></div>');

    const dayLabelHtml = day.multiDay
      ? `${dayDateLabel(day.n)} <span style="font-size:9.5px;color:rgba(255,255,255,0.75)">(${day.dayOf}/${day.totalDays})</span>`
      : dayDateLabel(day.n);

    const _ep  = getExpPhoto(day.items[0], day.n);
    const _eph = day.items.length > 1 ? 190 : 125;
    return `<div style="border-left:3px solid var(--g);padding-left:12px;margin-bottom:16px">
      <div style="background:var(--g);color:#fff;font-size:9.5px;font-weight:700;padding:3px 9px;border-radius:5px;display:inline-block;margin-bottom:7px;max-width:100%;box-sizing:border-box">${dayLabelHtml}</div>
      <div style="display:grid;grid-template-columns:1fr 118px;gap:9px;align-items:start">
        <div>${itemsHtml}</div>
        <div style="border-radius:7px;overflow:hidden;flex-shrink:0">
          <img src="${_ep}" alt="Experience photo" style="width:100%;height:${_eph}px;object-fit:cover;display:block" loading="lazy" onerror="this.parentElement.style.display='none'">
        </div>
      </div>
    </div>`;
  }).join('');

  // ── Quick pricing using real TAA_TOURS prices ────────────
  const qpRows = [1,2,3,4,5,6,8,10].map(np => {
    const npn = Math.min(np, 10);
    const sell = selProds.reduce((s,p)=>{
      const t = TAA_TOURS.find(x=>x.id===p.id);
      return s + (t ? (t['p'+npn]||0) : (p.cost||0));
    }, 0);
    const isCur = np === pax;
    return `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--b);font-size:12px;${isCur?'color:var(--g);font-weight:700':''}">
      <span>${np} pax${isCur?' ★':''}</span>
      <span>$${fmt(sell)}/pax</span>
      <span style="font-weight:600">$${fmt(sell*np)}</span>
    </div>`;
  }).join('');
  const margin = totalSell>0 ? Math.round((totalSell-totalCost)/totalSell*100) : 0;
  const qpFooter = `<div style="font-size:10.5px;color:var(--m);margin-top:6px">Net: $${fmt(totalCost)}/pax &nbsp;·&nbsp; Sell: $${fmt(totalSell)}/pax &nbsp;·&nbsp; Margin: ${margin}% &nbsp;·&nbsp; ${pax} pax tour total: $${fmt(totalSell*pax)}</div>`;

  // ── Start date header for itinerary section ──────────────
  const itiTitle = travelStart
    ? `📅 Draft Itinerary — from ${DOW[travelStart.getDay()]}, ${travelStart.getDate()} ${MONTHS[travelStart.getMonth()]} ${travelStart.getFullYear()}`
    : '📅 Draft Itinerary — Auto-Generated';

  // ── Render into right panel ──────────────────────────────
  list.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:10px;background:var(--gl);border-radius:8px;margin-bottom:12px;text-align:center">
      <div><div style="font-size:10px;color:var(--gd);text-transform:uppercase;letter-spacing:.5px">Experiences</div><div style="font-size:18px;font-weight:700;color:var(--g)">${selProds.length}</div></div>
      <div><div style="font-size:10px;color:var(--gd);text-transform:uppercase;letter-spacing:.5px">Total Days</div><div style="font-size:18px;font-weight:700;color:var(--g)">${totalD}D</div></div>
      <div><div style="font-size:10px;color:var(--gd);text-transform:uppercase;letter-spacing:.5px">Sell (${pax} pax)</div><div style="font-size:18px;font-weight:700;color:var(--g)">$${fmt(totalSell)}<span style="font-size:10px;font-weight:500">/pax</span></div></div>
    </div>

    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--m);margin-bottom:6px">Selected Experiences</div>
    ${selProds.map((p,i)=>`
      <div style="display:flex;align-items:center;gap:7px;padding:7px 9px;background:var(--bg);border-radius:7px;margin-bottom:5px">
        <div style="width:20px;height:20px;background:var(--g);color:#fff;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0">${i+1}</div>
        <div style="flex:1;min-width:0">
          <div style="font-size:11.5px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${p.n}</div>
          <div style="font-size:10.5px;color:var(--m)">${p.dl}${p.dest?' · '+p.dest:''}</div>
        </div>
        <button onclick="toggleProd('${p.id}')" style="background:var(--red-l);color:var(--red);border:none;border-radius:4px;padding:2px 7px;cursor:pointer;font-size:12px;flex-shrink:0">×</button>
      </div>`).join('')}

