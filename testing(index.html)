function saveRateOverrides() {
  const vnd = parseFloat(document.getElementById('fx-input-vnd').value);
  const aud = parseFloat(document.getElementById('fx-input-aud').value);
  const eur = parseFloat(document.getElementById('fx-input-eur').value);
  if (!vnd || !aud || !eur || vnd < 1000 || aud <= 0 || eur <= 0) {
    alert('Please enter valid rates. VND should be ~20,000–35,000. AUD and EUR should be between 0.5–3.');
    return;
  }
  const today = new Date().toISOString().split('T')[0];
  localStorage.setItem('ant_fx_overrides', JSON.stringify({ USD:1, VND:vnd, AUD:aud, EUR:eur, updatedDate: today }));
  closeEditRatesModal();
  renderFXPill();
  filterPriceList(); // re-render price table with new rates
  alert('✅ Exchange rates updated and saved.');
}

// Renders the rate pill text and staleness warning on the Pricing page
function renderFXPill() {
  const rates   = getFXRates();
  const updated = getFXUpdatedDate();
  const pillText = document.getElementById('fx-pill-text');
  const pillDate = document.getElementById('fx-pill-date');
  const staleDiv = document.getElementById('fx-stale-warning');
  const staleDaysEl = document.getElementById('fx-stale-days');
  if (!pillText) return;

  pillText.textContent = 'USD/VND ' + Number(rates.VND).toLocaleString() + ' · USD/AUD ' + rates.AUD + ' · USD/EUR ' + rates.EUR;

  // Format the update date nicely
  const updDate = new Date(updated + 'T00:00:00');
  const opts = { day:'numeric', month:'short', year:'numeric' };
  pillDate.textContent = '· Updated ' + updDate.toLocaleDateString('en-GB', opts);

  // Staleness check — warn if >30 days old
  const today = new Date();
  const diffDays = Math.floor((today - updDate) / 86400000);
  if (staleDiv && staleDaysEl) {
    if (diffDays > 30) {
      staleDaysEl.textContent = diffDays;
      staleDiv.style.display = 'block';
    } else {
      staleDiv.style.display = 'none';
    }
  }
}
