function saveEditCustomer(id) {
  const idx = CUSTOMERS.findIndex(x => x.id === id);
  if (idx < 0) return;
  const name = document.getElementById('nc-name')?.value?.trim();
  const email = document.getElementById('nc-email')?.value?.trim();
  if (!name)  { alert('Please enter the customer name.'); return; }
  if (!email) { alert('Please enter the email address.'); return; }

  const numCh = parseInt(document.getElementById('nc-num-children')?.value || 0);
  // Preserve immutable fields from existing record
  const existing = CUSTOMERS[idx];
  CUSTOMERS[idx] = {
    ...existing,
    name, email,
