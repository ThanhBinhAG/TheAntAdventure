let currentLibTab = 'pkg';

function setLibTab(tab) {
  currentLibTab = tab;
  const pkgPanel = document.getElementById('lib-pkg-panel');
  const expPanel = document.getElementById('lib-exp-panel');
  const tabPkg   = document.getElementById('lib-tab-pkg');
  const tabExp   = document.getElementById('lib-tab-exp');
  const rightSel = document.getElementById('right-sel-panel');
  const rightPkg = document.getElementById('right-pkg-panel');

  if (tab === 'pkg') {
    pkgPanel.style.display = 'block';
    expPanel.style.display = 'none';
    tabPkg.style.borderBottomColor = 'var(--g)';
    tabPkg.style.color = 'var(--g)';
    tabExp.style.borderBottomColor = 'transparent';
    tabExp.style.color = 'var(--m)';
    rightSel.style.display = 'none';
    rightPkg.style.display = 'block';
    renderPkgList();
  } else {
    pkgPanel.style.display = 'none';
    expPanel.style.display = 'block';
    tabPkg.style.borderBottomColor = 'transparent';
    tabPkg.style.color = 'var(--m)';
    tabExp.style.borderBottomColor = 'var(--g)';
    tabExp.style.color = 'var(--g)';
    rightSel.style.display = 'block';
    rightPkg.style.display = 'none';
    renderLibrary();
  }
}

function renderPkgList() {
