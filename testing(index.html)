function renderGallery() {
  const q  = (document.getElementById('gallery-search')?.value || '').toLowerCase();
  const r  = document.getElementById('gf-region')?.value    || '';
  const tt = document.getElementById('gf-tourtype')?.value  || '';
  const se = document.getElementById('gf-season')?.value    || '';
  const ot = document.getElementById('gf-other')?.value     || '';

  const filtered = PHOTOS.filter(p => {
    if (galleryRegionTab !== 'all' && p.region !== galleryRegionTab) return false;
    // Text search: title (caption)
    if (q && !p.caption.toLowerCase().includes(q)) return false;
    // Taxonomy AND filters
    const tags = Array.isArray(p.tags) ? p.tags : [];
    if (r  && !tags.includes(r))  return false;
    if (tt && !tags.includes(tt)) return false;
    if (se && !tags.includes(se)) return false;
    if (ot && !tags.includes(ot)) return false;
    return true;
  });

  const grid = document.getElementById('gallery-grid');
  if (!grid) return;
  if (!filtered.length) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px 16px;color:var(--m)">
      <div style="font-size:13px;margin-bottom:10px">No photos match your current filters. Try adjusting them.</div>
      <button class="btn btn-s btn-sm" onclick="clearGalleryFilters()">Clear Filters</button>
    </div>`;
    return;
  }
  const regionColors = { north: '#2E7D52', central: '#856404', south: '#1565C0', people: '#6B21A8' };
  grid.innerHTML = filtered.map(p => {
    const col = regionColors[p.region] || '#2E7D52';
    const bgStyle = p.url
      ? `background:url(${p.url}) center/cover no-repeat`
      : `background:linear-gradient(135deg,${col}dd,${col}88)`;
    // Prompt #7: tag pills — up to 3 + "+X more"
    const tags = Array.isArray(p.tags) ? p.tags : [];
    const visibleTags = tags.slice(0, 3);
    const extraCount  = tags.length - 3;
    const tagPills = visibleTags.map(t =>
      `<span style="background:var(--gl);color:var(--gd);border-radius:12px;font-size:10px;padding:2px 8px">${t}</span>`
    ).join('');
    const morePill = extraCount > 0
      ? `<span style="background:#F0F0EE;color:var(--m);border-radius:12px;font-size:10px;padding:2px 8px">+${extraCount} more</span>`
      : '';
    return `<div style="border-radius:10px;overflow:hidden;border:1px solid var(--b);cursor:pointer;transition:all .15s" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.12)'" onmouseout="this.style.boxShadow='none'">
      <div style="${bgStyle};height:160px;position:relative">
        ${!p.url ? `<div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:rgba(255,255,255,0.9)"><div style="font-size:32px">🏔</div><div style="font-size:11px;margin-top:4px;font-weight:500">No image yet</div></div>` : ''}
        <div style="position:absolute;top:8px;right:8px;background:rgba(0,0,0,0.5);color:#fff;padding:2px 7px;border-radius:8px;font-size:10px;font-weight:600">${p.region.toUpperCase()}</div>
