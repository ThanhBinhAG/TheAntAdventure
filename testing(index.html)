function saveApiKey() {
  const input = document.getElementById('api-key-input');
  const key = input?.value?.trim();
  if (!key) { alert('Please enter your API key.'); return; }
  if (!key.startsWith('sk-')) {
    alert('API key should start with sk-ant-... Please check and try again.');
    return;
  }
  LS.set('ant_api_key', key);
  updateApiKeyStatus();
  if (input) input.value = '';
  alert('✓ API key saved! You can now use the AI export features.');
}

function clearApiKey() {
  if (!confirm('Remove saved API key?')) return;
  LS.set('ant_api_key', '');
  updateApiKeyStatus();
}

function updateApiKeyStatus() {
  const key = LS.get('ant_api_key', '');
  const statusEl = document.getElementById('api-key-status');
  const banner = document.getElementById('api-key-banner');
  if (!statusEl) return;
  if (key && key.startsWith('sk-')) {
    const masked = key.substring(0,10) + '••••••••••••••••••••' + key.slice(-4);
    statusEl.innerHTML = '✅ <b>API key saved:</b> ' + masked + ' — AI export is ready to use.';
    statusEl.style.color = 'var(--g)';
    if (banner) banner.style.borderColor = 'var(--g)';
    if (banner) banner.style.background = 'var(--gl)';
  } else {
    statusEl.innerHTML = '⚠ No API key saved. Enter your key above to enable AI export.';
    statusEl.style.color = 'var(--m)';
    if (banner) { banner.style.borderColor = 'var(--pur)'; banner.style.background = '#F3E8FF'; }
  }
}

