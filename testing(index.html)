// Generate the email using Claude API — same pattern as aiExport()
async function generateFollowUpEmail() {
  const apiKey = LS.get('ant_api_key', '');
  const errEl  = document.getElementById('ai-email-error');
  const loading = document.getElementById('ai-email-loading');
  const output  = document.getElementById('ai-email-output');
  const box     = document.getElementById('ai-email-box');

  if (!apiKey || !apiKey.startsWith('sk-')) {
    errEl.style.display = 'block';
    errEl.innerHTML = '⚡ <b>API key required.</b> Go to Tour Design → Step 4, enter your Anthropic API key and click Save Key, then try again.';
    return;
  }

  const emailType = document.getElementById('ai-email-type').value;
  const tone      = document.getElementById('ai-email-tone').value;
  const lang      = document.getElementById('ai-email-lang').value;
  const context   = document.getElementById('ai-email-context-ta').value;

  const emailTypeLabels = {
    followup:     'a warm follow-up email after the client\'s initial inquiry',
    reminder:     'a gentle quote reminder email (the client has not responded to the quote)',
    deposit:      'a deposit confirmation request email (tour is confirmed, deposit needed to secure dates)',
    posttour:     'a heartfelt post-tour thank you email',
    reengage:     'a re-engagement email for a past client to inspire their next Vietnam trip',
    custom:       'a professional email'
  };
  const toneLabel = tone === 'warm' ? 'warm, personal, and emotionally resonant' : 'professional, concise, and clear';
  const langInstr = lang === 'vietnamese'
    ? 'Write entirely in Vietnamese. Use warm, professional Vietnamese suitable for a luxury brand — không quá trang trọng, không quá thân mật. Sign off as "Đội ngũ The Ant Adventures".'
    : 'Write in English. Sign off as "The Ant Adventures Team | taipham@theantadventures.com | www.theantadventures.com".';

  const systemPrompt = `You are a senior travel consultant for The Ant Adventures, a luxury inbound tour company in Vietnam. Write in an elegant, warm, personalized style. Never be generic. Reference specific tour details, client preferences, and The Ant Adventures brand values. The brand color is forest green (#2E7D52). The brand voice is: boutique, considered, locally rooted, quietly luxurious.`;

  const userPrompt = `Write ${emailTypeLabels[emailType] || 'a professional email'} for the following client. Tone: ${toneLabel}. ${langInstr}

CLIENT & TOUR CONTEXT:
${context}

Structure the email with:
- Subject: line (start with "Subject:")
- A blank line
- Greeting by first name
- Email body (3–5 paragraphs, specific to the client and tour details above)
- Clear next step or call to action
- Sign-off

Do not use generic phrases. Reference the specific tour, destination, or personal detail from the context above.`;

  // Reset UI
  errEl.style.display = 'none';
  output.style.display = 'none';
  box.textContent = '';
  loading.style.display = 'flex';

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1200,
        system: systemPrompt,
        messages: [{ role: 'user', content: userPrompt }]
      })
    });
    const data = await res.json();
    loading.style.display = 'none';
    if (!res.ok) {
      errEl.style.display = 'block';
      errEl.innerHTML = '⚠ API error ' + res.status + ': ' + (data.error?.message || 'Unknown error. Check your API key.');
      return;
    }
    const text = data.content?.filter(b => b.type === 'text').map(b => b.text).join('\n') || 'No response generated.';
    box.textContent = text;
    output.style.display = 'block';
  } catch(e) {
    loading.style.display = 'none';
    errEl.style.display = 'block';
    errEl.innerHTML = '⚠ Network error: ' + e.message + '. Check your internet connection.';
  }
}

