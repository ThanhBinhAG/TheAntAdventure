// SECTION: BACKUP SYSTEM — JSON Export / Import
// All actual localStorage keys used in this CRM (v43)
// BACKEND NEEDED: none — fully frontend, uses Blob + FileReader APIs
// ══════════════════════════════════════════════════════════════════

const BACKUP_KEYS = [
  'ant_custs_v3', 'ant_leads_v3', 'ant_bookings_v2', 'ant_agents_v3',
  'ant_guides_v3', 'ant_feedback_v1', 'ant_staff_v3', 'ant_tasks_v3',
  'ant_chat_v3', 'ant_contracts_v1', 'ant_photos_v3', 'ant_prods_v3',
  'ant_special_sup_v3', 'ant_ext_sup_v1', 'ant_comms_v3', 'ant_cal_v3',
  'ant_devnotes_v3', 'ant_weather_v3', 'ant_about_v3', 'ant_ai_reqs',
  'ant_api_key', 'ant_lang', 'ant_chat_name', 'ant_fx_overrides', 'pl_overrides'
];

function exportAllData() {
  const data = {};
  BACKUP_KEYS.forEach(k => {
    const v = localStorage.getItem(k);
    if (v !== null) {
      try { data[k] = JSON.parse(v); } catch { data[k] = v; }
    }
  });

  const now = new Date();
  const pad = n => String(n).padStart(2, '0');
  const dateStr = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}`;
  const filename = `AntCRM_Backup_${dateStr}.json`;

  const payload = {
    exportedAt: now.toISOString(),
    version: '4.3',
    keysExported: Object.keys(data).length,
    data
  };

  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1000);

  // Save timestamp and update label
  localStorage.setItem('LAST_EXPORT_TIME', now.toISOString());
  updateLastBackupLabel(now.toISOString());

  _sbfToast(`✓ Backup downloaded: ${filename}`, 'success');
}

function importAllData() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.style.display = 'none';
  document.body.appendChild(input);

  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) { input.remove(); return; }

    const reader = new FileReader();
    reader.onload = evt => {
      let parsed;
      try { parsed = JSON.parse(evt.target.result); } catch {
        _sbfToast('✗ Invalid file — not a valid JSON backup.', 'error');
        input.remove();
        return;
      }

      if (!parsed.data || typeof parsed.data !== 'object') {
        _sbfToast('✗ Invalid backup — missing data section.', 'error');
        input.remove();
        return;
      }

      const keyCount = Object.keys(parsed.data).length;
      const exportDate = parsed.exportedAt
        ? new Date(parsed.exportedAt).toLocaleString()
        : 'unknown date';

      const confirmed = confirm(
        `⚠️ RESTORE BACKUP\n\n` +
        `Backup from: ${exportDate}\n` +
        `Keys to restore: ${keyCount}\n\n` +
        `This will OVERWRITE all current CRM data with the backup.\n` +
        `This cannot be undone.\n\nAre you sure?`
      );

      if (!confirmed) { input.remove(); return; }

      // Write each key back to localStorage
      let restored = 0;
      Object.entries(parsed.data).forEach(([k, v]) => {
        try {
          localStorage.setItem(k, JSON.stringify(v));
          restored++;
        } catch { /* skip oversized keys silently */ }
      });

      input.remove();
      location.reload();
    };

    reader.onerror = () => {
      _sbfToast('✗ Could not read file. Please try again.', 'error');
      input.remove();
    };

    reader.readAsText(file);
  };

  input.click();
}

function updateLastBackupLabel(isoTs) {
  const el = document.getElementById('last-backup-label');
  if (!el) return;
  if (!isoTs) { el.textContent = 'Last backup: never'; return; }
  try {
    const d = new Date(isoTs);
    const pad = n => String(n).padStart(2, '0');
    el.textContent = `Last backup: ${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
  } catch { el.textContent = 'Last backup: unknown'; }
}

