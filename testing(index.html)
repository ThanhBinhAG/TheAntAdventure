let _ctrFilter = 'all';
let _ctrPreviewId = null;

// ── Filter buttons ──────────────────────────────────────────────
function setCtrFilter(f) {
  _ctrFilter = f;
  document.querySelectorAll('.ctr-filter-btn').forEach(b => {
    b.classList.toggle('on', b.dataset.ctrFilter === f);
    b.style.fontWeight = b.dataset.ctrFilter === f ? '700' : '500';
  });
  renderContracts();
}

// ── Status badge helper ─────────────────────────────────────────
function ctrStatusBadge(status) {
  const map = {
    'Draft':  { bg:'#FEF3C7', color:'#92400E', border:'#D97706' },
    'Sent':   { bg:'#DBEAFE', color:'#1e3a8a', border:'#1565C0' },
    'Signed': { bg:'#E8F5EE', color:'#1a5c38', border:'#2E7D52' }
  };
  const s = map[status] || map['Draft'];
  return `<span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:${s.bg};color:${s.color};border:1px solid ${s.border}">${status}</span>`;
}

// ── KPI row ─────────────────────────────────────────────────────
function renderContractKPIs() {
  const total   = CONTRACTS.length;
  const draft   = CONTRACTS.filter(c=>c.status==='Draft').length;
  const sent    = CONTRACTS.filter(c=>c.status==='Sent').length;
  const signed  = CONTRACTS.filter(c=>c.status==='Signed').length;
  const totalVal= CONTRACTS.filter(c=>c.status!=='Draft').reduce((s,c)=>s+Number(c.total),0);
  const pills = [
    { label:'Total Contracts', value:total,  color:'var(--gd)' },
    { label:'Draft',           value:draft,  color:'#D97706'   },
    { label:'Sent to Client',  value:sent,   color:'var(--blue)'},
    { label:'Signed',          value:signed, color:'var(--g)'  },
    { label:'Pipeline Value',  value:'$'+totalVal.toLocaleString(), color:'var(--pur)' }
  ];
  const el = document.getElementById('ctr-kpi-row');
  if (!el) return;
  el.innerHTML = pills.map(p=>`
    <div style="background:#fff;border:1px solid var(--b);border-radius:10px;padding:10px 18px;min-width:110px;text-align:center">
      <div style="font-size:18px;font-weight:700;color:${p.color}">${p.value}</div>
      <div style="font-size:11px;color:var(--m);margin-top:2px">${p.label}</div>
    </div>`).join('');
}

// ── Main render ─────────────────────────────────────────────────
function renderContracts() {
  renderContractKPIs();
  const q = (document.getElementById('ctr-search')?.value||'').toLowerCase();
  let list = CONTRACTS.filter(c => {
    if (_ctrFilter !== 'all' && c.status !== _ctrFilter) return false;
    if (q && !`${c.clientName} ${c.tourName} ${c.id}`.toLowerCase().includes(q)) return false;
    return true;
  });
  const tbody = document.getElementById('ctr-tbody');
  if (!tbody) return;
  if (!list.length) {
    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--m);font-style:italic">No contracts found.</td></tr>`;
    return;
  }
  const fmtDate = d => d ? new Date(d).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) : '—';
  tbody.innerHTML = list.map(c => `
    <tr style="cursor:pointer" onclick="openContractPreview('${c.id}')">
      <td><b style="color:var(--gd)">${c.id}</b></td>
      <td>${c.clientName}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${c.tourName}">${c.tourName}</td>
      <td style="text-align:center">${c.pax}</td>
      <td><b>${c.currency} ${Number(c.total).toLocaleString()}</b></td>
      <td>${fmtDate(c.departureDate)}</td>
      <td>${ctrStatusBadge(c.status)}</td>
      <td>${fmtDate(c.createdAt)}</td>
      <td onclick="event.stopPropagation()">
        <div style="display:flex;gap:5px">
          <button onclick="openContractPreview('${c.id}')" title="Preview" style="padding:4px 9px;font-size:11px;border:1px solid var(--b);border-radius:6px;background:#fff;cursor:pointer">👁 View</button>
          <button onclick="deleteContract('${c.id}')" title="Delete" style="padding:4px 8px;font-size:11px;border:1px solid #fca5a5;border-radius:6px;background:#FEF2F2;color:#b91c1c;cursor:pointer">🗑</button>
        </div>
      </td>
    </tr>`).join('');
}

// ── New Contract Modal ──────────────────────────────────────────
function openNewContractModal() {
  // Populate booking select with confirmed bookings
  const sel = document.getElementById('ctr-booking-select');
  if (sel) {
    const confirmed = BOOKINGS.filter(b => ['Confirmed','On Tour','Completed'].includes(b.status));
    sel.innerHTML = '<option value="">— Select a confirmed booking to auto-fill —</option>'
      + confirmed.map(b=>`<option value="${b.id}">${b.id} — ${b.tour} (${b.pax} pax, ${b.date})</option>`).join('');
  }
  // Clear fields
  ['ctr-client-name','ctr-nationality','ctr-rooms','ctr-tour-name','ctr-duration','ctr-route','ctr-inclusions','ctr-exclusions','ctr-flights','ctr-notes'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });
  ['ctr-pax','ctr-total','ctr-deposit-amt'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });
  ['ctr-dep-date','ctr-ret-date','ctr-balance-date'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });
  const overlay = document.getElementById('ctr-new-overlay');
  if (overlay) { overlay.style.display='flex'; }
}

function closeNewContractModal() {
  const overlay = document.getElementById('ctr-new-overlay');
  if (overlay) overlay.style.display='none';
}

// Auto-fill from selected booking
function autoFillFromBooking() {
  const sel = document.getElementById('ctr-booking-select');
  if (!sel || !sel.value) return;
  const b = BOOKINGS.find(x=>x.id===sel.value);
  if (!b) return;
  // Find linked customer
  const cust = CUSTOMERS.find(c=>c.id===b.custId) || {};
  // Fill fields
  const set = (id, val) => { const el=document.getElementById(id); if(el&&val) el.value=val; };
  set('ctr-client-name', cust.name || b.guest || '');
  set('ctr-nationality', cust.country || '');
  set('ctr-pax', b.pax || '');
  set('ctr-tour-name', b.tour || '');
  set('ctr-dep-date', b.date || '');
  set('ctr-total', b.total || '');
  // Default inclusions
  document.getElementById('ctr-inclusions').value =
    'Accommodation throughout (twin share, daily breakfast).\nPrivate airport transfers and private transport throughout.\nEnglish-speaking local guide per region.\nAll airport, hotel, and service taxes.';
  document.getElementById('ctr-exclusions').value =
    'International airfare to/from Vietnam.\nTravel insurance (strongly recommended).\nPersonal expenses — drinks, laundry, tips, gratuities.\nEntrance tickets to attractions and museums.\nMeals not stated as included.\nOptional activities not in confirmed itinerary.';
  calcDepositAmt();
}

function clearAutoFill() {
  const sel = document.getElementById('ctr-booking-select');
  if (sel) sel.value = '';
}

function calcDepositAmt() {
  const total = parseFloat(document.getElementById('ctr-total')?.value||0);
  const pct   = parseInt(document.getElementById('ctr-deposit-pct')?.value||50);
  const amt   = (total * pct / 100).toFixed(2);
  const el    = document.getElementById('ctr-deposit-amt');
  if (el) el.value = isNaN(amt) ? '' : Number(amt).toLocaleString();
}

// ── Save contract ───────────────────────────────────────────────
function saveContract() {
  const get = id => document.getElementById(id)?.value?.trim()||'';
  const clientName = get('ctr-client-name');
  const tourName   = get('ctr-tour-name');
  if (!clientName || !tourName) { alert('Please fill in at least Client Name and Tour Name.'); return; }
  const total = parseFloat(get('ctr-total').replace(/,/g,'')||0);
  const pct   = parseInt(get('ctr-deposit-pct')||50);
  const newId = 'CTR-' + new Date().getFullYear() + '-' + String(CONTRACTS.length+1).padStart(3,'0');
  const contract = {
    id: newId,
    bookingId: document.getElementById('ctr-booking-select')?.value||'',
    clientName,
    nationality: get('ctr-nationality'),
    pax: parseInt(get('ctr-pax')||1),
    rooms: get('ctr-rooms'),
    tourName,
    duration: get('ctr-duration'),
    departureDate: get('ctr-dep-date'),
    returnDate: get('ctr-ret-date'),
    route: get('ctr-route'),
    inclusions: get('ctr-inclusions'),
    exclusions: get('ctr-exclusions'),
    flights: get('ctr-flights'),
    currency: get('ctr-currency')||'USD',
    total,
    depositPct: pct,
    depositAmt: total * pct / 100,
    balanceDueDate: get('ctr-balance-date'),
    status: 'Draft',
    createdAt: new Date().toISOString().slice(0,10),
    signedAt: null,
    notes: get('ctr-notes')
  };
  CONTRACTS.unshift(contract);
  persistContracts();
  closeNewContractModal();
  renderContracts();
  // Immediately open preview
  setTimeout(()=>openContractPreview(newId), 150);
}

// ── Delete contract ─────────────────────────────────────────────
function deleteContract(id) {
  if (!confirm('Delete this contract? This cannot be undone.')) return;
  CONTRACTS = CONTRACTS.filter(c=>c.id!==id);
  persistContracts();
  renderContracts();
}

// ── Update status from preview modal ───────────────────────────
function updateContractStatus() {
  if (!_ctrPreviewId) return;
  const sel = document.getElementById('ctr-status-select');
  const newStatus = sel?.value;
  const c = CONTRACTS.find(x=>x.id===_ctrPreviewId);
  if (!c || !newStatus) return;
  c.status = newStatus;
  if (newStatus === 'Signed') c.signedAt = new Date().toISOString().slice(0,10);
  persistContracts();
  renderContracts();
  // Update badge in preview header
  const titleEl = document.getElementById('ctr-preview-title');
  if (titleEl) titleEl.textContent = `📄 ${c.id} — ${c.clientName}`;
}

// ── Open contract preview ───────────────────────────────────────
function openContractPreview(id) {
  const c = CONTRACTS.find(x=>x.id===id);
  if (!c) return;
  _ctrPreviewId = id;
  // Set title
  const titleEl = document.getElementById('ctr-preview-title');
  if (titleEl) titleEl.textContent = `📄 ${c.id} — ${c.clientName}`;
  // Set status select
  const sel = document.getElementById('ctr-status-select');
  if (sel) sel.value = c.status;
  // Render body
  document.getElementById('ctr-preview-body').innerHTML = buildContractHTML(c, false);
