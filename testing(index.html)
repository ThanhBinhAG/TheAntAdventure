function setWeatherCell(destId, monthIdx, code) {
  // Highlight selected
  document.querySelectorAll('#weather-popup [onclick^="setWeather"]').forEach(el=>{
    el.style.border='2px solid transparent';
  });
  event.currentTarget.style.border='2px solid var(--g)';
  event.currentTarget.dataset.selected = code;
  // Store temp selection
  window._pendingWeatherCode = code;
}

function saveWeatherCell(destId, monthIdx) {
  const code = window._pendingWeatherCode || (weatherData[destId]?.[monthIdx]) || 'G';
  if (!weatherData[destId]) weatherData[destId] = Array(12).fill('G');
  weatherData[destId][monthIdx] = code;
  // Update temp ranges
  const lo = document.getElementById('temp-lo')?.value;
  const hi = document.getElementById('temp-hi')?.value;
  if (lo && hi && TEMP_RANGES[destId]) {
    TEMP_RANGES[destId][monthIdx] = [parseInt(lo), parseInt(hi)];
  }
  document.getElementById('weather-popup')?.remove();
  saveWeatherData();
  renderWeatherGrid();
}

function saveWeatherData() {
  LS.set('ant_weather_v3', weatherData);
  // Flash save confirmation
  const btn = document.querySelector('[onclick="saveWeatherData()"]');
  if (btn) { btn.textContent='✓ Saved!'; btn.style.background='var(--gd)'; setTimeout(()=>{ btn.textContent='💾 Save Changes'; btn.style.background=''; },1500); }
