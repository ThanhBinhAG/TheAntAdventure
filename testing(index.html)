      document.getElementById('sales-policy-view').style.display   = t.dataset.salesTab === 'policy'   ? 'block' : 'none';
    });
  });

  // ── Weighted forecast bar ─────────────────────────────────────
  const totalPipelineVal  = LEADS.filter(l => l.stage !== 'Lost' && l.stage !== 'Completed').reduce((s, l) => s + (l.value || 0), 0);
  const weightedForecast  = LEADS.filter(l => l.stage !== 'Lost' && l.stage !== 'Completed').reduce((s, l) => {
    const prob = l.probability ?? STAGE_PROB[l.stage] ?? 10;
    return s + ((l.value || 0) * (prob / 100));
  }, 0);
  const confirmedVal = LEADS.filter(l => l.stage === 'Confirmed').reduce((s, l) => s + (l.value || 0), 0);
  const forecastEl = document.getElementById('pipeline-forecast-bar');
  if (forecastEl) forecastEl.innerHTML = `
    <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;padding:10px 14px;background:#fff;border:1px solid var(--b);border-radius:9px;margin-bottom:12px">
      <div style="text-align:center;min-width:90px">
        <div style="font-size:18px;font-weight:700;color:var(--g);font-family:'DM Serif Display',Georgia,serif">$${fmt(Math.round(confirmedVal))}</div>
        <div style="font-size:10.5px;color:var(--m);margin-top:1px">Confirmed</div>
      </div>
      <div style="text-align:center;min-width:110px">
        <div style="font-size:18px;font-weight:700;color:var(--pur);font-family:'DM Serif Display',Georgia,serif">$${fmt(Math.round(weightedForecast))}</div>
        <div style="font-size:10.5px;color:var(--m);margin-top:1px">Weighted Forecast</div>
      </div>
      <div style="text-align:center;min-width:100px">
        <div style="font-size:18px;font-weight:700;color:var(--m);font-family:'DM Serif Display',Georgia,serif">$${fmt(Math.round(totalPipelineVal))}</div>
        <div style="font-size:10.5px;color:var(--m);margin-top:1px">Total Pipeline</div>
      </div>
      <div style="flex:1"></div>
      <span style="font-size:11px;color:var(--m)">Weighted = stage probability × deal value</span>
    </div>`;

  // ── Pipeline board (Kanban) ───────────────────────────────────
  const stages = ['Inquiry','Designing','Quoted','Negotiation','Confirmed','Completed'];
  const board  = document.getElementById('pipeline-board');
  board.innerHTML = stages.map(s => {
    const leads    = LEADS.filter(l => l.stage === s);
    const stageVal = leads.reduce((acc, l) => acc + (l.value || 0), 0);
    return `<div class="pipe-col">
      <div class="pipe-hd">
        <span>${s}</span>${bdg(leads.length, STAGE_COLORS[s] || 'bdg-w')}
        ${stageVal > 0 ? `<span style="font-size:10.5px;color:var(--m);margin-left:4px">$${fmt(Math.round(stageVal))}</span>` : ''}
      </div>
      ${leads.map(l => {
        const c        = CUSTOMERS.find(x => x.id === l.custId);
        const prob     = l.probability ?? STAGE_PROB[s] ?? 10;
        const weighted = Math.round((l.value || 0) * prob / 100);
        const bdr      = s === 'Confirmed' ? 'border-left:3px solid var(--g)' : s === 'Negotiation' ? 'border-left:3px solid var(--amb)' : '';
        return `<div class="pipe-card" style="${bdr}" title="${l.tour} | ${l.pax} pax | ${l.month}" onclick="setCurrentLead('${l.id}')">
          <div class="pname">${c?.name || (l.notes?.split('·')[0]?.trim()) || 'Client'}</div>
