    const el = document.getElementById('ds3-ai-result');
    if (el) el.innerHTML = reply.replace(/\*\*(.*?)\*\*/g,'<b>$1</b>').replace(/\n/g,'<br>');
  } catch(e) {
    const el = document.getElementById('ds3-ai-result');
    if (el) el.textContent = 'Error: ' + e.message;
