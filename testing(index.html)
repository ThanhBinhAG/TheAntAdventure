function buildCatPicker() {
  const picker = document.getElementById('cat-picker');
  if (!picker) return;
  const cats = [
    ...Object.entries(SUP_MASTER_CATS).filter(([,v])=>!v.parent).map(([k,v])=>({key:k,...v})),
    // New cats by parent
    {key:'logistics', emoji:'✈️', label:'Logistics & Immigration', color:'#C0392B', bg:'#FDECEA'},
    {key:'water',     emoji:'🚤', label:'Specialized Water Transport', color:'#0277BD', bg:'#E1F5FE'},
    {key:'adventure', emoji:'🧗', label:'Adventure & Equipment', color:'#1565C0', bg:'#E3F2FD'},
    {key:'experience',emoji:'🎭', label:'High-End Experiences', color:'#856404', bg:'#FFF3CD'},
    {key:'personnel', emoji:'👥', label:'Personnel & Safety', color:'#4a1460', bg:'#F3E5F5'},
    ...CUSTOM_CATS.map(c=>({key:c.id,emoji:c.emoji,label:c.name,color:c.color,bg:c.color+'22'})),
  ];
  // Deduplicate by key
  const seen = new Set();
  const unique = cats.filter(c=>{ if(seen.has(c.key)) return false; seen.add(c.key); return true; });
  picker.innerHTML = unique.map(cat=>`
    <div class="prd-pick" id="cat-pick-${cat.key}" onclick="selectCat('${cat.key}')" style="border-radius:10px">
      <div class="prd-icon" style="background:${cat.bg||'#eee'};color:${cat.color||'#333'};font-size:18px;width:36px;height:36px">${cat.emoji}</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:12.5px;font-weight:600">${cat.label}</div>
      </div>
    </div>
  `).join('');
}

function selectCat(key) {
  document.querySelectorAll('.prd-pick').forEach(p=>p.classList.remove('sel'));
  document.getElementById('cat-pick-'+key)?.classList.add('sel');
  _addSupSelectedCat = key;
  // Show sub-category select if applicable
  const subs = [...(SUP_SUBCATS[key]||[])];
  // Also check custom cats
  const customCat = CUSTOM_CATS.find(c=>c.id===key);
  if(customCat?.subs?.length) subs.push(...customCat.subs);
  const subcatRow = document.getElementById('subcat-row');
  const subcatSel = document.getElementById('add-sup-subcat');
  if (subs.length && subcatRow && subcatSel) {
    subcatSel.innerHTML = subs.map(s=>`<option value="${s}">${s}</option>`).join('');
    subcatRow.style.display='block';
  } else if(subcatRow) {
    subcatRow.style.display='none';
  }
}

function addSupStep(n) {
  if (n===2 && !_addSupSelectedCat) { alert('Please select a category first.'); return; }
  _addSupStep = n;
  [1,2,3,4].forEach(i=>{
    const panel = document.getElementById('add-sup-step-'+i);
    if(panel) panel.style.display = i===n ? 'block':'none';
    const stepEl = document.querySelector(`[data-step="${i}"]`);
    if(stepEl) {
      stepEl.classList.remove('on','done');
      if(i===n) stepEl.classList.add('on');
      else if(i<n) stepEl.classList.add('done');
    }
  });
}

