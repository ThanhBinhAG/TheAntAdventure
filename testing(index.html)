    vat_in:SEED_TAX.reduce((s,t)=>s+t.vat_in,0),
    vat_pay:SEED_TAX.reduce((s,t)=>s+t.vat_pay,0),
    profit_bt:SEED_TAX.reduce((s,t)=>s+t.profit_bt,0),
    corp_tax:SEED_TAX.reduce((s,t)=>s+t.corp_tax,0),
