    const today  = now.toISOString().split('T')[0];
    const pad2   = n => String(n).padStart(2,'0');
    const fmtD   = d => { try { const x=new Date(d); return `${x.getDate()} ${x.toLocaleString('en-GB',{month:'short'})} ${x.getFullYear()}`; } catch { return d; } };
    const fmtUSD = n => `$${Number(n||0).toLocaleString('en-US')}`;

    const lines = [];
    lines.push(`=== LIVE CRM SNAPSHOT — ${now.toLocaleString('en-GB',{weekday:'short',day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})} ===`);

    // Clients
    try { lines.push(`CLIENTS: ${CUSTOMERS.length} clients on file`); } catch {}

    // Pipeline
    try {
      const active = LEADS.filter(l => !['Lost','Completed','Confirmed'].includes(l.stage));
      const pipeVal = active.reduce((s,l) => s+(parseFloat(l.value)||0), 0);
      lines.push(`PIPELINE: ${active.length} active deals · Total value: ${fmtUSD(pipeVal)}`);
    } catch {}

    // Confirmed bookings
    try {
      const confirmed = BOOKINGS.filter(b => ['Confirmed','On Tour','Fully Paid','Deposit Paid'].includes(b.status));
      const confPax   = confirmed.reduce((s,b) => s+(parseInt(b.pax)||0), 0);
      lines.push(`CONFIRMED BOOKINGS: ${confirmed.length} bookings · ${confPax} pax`);
    } catch {}

    // Upcoming departures (next 14 days) — b.start is like "Oct 12"
    try {
      const yr = now.getFullYear();
      const in14 = new Date(now); in14.setDate(in14.getDate()+14);
      const upcoming = BOOKINGS.filter(b => {
        if (!b.start || ['Cancelled','Completed'].includes(b.status)) return false;
        try {
          const d = new Date(b.start + ' ' + yr + ' 12:00');
          return d >= now && d <= in14;
        } catch { return false; }
      }).sort((a,b) => new Date(a.start+' '+yr) - new Date(b.start+' '+yr)).slice(0,5);

      lines.push(`UPCOMING DEPARTURES (next 14 days):`);
      if (upcoming.length === 0) {
        lines.push(`  · None in next 14 days`);
      } else {
        upcoming.forEach(b => {
          const cust = CUSTOMERS.find(c=>c.id===b.custId);
          lines.push(`  · ${cust?.name||b.custId} — ${b.tour||'—'} — ${b.start} — ${b.pax} pax`);
        });
      }
    } catch {}

    // Overdue tasks — TASKS.date is ISO (YYYY-MM-DD), status options: todo/inprogress/review/done
    try {
      const overdue = TASKS.filter(t => t.status !== 'done' && (t.date||'') < today);
      lines.push(`OVERDUE TASKS: ${overdue.length} overdue`);
      overdue.slice(0,3).forEach(t => lines.push(`  · ${t.title} — due ${fmtD(t.date)}`));
    } catch {}

    // Unpaid / balance outstanding bookings
    try {
      const unpaid = BOOKINGS.filter(b => !['Fully Paid','Cancelled','Completed'].includes(b.status));
      const unpaidTotal = unpaid.reduce((s,b) => s+(parseFloat(b.total)||0)-(parseFloat(b.deposit)||0), 0);
      lines.push(`OUTSTANDING BALANCES: ${unpaid.length} bookings · ${fmtUSD(unpaidTotal)} outstanding`);
    } catch {}

    // Top agent this month (by lead count with agentId)
    try {
      const thisMonth = `${yr}-${pad2(now.getMonth()+1)}`;
      const agentCounts = {};
      LEADS.forEach(l => {
        if (l.agentId && l.agentId !== 'AGT-001' && (l.month||'').includes(yr.toString())) {
          agentCounts[l.agentId] = (agentCounts[l.agentId]||0) + 1;
        }
      });
      const topId = Object.keys(agentCounts).sort((a,b)=>agentCounts[b]-agentCounts[a])[0];
      if (topId) {
        const agent = AGENTS.find(a=>a.id===topId);
        lines.push(`TOP AGENT (${yr}): ${agent?.name||topId} — ${agentCounts[topId]} deals`);
      }
    } catch {}

    lines.push(`=== END SNAPSHOT ===`);

    // Cap at 600 words
    const full = lines.join('\n');
    const words = full.split(/\s+/);
    return words.length > 600 ? words.slice(0,600).join(' ') + '\n[snapshot truncated]' : full;

  } catch(e) {
    return `=== LIVE CRM SNAPSHOT — unavailable (${e.message}) ===`;
  }
}

