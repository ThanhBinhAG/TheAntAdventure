// ── PROMPT #4: Supplier Form — Switch Booking Dropdown ───────────────────────
function buildSBFDropdownOptions() {
  const sel = document.getElementById('sbf-booking-dropdown');
  if (!sel) return;
  const qualifying = BOOKINGS.filter(b =>
    b.status === 'Confirmed' || b.status === 'On Tour'
  ).sort((a, b) => {
    const da = parseBookingDate(a.start) ? parseBookingDate(a.start).toISOString() : '';
    const db = parseBookingDate(b.start) ? parseBookingDate(b.start).toISOString() : '';
    return da.localeCompare(db);
  });
  if (qualifying.length === 0) {
    sel.innerHTML = '<option disabled>— No confirmed bookings available —</option>';
    return;
  }
  sel.innerHTML = '<option value="">— Select a booking to auto-fill —</option>' +
    qualifying.map(b => {
      const cust = CUSTOMERS.find(c => c.id === b.custId);
      const label = `${b.id} · ${cust?.name || b.custId || ''} · ${(b.tour || '').slice(0, 28)} · ${b.start}–${b.end}`;
      const selected = b.id === _sbfBookingId ? ' selected' : '';
      return `<option value="${b.id}"${selected}>${label}</option>`;
    }).join('');
}

function sbfSwitchBooking() {
  const sel = document.getElementById('sbf-booking-dropdown');
  const id = sel?.value;
  if (!id) { _sbfToast('Please select a booking first', 'info'); return; }
  if (_sbfBookingId && _sbfBookingId !== id) {
    const b = BOOKINGS.find(x => x.id === _sbfBookingId);
    const confirmed = confirm(
      `Some fields already have values from Booking ${_sbfBookingId}${b ? ' (' + b.tour + ')' : ''}.\n\nOverwrite with selected booking?`
    );
    if (!confirmed) return;
  }
  openSupplierForms(id);
  const bk = BOOKINGS.find(x => x.id === id);
  if (bk) {
    const cust = CUSTOMERS.find(c => c.id === bk.custId);
    _sbfToast(`✓ Forms filled from Booking ${id} — ${cust?.name || bk.custId}`, 'success');
  }
}
