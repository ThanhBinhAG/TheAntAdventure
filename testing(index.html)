          </div>

          <!-- RESTAURANT (multi-entry) -->
          <div id="sbf-panel-restaurant" style="display:none">
            <div id="sbf-restaurant-list"></div>
            <button onclick="addRestaurantEntry()" style="margin-bottom:4px;padding:6px 14px;background:#FDF6E3;color:#856404;border:1px solid #e8d5a3;border-radius:7px;font-size:12px;cursor:pointer;font-family:inherit;font-weight:600">＋ Add Another Restaurant</button>
            <div class="sbf-footer" style="margin-top:14px">
              <div style="font-size:11.5px;color:var(--m)">💡 One block per dining / culinary experience. Auto-filled from your itinerary.</div>
              <button onclick="downloadSBF('restaurant')" class="sbf-dl-btn">📄 Download All Restaurant Forms</button>
            </div>
          </div>

          <!-- FLIGHT -->
          <div id="sbf-panel-flight" style="display:none">
            <div id="sbf-flights-list"></div>
            <button onclick="addFlightEntry()" style="margin-bottom:14px;padding:6px 14px;background:#E8F5EE;color:var(--gd);border:1px solid #b8dfc9;border-radius:7px;font-size:12px;cursor:pointer;font-family:inherit;font-weight:600">＋ Add Another Flight</button>
            <div><label class="sbf-lbl">Passenger Names (for ticketing)</label>
              <textarea id="sbf-f-names" class="sbf-inp" rows="3" placeholder="1. James Miller — Passport: A1234567 — DOB: 15 Mar 1970&#10;2. Sarah Miller — Passport: B9876543 — DOB: 22 Jun 1972"></textarea></div>
            <div class="sbf-footer">
              <div style="font-size:11.5px;color:var(--m)">💡 Confirm baggage allowance and meal preference per flight.</div>
              <button onclick="downloadSBF('flight')" class="sbf-dl-btn">📄 Download Flight Form</button>
            </div>
          </div>

          <!-- SPECIAL PROVIDER -->
          <div id="sbf-panel-special" style="display:none">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div><label class="sbf-lbl">Provider Name</label><input id="sbf-sp-name" class="sbf-inp" placeholder="e.g. Mr. Hoa — Lantern Artisan, Hoi An"></div>
              <div><label class="sbf-lbl">Provider Type</label>
                <select id="sbf-sp-type" class="sbf-inp"><option>Artisan / Craftsperson</option><option>Private Chef</option><option>Coffee / Tea Owner</option><option>Local Market Vendor</option><option>Cultural Performer</option><option>Farmer / Homestead</option><option>Other Local Experience</option></select></div>
              <div><label class="sbf-lbl">Experience / Activity</label><input id="sbf-sp-activity" class="sbf-inp" placeholder="e.g. Hands-on lantern making class"></div>
              <div><label class="sbf-lbl">Location / Address</label><input id="sbf-sp-location" class="sbf-inp" placeholder="e.g. Nguyen Thai Hoc St, Hoi An"></div>
              <div><label class="sbf-lbl">Date</label><input id="sbf-sp-date" type="date" class="sbf-inp"></div>
              <div><label class="sbf-lbl">Start Time</label><input id="sbf-sp-time" type="time" class="sbf-inp" value="10:00"></div>
              <div><label class="sbf-lbl">Duration</label><input id="sbf-sp-duration" class="sbf-inp" placeholder="e.g. 90 minutes"></div>
              <div><label class="sbf-lbl">No. of Guests</label><input id="sbf-sp-pax" type="number" class="sbf-inp"></div>
              <div><label class="sbf-lbl">Guide Language</label>
                <select id="sbf-sp-lang" class="sbf-inp"><option>English</option><option>French</option><option>Spanish</option><option>German</option><option>Chinese (Mandarin)</option><option>Vietnamese</option></select></div>
              <div><label class="sbf-lbl">Guide Name</label><input id="sbf-sp-guide" class="sbf-inp" placeholder="e.g. Lan Tran"></div>
              <div><label class="sbf-lbl">Guide Phone</label><input id="sbf-sp-phone" class="sbf-inp" placeholder="e.g. +84 91 234 5678"></div>
              <div><label class="sbf-lbl">Agreed Fee (USD)</label><input id="sbf-sp-fee" type="number" class="sbf-inp" placeholder="80"></div>
            </div>
            <div style="margin-top:8px"><label class="sbf-lbl">Payment Terms</label>
              <input id="sbf-sp-payment" class="sbf-inp" placeholder="e.g. Cash on day, or bank transfer 3 days prior"></div>
            <div style="margin-top:8px"><label class="sbf-lbl">Additional Notes for Provider</label>
              <textarea id="sbf-sp-notes" class="sbf-inp" rows="2" placeholder="e.g. Group includes 2 children aged 8 and 11. Please prepare child-sized aprons."></textarea></div>
            <div class="sbf-footer">
              <div style="font-size:11.5px;color:var(--m)">💡 Always confirm 48h before. Provider receives this as official booking confirmation.</div>
              <button onclick="downloadSBF('special')" class="sbf-dl-btn">📄 Download Provider Form</button>
            </div>
          </div>

        </div><!-- /scrollable form area -->
      </div><!-- /right panel -->

    </div><!-- /split body -->
  </div><!-- /modal box -->
</div>
