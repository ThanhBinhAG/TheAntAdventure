  document.querySelectorAll('.pl-cost-row').forEach(el => {
    el.style.display = plShowCost ? 'block' : 'none';
  });
}

function editPriceCell(el, num, paxN, isCost) {
  const t = TAA_TOURS.find(x => x.num === num);
  if (!t) return;
  const key = (isCost ? 'c' : 'p') + paxN;
  const ok  = num + '_' + key;
  const cur = priceOverrides[ok] !== undefined ? priceOverrides[ok] : t[key];
  el.onclick = null;
  const inp = document.createElement('input');
  inp.type = 'number'; inp.min = 0; inp.value = cur || 0;
  inp.style.cssText = 'width:62px;font-size:11.5px;padding:2px 4px;border:1.5px solid var(--g);border-radius:5px;text-align:right;font-family:inherit;outline:none;background:#fff';
  el.innerHTML = ''; el.appendChild(inp);
  inp.focus(); inp.select();
  function save() {
    const v = parseFloat(inp.value);
    if (!isNaN(v) && v >= 0) {
      priceOverrides[ok] = v;
      try { localStorage.setItem('pl_overrides', JSON.stringify(priceOverrides)); } catch(e) {}
    }
    filterPriceList();
  }
  inp.addEventListener('blur', save);
  inp.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); save(); }
    if (e.key === 'Escape') filterPriceList();
  });
}

function toggleInclDetail(num) {
