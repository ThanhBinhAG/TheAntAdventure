// ── Render day-by-day itinerary in left panel ────────────────────
function sbfRenderDayList(cinISO, coutISO, itinerary) {
  const list = document.getElementById('sbf-day-list');
  if (!list) return;

  const DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const MON = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  // ── RICH MODE: itinerary data available ──────────────────────
  if (itinerary && itinerary.length) {
    const startDate = cinISO ? new Date(cinISO) : null;
    let html = '';
    itinerary.forEach((dayObj, i) => {
      // Compute real date for this day if we have a start date
      let dateLabel = '', iso = '';
      if (startDate) {
        const d = new Date(startDate);
        d.setDate(d.getDate() + i);
        iso = d.toISOString().slice(0,10);
        dateLabel = `${d.getDate()} ${MON[d.getMonth()]} · ${DOW[d.getDay()]}`;
      }
      const clickAttr = iso ? `onclick="sbfDayClick('${iso}')"` : '';
      const idAttr    = iso ? `id="sbf-day-${iso}"` : '';

      // Activity pills
      const pills = (dayObj.activities||[]).map(a =>
        `<div style="display:flex;align-items:flex-start;gap:4px;margin-bottom:3px">
          <span style="font-size:11px;flex-shrink:0">${_sbfCatIcon(a.cat)}</span>
          <span style="font-size:11px;color:var(--t);line-height:1.4">${a.name}</span>
        </div>`
      ).join('');

      // Hotel line
      const hotelLine = dayObj.hotel
        ? `<div style="font-size:10.5px;color:var(--m);margin-top:4px;margin-bottom:2px">🏨 ${dayObj.hotel}</div>`
        : '';

      html += `<div ${idAttr} ${clickAttr}
        style="background:#fff;border:1px solid #E2E8E4;border-radius:8px;padding:9px 10px;margin-bottom:5px;cursor:${iso?'pointer':'default'};transition:border-color .12s,background .12s"
        ${iso ? `onmouseover="if(!this.dataset.sel)this.style.background='#E8F5EE'"` : ''}
        ${iso ? `onmouseout="if(!this.dataset.sel)this.style.background='#fff'"` : ''}>
        <div style="display:flex;align-items:center;gap:7px;margin-bottom:6px">
          <div style="background:var(--g);color:#fff;border-radius:5px;min-width:26px;height:26px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0">D${dayObj.day}</div>
          <div>
            <div style="font-size:11px;font-weight:700;color:var(--t)">${dayObj.dest}</div>
            ${dateLabel ? `<div style="font-size:10px;color:var(--m)">${dateLabel}</div>` : ''}
          </div>
        </div>
        ${hotelLine}
        <div style="padding-left:2px">${pills}</div>
      </div>`;
    });
    list.innerHTML = html;
    return;
  }

  // ── FALLBACK MODE: date-only cards ───────────────────────────
  if (!cinISO || !coutISO) {
    list.innerHTML = '<div style="font-size:11.5px;color:var(--m);padding:8px 6px;text-align:center">No itinerary data.<br>Dates will appear once<br>the tour design is linked.</div>';
    return;
  }
  const start = new Date(cinISO);
  const end   = new Date(coutISO);
  const totalDays = Math.round((end - start) / 86400000) + 1;
  let html = '';
  for (let i = 0; i < totalDays; i++) {
    const d = new Date(start);
    d.setDate(d.getDate() + i);
    const iso    = d.toISOString().slice(0,10);
    const label  = `${d.getDate()} ${MON[d.getMonth()]}`;
    const dow    = DOW[d.getDay()];
    const isWknd = d.getDay() === 0 || d.getDay() === 6;
    html += `<div id="sbf-day-${iso}" onclick="sbfDayClick('${iso}')"
      style="display:flex;align-items:center;gap:8px;padding:6px 8px;margin-bottom:3px;border-radius:7px;cursor:pointer;border:1px solid ${isWknd?'#e8d5a3':'#E2E8E4'};background:${isWknd?'#FDF6E3':'#fff'};transition:background .12s"
      onmouseover="if(!this.dataset.sel)this.style.background='#E8F5EE'"
      onmouseout="if(!this.dataset.sel)this.style.background='${isWknd?'#FDF6E3':'#fff'}'">
      <div style="background:var(--g);color:#fff;border-radius:5px;min-width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0">D${i+1}</div>
      <div>
        <div style="font-size:12px;font-weight:600;color:var(--t);line-height:1.2">${label}</div>
        <div style="font-size:10.5px;color:var(--m)">${dow}</div>
      </div>
    </div>`;
  }
  list.innerHTML = html;
}

// ── Day-click handler: fill active hotel check-in / check-out ───
function sbfDayClick(isoDate) {
  const allDayEls = document.querySelectorAll('#sbf-day-list [id^="sbf-day-2"]');

  if (_sbfClickPhase === 0) {
    // First click → check-in
    _sbfClickCinDate = isoDate;
    _sbfClickPhase   = 1;
    // Clear all highlights
    allDayEls.forEach(d => { d.removeAttribute('data-sel'); d.style.background = ''; d.style.borderColor = ''; });
    // Highlight this day solid green
    const el = document.getElementById(`sbf-day-${isoDate}`);
    if (el) { el.style.background = '#2E7D52'; el.style.borderColor = 'var(--gd)'; el.dataset.sel = '1'; }
    // Fill check-in, clear check-out
    const cinEl  = document.getElementById(`sbf-hotel-${_sbfActiveHotel}-cin`);
    const coutEl = document.getElementById(`sbf-hotel-${_sbfActiveHotel}-cout`);
    if (cinEl)  { cinEl.value = isoDate; }
    if (coutEl) { coutEl.value = ''; }
    calcHotelCost(_sbfActiveHotel);
    // Update hint text
    const hint = document.querySelector('#sbf-overlay .sbf-day-hint');
    if (hint) hint.innerHTML = `Check-in set ✓ — Now click <b>Check-out</b> →`;

  } else {
    // Second click → check-out
    _sbfClickPhase = 0;
    const [realCin, realCout] = _sbfClickCinDate <= isoDate
      ? [_sbfClickCinDate, isoDate]
      : [isoDate, _sbfClickCinDate];

    // Highlight range
    allDayEls.forEach(d => {
      const dIso = d.id.replace('sbf-day-','');
      d.removeAttribute('data-sel');
      if (dIso === realCin) {
        d.style.background = '#2E7D52'; d.style.borderColor = 'var(--gd)'; d.dataset.sel = '1';
      } else if (dIso > realCin && dIso <= realCout) {
        d.style.background = '#E8F5EE'; d.style.borderColor = '#b8dfc9'; d.dataset.sel = '1';
      } else {
        d.style.background = ''; d.style.borderColor = '';
      }
    });
    // Fill dates on active hotel
    const cinEl  = document.getElementById(`sbf-hotel-${_sbfActiveHotel}-cin`);
    const coutEl = document.getElementById(`sbf-hotel-${_sbfActiveHotel}-cout`);
    if (cinEl)  cinEl.value  = realCin;
    if (coutEl) coutEl.value = realCout;
    calcHotelCost(_sbfActiveHotel);
    _sbfClickCinDate = null;
    // Restore hint
    const hint = document.querySelector('#sbf-overlay .sbf-day-hint');
    if (hint) hint.innerHTML = `1st click = <b>Check-in</b><br>2nd click = <b>Check-out</b>`;
  }
}

// ── ACTIVITIES: auto-create + add-entry ──────────────────────────
// Creates one block per Activity / Cultural / Cycling item in the itinerary.
// Excludes: Transfer, Transport, Flight, Cruise, Culinary (those have own tabs).
const _ACT_CATS = new Set(['Activity','Cultural','Cycling']);

function autoCreateActivityBlocks(itinerary, cinISO, pax) {
  if (!itinerary || !itinerary.length) { addActivityEntry(); return; }
  const startDate = cinISO ? new Date(cinISO) : null;
  let created = 0;
  itinerary.forEach((dayObj, i) => {
    (dayObj.activities || []).forEach(a => {
      if (!_ACT_CATS.has(a.cat)) return;
      addActivityEntry();
      const n = _activityCount;
      const set = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
      set(`sbf-act-${n}-name`, a.name);
      set(`sbf-act-${n}-location`, dayObj.dest ? dayObj.dest.split('→')[0].trim() : '');
      set(`sbf-act-${n}-pax`, pax || '');
      if (startDate) {
        const d = new Date(startDate); d.setDate(d.getDate() + i);
        set(`sbf-act-${n}-date`, d.toISOString().slice(0,10));
      }
      created++;
    });
  });
  if (!created) addActivityEntry();
}

