function fmtPx(usd) {
  if (!usd && usd !== 0) return '—';
  const v = usd * getFXRates()[plCurrency];
  if (plCurrency === 'VND') {
    if (v >= 1000000) return (v/1000000).toFixed(1) + 'M₫';
    return Math.round(v).toLocaleString('vi') + '₫';
  }
  if (plCurrency === 'AUD') return 'A$' + Math.round(v);
  if (plCurrency === 'EUR') return '€' + Math.round(v);
  return '$' + Math.round(v);
}

function getSpUSD(t, n)   { const k = t.num + '_p' + n; return priceOverrides[k] !== undefined ? priceOverrides[k] : t['p' + n]; }
function getCostUSD(t, n) { const k = t.num + '_c' + n; return priceOverrides[k] !== undefined ? priceOverrides[k] : t['c' + n]; }

// Step 3 markup control — default 30%. Changing this recalculates the full pricing table.
let _step3Markup = 30;
// Returns sell price using custom markup when != 30%, otherwise uses library price (incl. manual overrides)
function getAdjustedSell(t, n) {
  if (_step3Markup === 30) return getSpUSD(t, n);
  return Math.round(getCostUSD(t, n) * (1 + _step3Markup / 100));
}
function adjustMarkup(val) {
  _step3Markup = parseFloat(val) || 30;
  const display = document.getElementById('markup-pct-display');
  if (display) display.textContent = _step3Markup + '%';
  renderPricingStep();
}
function mkPct(sp, co)    { return (!sp || !co || sp <= 0) ? 0 : Math.round((sp - co) / sp * 100); }

function setCurrency(c) {
  plCurrency = c;
  ['USD','VND','AUD','EUR'].forEach(x => {
    const b = document.getElementById('curr-' + x.toLowerCase());
    if (!b) return;
    const on = x === c;
    b.style.background = on ? 'var(--g)' : 'none';
    b.style.color      = on ? '#fff' : 'var(--m)';
    b.style.border     = on ? '1.5px solid var(--g)' : '1.5px solid var(--b)';
  });
  const badge = document.getElementById('pl-currency-badge');
  const cntEl = document.getElementById('pl-count');
  if (badge && cntEl) {
    const m = cntEl.textContent.match(/Showing (\d+)/);
    badge.textContent = (m ? m[1] : '193') + ' Products · ' + c;
  }
  filterPriceList();
}

function toggleCostCol() {
