let _bkdCurrentId = null;

function openBookingDetail(bookingId) {
  _bkdCurrentId = bookingId;
  _currentBookingId = bookingId; // AI context tracking
  const b = BOOKINGS.find(x => x.id === bookingId);
  if (!b) return;
  const c   = CUSTOMERS.find(x => x.id === b.custId);
  const bal = b.total - b.deposit;
  const STATUS_COLORS = {'Deposit Paid':'#D97706','Fully Paid':'#2E7D52','Confirmed':'#1565C0','On Tour':'#6B21A8','Completed':'#6B7F74','Cancelled':'#C0392B'};
  const sc = STATUS_COLORS[b.status] || '#6B7F74';

  // Header
  document.getElementById('bkd-title').textContent = b.tour;
  document.getElementById('bkd-sub').textContent   = `${b.id} · ${c?.name||b.custId} · ${b.pax} pax · ${b.start}–${b.end} 2026`;
  document.getElementById('bkd-status-badge').innerHTML = `<span style="background:${sc};color:#fff;border-radius:20px;padding:4px 14px;font-size:12px;font-weight:700">${b.status}</span>`;

  // Finance bar
  document.getElementById('bkd-finance').innerHTML = [
    {label:'Total Value',    value:`$${fmt(b.total)}`,      color:'var(--td)'},
    {label:'Deposit Paid',   value:`$${fmt(b.deposit)}`,    color:'var(--blue)'},
    {label:'Balance Due',    value:`$${fmt(bal)}`,          color: bal>0?'var(--amb)':'var(--g)'},
    {label:'Guide',          value: b.guide||'—',           color:'var(--td)'},
    {label:'Hotel',          value: b.hotel||'—',           color:'var(--td)'},
    {label:'Changes',        value:`${(b.changes||[]).length}`, color:'var(--g)'},
  ].map(f=>`<div style="flex:1;padding:12px 16px;border-right:1px solid #E2E8E4;text-align:center">
    <div style="font-size:10px;text-transform:uppercase;letter-spacing:.7px;color:var(--m);margin-bottom:3px">${f.label}</div>
    <div style="font-weight:700;font-size:14px;color:${f.color}">${f.value}</div>
  </div>`).join('');

  // Guide alert banner if pending
  if (b.guideAlertPending) {
    const alertDiv = document.createElement('div');
    alertDiv.style.cssText = 'background:#FFF3CD;border-left:4px solid #D97706;padding:10px 16px;font-size:12.5px;color:#856404;display:flex;align-items:center;justify-content:space-between';
    alertDiv.innerHTML = `<span>⚠ <b>Guide not yet notified</b> of recent changes — please contact ${b.guide||'the assigned guide'} directly.</span>
      <button onclick="markGuideNotified('${b.id}')" style="background:#D97706;color:#fff;border:none;border-radius:6px;padding:4px 12px;cursor:pointer;font-size:11px;font-family:inherit;font-weight:600">✓ Mark Notified</button>`;
    const body = document.querySelector('#booking-detail-overlay > div > div[style*="padding:22px"]');
    if (body) body.insertAdjacentElement('beforebegin', alertDiv);
  }

  // Render change log
  renderChangeLog(b);

  // Reset tabs to default (add)
  setOnTourTab('add');

  // Show overlay
  const ov = document.getElementById('booking-detail-overlay');
  if (ov) { ov.style.display = 'flex'; ov.scrollTop = 0; }
}

function closeBookingDetail() {
  const ov = document.getElementById('booking-detail-overlay');
  if (ov) ov.style.display = 'none';
  // Remove any guide alert banners injected
  document.querySelectorAll('#booking-detail-overlay [style*="FFF3CD"]').forEach(el=>el.remove());
  _bkdCurrentId = null;
}

function setOnTourTab(tab) {
  ['add','cancel','full','modify'].forEach(t => {
    const form = document.getElementById(`otab-form-${t}`);
    const btn  = document.getElementById(`otab-${t}`);
    if (form) form.style.display = t === tab ? 'block' : 'none';
    if (btn) {
      btn.style.background = t === tab ? 'var(--g)' : '#fff';
      btn.style.color      = t === tab ? '#fff' : 'var(--td)';
      btn.style.borderColor = t === tab ? 'var(--g)' : 'var(--b)';
    }
  });
}

function saveOnTourChange(type) {
  const b = BOOKINGS.find(x => x.id === _bkdCurrentId);
  if (!b) return;
  const now   = new Date();
  const today = now.toISOString().split('T')[0];
  const time  = now.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});
  let entry   = { id:'CHG-'+Date.now(), type, date:today, time, by:'Staff' };
  let costDelta = 0;
  let guideAlert = false;

  if (type === 'add') {
    const name  = document.getElementById('ot-add-name')?.value.trim();
    if (!name) { alert('Please enter the activity name.'); return; }
    const cost  = parseFloat(document.getElementById('ot-add-cost')?.value) || 0;
    const notes = document.getElementById('ot-add-notes')?.value.trim();
    guideAlert  = document.getElementById('ot-add-guide-alert')?.checked;
    entry = {...entry, description:`Added: ${name}`, detail: notes, costImpact:+cost};
    costDelta = +cost;
    // Reset form
    document.getElementById('ot-add-name').value = '';
    document.getElementById('ot-add-cost').value = '';
    document.getElementById('ot-add-notes').value = '';

  } else if (type === 'cancel') {
    const name   = document.getElementById('ot-cancel-name')?.value.trim();
    if (!name) { alert('Please enter the activity being cancelled.'); return; }
    const reason    = document.getElementById('ot-cancel-reason')?.value;
    const fee       = parseFloat(document.getElementById('ot-cancel-fee')?.value) || 0;
    const reduction = parseFloat(document.getElementById('ot-cancel-reduction')?.value) || 0;
    const notes     = document.getElementById('ot-cancel-notes')?.value.trim();
    guideAlert      = document.getElementById('ot-cancel-guide-alert')?.checked;
    entry = {...entry, description:`Cancelled: ${name}`, detail:`Reason: ${reason}${notes?'. '+notes:''}`, cancelFee:fee, costImpact:-reduction};
    costDelta = -reduction;
    document.getElementById('ot-cancel-name').value = '';
    document.getElementById('ot-cancel-fee').value = '';
    document.getElementById('ot-cancel-reduction').value = '';
    document.getElementById('ot-cancel-notes').value = '';

  } else if (type === 'full') {
    if (!document.getElementById('ot-full-confirm')?.checked) {
      alert('Please tick the confirmation checkbox before cancelling the booking.'); return;
    }
    const reason = document.getElementById('ot-full-reason')?.value;
    const fee    = parseFloat(document.getElementById('ot-full-fee')?.value) || 0;
    const refund = parseFloat(document.getElementById('ot-full-refund')?.value) || 0;
    const notes  = document.getElementById('ot-full-notes')?.value.trim();
    entry = {...entry, description:'BOOKING CANCELLED', detail:`Reason: ${reason}${notes?'. '+notes:''}`, cancelFee:fee, refund, costImpact:0};
    b.status = 'Cancelled';
    guideAlert = true;
    document.getElementById('ot-full-confirm').checked = false;
    document.getElementById('ot-full-notes').value = '';

  } else if (type === 'modify') {
    const parts = [];
    const newPax   = document.getElementById('ot-mod-pax')?.value;
    const newStart = document.getElementById('ot-mod-start')?.value;
    const newEnd   = document.getElementById('ot-mod-end')?.value;
    const newHotel = document.getElementById('ot-mod-hotel')?.value.trim();
    const cost     = parseFloat(document.getElementById('ot-mod-cost')?.value) || 0;
    const notes    = document.getElementById('ot-mod-notes')?.value.trim();
    guideAlert     = document.getElementById('ot-mod-guide-alert')?.checked;
    if (newPax)   { b.pax   = parseInt(newPax);   parts.push(`Pax → ${newPax}`); }
    if (newStart) { b.start = newStart;             parts.push(`Start → ${newStart}`); }
    if (newEnd)   { b.end   = newEnd;               parts.push(`End → ${newEnd}`); }
    if (newHotel) { b.hotel = newHotel;             parts.push(`Hotel → ${newHotel}`); }
    if (!parts.length && !cost) { alert('Please enter at least one change to save.'); return; }
    entry = {...entry, description:`Modified: ${parts.join(' · ')||'details updated'}`, detail:notes, costImpact:cost};
    costDelta = cost;
    ['ot-mod-pax','ot-mod-start','ot-mod-end','ot-mod-hotel','ot-mod-cost','ot-mod-notes'].forEach(id=>{
      const el=document.getElementById(id); if(el) el.value='';
    });
  }

  // Apply cost delta and update guide alert
  b.total = Math.max(0, b.total + costDelta);
  if (guideAlert) b.guideAlertPending = true;
  if (!b.changes) b.changes = [];
  b.changes.unshift(entry);

  persistBookings();
  renderChangeLog(b);
  renderBookings();

  // Refresh finance bar
  const bal = b.total - b.deposit;
  const finCells = document.querySelectorAll('#bkd-finance > div');
  if (finCells[0]) finCells[0].querySelector('div:last-child').textContent = `$${fmt(b.total)}`;
  if (finCells[2]) { finCells[2].querySelector('div:last-child').textContent = `$${fmt(bal)}`; finCells[2].querySelector('div:last-child').style.color = bal>0?'var(--amb)':'var(--g)'; }
  if (finCells[5]) finCells[5].querySelector('div:last-child').textContent = b.changes.length;

  // Status badge refresh for full cancel
  if (type === 'full') {
    document.getElementById('bkd-status-badge').innerHTML = `<span style="background:#C0392B;color:#fff;border-radius:20px;padding:4px 14px;font-size:12px;font-weight:700">Cancelled</span>`;
  }
}

function renderChangeLog(b) {
  const el = document.getElementById('bkd-change-log');
  if (!el) return;
  const changes = b.changes || [];
  if (!changes.length) {
    el.innerHTML = '<div style="color:var(--m);font-size:13px;padding:12px;background:#F7F8F6;border-radius:8px;text-align:center">No changes recorded yet for this booking.</div>';
    return;
  }
  const TYPE_COLORS = {add:'var(--g)', cancel:'var(--amb)', full:'var(--red)', modify:'var(--blue)'};
  const TYPE_LABELS = {add:'Added', cancel:'Cancelled', full:'Full Cancel', modify:'Modified'};
  el.innerHTML = `<table class="tbl"><thead><tr>
    <th>Date / Time</th><th>Type</th><th>Description</th><th>Detail</th>
    <th style="text-align:right">Cost Impact</th><th style="text-align:right">Cancel Fee</th><th>By</th>
  </tr></thead><tbody>${changes.map(ch=>{
    const tc = TYPE_COLORS[ch.type]||'var(--m)';
    const tl = TYPE_LABELS[ch.type]||ch.type;
    const ci = ch.costImpact || 0;
    return `<tr>
      <td style="white-space:nowrap;font-size:11px">${ch.date}<br><span style="color:var(--m)">${ch.time||''}</span></td>
      <td><span style="background:${tc}22;color:${tc};border-radius:10px;padding:1px 8px;font-size:10.5px;font-weight:700;white-space:nowrap">${tl}</span></td>
      <td style="font-weight:600">${ch.description}</td>
      <td style="font-size:12px;color:var(--m)">${ch.detail||'—'}</td>
      <td style="text-align:right;font-weight:600;color:${ci>0?'var(--g)':ci<0?'var(--red)':'var(--m)'}">${ci>0?'+':''}${ci!==0?'$'+fmt(Math.abs(ci)):'—'}</td>
      <td style="text-align:right;color:var(--red)">${ch.cancelFee?'$'+fmt(ch.cancelFee):'—'}</td>
      <td style="font-size:11px">${ch.by||'Staff'}</td>
    </tr>`;
  }).join('')}</tbody></table>`;
}

function markGuideNotified(bookingId) {
  const b = BOOKINGS.find(x=>x.id===bookingId);
  if (b) { b.guideAlertPending = false; persistBookings(); }
  // Remove banner
  document.querySelectorAll('#booking-detail-overlay [style*="FFF3CD"]').forEach(el=>el.remove());
  renderBookings();
}

