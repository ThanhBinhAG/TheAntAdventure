async function aiStep3Review() {
  if (!selProds.length) {
    alert('No products selected. Go back to Step 2 first.');
    return;
  }
  const briefPax   = parseInt(document.getElementById('d-pax')?.value) || 2;
  const style      = document.getElementById('d-style')?.value || 'Luxury';
  const budget     = document.getElementById('d-budget')?.value || '$2,000–$3,500';
  const activeTierN = briefPax <= 1 ? 1 : briefPax === 2 ? 2 : briefPax <= 4 ? 3 : briefPax <= 6 ? 5 : briefPax <= 9 ? 7 : 10;
  const sellPerPax  = selProds.reduce((s, sp) => {
    const t = TAA_TOURS.find(x => x.id === sp.id);
    return s + (t ? getAdjustedSell(t, activeTierN) : 0);
  }, 0);
  const costPerPax  = selProds.reduce((s, sp) => {
    const t = TAA_TOURS.find(x => x.id === sp.id);
    return s + (t ? getCostUSD(t, briefPax >= 10 ? 10 : briefPax) : 0);
  }, 0);
  const margin     = sellPerPax - costPerPax;
  const marginPct  = sellPerPax > 0 ? Math.round(margin / sellPerPax * 100) : 0;
  const groupTotal = sellPerPax * briefPax;
  const productList = selProds.map(sp => {
    const t = TAA_TOURS.find(x => x.id === sp.id);
    const sell = t ? getAdjustedSell(t, activeTierN) : 0;
    const cost = t ? getCostUSD(t, briefPax) : 0;
    return `- ${sp.n}: sell $${sell}/pax, cost $${cost}/pax`;
  }).join('\n');

  setStepAILoading(3, true);

  const prompt = `You are a pricing strategist for The Ant Adventures, a luxury Vietnam travel company.

Review the pricing below and give a concise analysis in 3 sections:

**1. Margin health**
Is ${marginPct}% margin healthy for ${style} tier? What is the target range?

**2. Competitive check**
Is $${sellPerPax}/pax (${briefPax} pax, group total $${groupTotal}) competitive vs. client's stated budget of ${budget}? Any mismatch?

**3. Adjustments to consider**
Any specific product prices that look high or low for their category? Suggest 1–2 concrete tweaks if needed.

CURRENT PRICING (${briefPax} pax, ${_step3Markup}% markup):
${productList}

Totals: Sell $${sellPerPax}/pax · Cost $${costPerPax}/pax · Margin $${margin} (${marginPct}%) · Group total $${groupTotal}

Be specific and direct. Max 200 words. No generic advice.`;

  try {
    const apiKey = LS.get('ant_api_key','');
    if (!apiKey || !apiKey.startsWith('sk-')) {
      document.getElementById('ds3-ai-result').textContent = '⚠ No API key saved. Go to ⚡ AI Requirements to add your Anthropic key.';
      return;
    }
