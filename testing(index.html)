function setProdTab(t) {
  ['library','add','modules'].forEach(x=>{
    const el = document.getElementById('prod-'+x);
    if (el) el.style.display = x===t?'block':'none';
    const tab = document.querySelector(`[data-prod-tab="${x}"]`);
    if (tab) tab.classList.toggle('on', x===t);
  });
  if (t==='library') renderProdLibrary();
  if (t==='add') autoGenId();
  if (t==='modules') renderModulesView();
}

document.querySelectorAll('[data-prod-tab]').forEach(t=>{
  t.addEventListener('click',()=>setProdTab(t.dataset.prodTab));
});

function autoGenId() {
  const r = document.getElementById('pf-region')?.value||'north';
  const code = r==='north'?'N':r==='central'?'C':r==='south'?'S':'F';
  const el = document.getElementById('pf-id');
  if (el) el.value = `PRD-${code}-${String(Math.floor(Math.random()*900)+100)}`;
}
document.getElementById('pf-region')?.addEventListener('change', autoGenId);

function saveProduct(asDraft) {
  const name = document.getElementById('pf-name')?.value;
  const cost = parseFloat(document.getElementById('pf-cost')?.value)||0;
  if (!name) { alert('Please enter a product name.'); return; }
  const dur = document.getElementById('pf-dur')?.value||'1';
  const id = document.getElementById('pf-id')?.value||('PRD-X-'+Date.now());
  const p = {
    id, r: document.getElementById('pf-region')?.value||'north',
    d: dur, dl: DUR_LABELS[dur]||dur,
    n: name, nv: document.getElementById('pf-namevn')?.value||'',
    cat: document.getElementById('pf-cat')?.value||'cultural',
    cost, desc: document.getElementById('pf-desc')?.value||'',
    hi: document.getElementById('pf-hi')?.value||'',
    diff: document.getElementById('pf-diff')?.value||'easy',
    status: asDraft ? 'draft' : 'active'
  };
  PRODUCTS = PRODUCTS.find(x=>x.id===id) ? PRODUCTS.map(x=>x.id===id?p:x) : [...PRODUCTS, p];
  persist();
  setProdTab('library');
  alert(`✓ Product "${p.n}" ${asDraft?'saved as draft':'activated'} successfully!`);
}

function editProduct(id) {
  const p = PRODUCTS.find(x=>x.id===id);
  if (!p) return;
  const setVal = (elId, val) => { const el=document.getElementById(elId); if(el) el.value=val; };
  setVal('pf-region',p.r); setVal('pf-dur',p.d); setVal('pf-cat',p.cat);
  setVal('pf-name',p.n); setVal('pf-namevn',p.nv||''); setVal('pf-cost',p.cost);
  setVal('pf-desc',p.desc||''); setVal('pf-hi',p.hi||''); setVal('pf-diff',p.diff||'easy');
  setVal('pf-status',p.status||'active'); setVal('pf-id',p.id);
  const title = document.getElementById('pf-title');
  if (title) title.textContent = 'Edit: '+p.n;
  setProdTab('add');
}

function deleteProduct(id) {
  const p = PRODUCTS.find(x=>x.id===id);
  if (!p||!confirm(`Delete "${p.n}"? This cannot be undone.`)) return;
  PRODUCTS = PRODUCTS.filter(x=>x.id!==id);
  persist();
  renderProdLibrary();
}

function renderModulesView() {
  const el = document.getElementById('mod-content');
  if (!el) return;
  el.innerHTML = ['north','central','south'].map(r=>{
    const [rbg,rfg]=REG_COLORS[r];
    const rp = PRODUCTS.filter(p=>p.r===r&&p.status==='active');
    return `<div style="margin-bottom:18px">
      <div style="background:${rbg};color:${rfg};padding:8px 13px;border-radius:8px 8px 0 0;font-weight:600;font-size:12.5px;border:1px solid ${rbg}">${REGIONS[r]}</div>
      <div style="border:1px solid ${rbg};border-top:none;border-radius:0 0 8px 8px;overflow:hidden">
        ${['0.5','1','2','3','4'].map(d=>{
          const dp=rp.filter(p=>p.d===d);
          if(!dp.length) return '';
          return `<div style="border-bottom:1px solid var(--b)">
            <div style="padding:5px 13px;background:${rbg}33;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:${rfg}">${DUR_LABELS[d]}</div>
            ${dp.map(p=>`<div style="display:flex;justify-content:space-between;padding:7px 13px;border-bottom:1px dotted var(--b);font-size:12.5px">
              <span>${p.n}</span><span style="color:var(--g);font-weight:600">$${(()=>{const t=TAA_TOURS.find(x=>x.id===p.id);return t?"\$"+getSpUSD(t,10)+"–\$"+getSpUSD(t,1)+"/pax":"—";})()}</span>
            </div>`).join('')}
          </div>`;
        }).join('')}
      </div>
    </div>`;
  }).join('');
}

