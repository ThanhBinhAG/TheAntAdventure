<!-- SECTION: Contracts -->
<!-- DB TABLE NEEDED: contracts (id, booking_id, lead_id, customer_id, client_name, nationality, pax, tour_name, duration, departure_date, return_date, route, inclusions, exclusions, flights, total_price, currency, deposit_pct, balance_due_date, status, created_at, signed_at, notes) -->
<div class="page" id="page-contracts">

  <!-- Header bar -->
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap">
    <input type="text" id="ctr-search" placeholder="🔍  Search contracts…" oninput="renderContracts()" style="padding:7px 12px;border:1px solid var(--b);border-radius:8px;font-family:inherit;font-size:12.5px;width:220px">
    <div style="display:flex;gap:6px;flex:1">
      <button class="ctr-filter-btn on" data-ctr-filter="all" onclick="setCtrFilter('all')" style="padding:5px 13px;border-radius:20px;border:1px solid var(--b);background:#fff;font-size:12px;cursor:pointer;font-family:inherit">All</button>
      <button class="ctr-filter-btn" data-ctr-filter="Draft" onclick="setCtrFilter('Draft')" style="padding:5px 13px;border-radius:20px;border:1px solid #D97706;background:#FEF3C7;font-size:12px;cursor:pointer;font-family:inherit;color:#92400E">Draft</button>
      <button class="ctr-filter-btn" data-ctr-filter="Sent" onclick="setCtrFilter('Sent')" style="padding:5px 13px;border-radius:20px;border:1px solid #1565C0;background:#DBEAFE;font-size:12px;cursor:pointer;font-family:inherit;color:#1e3a8a">Sent</button>
      <button class="ctr-filter-btn" data-ctr-filter="Signed" onclick="setCtrFilter('Signed')" style="padding:5px 13px;border-radius:20px;border:1px solid var(--g);background:#E8F5EE;font-size:12px;cursor:pointer;font-family:inherit;color:var(--gd)">Signed</button>
    </div>
    <button onclick="openNewContractModal()" style="margin-left:auto;padding:7px 16px;background:var(--g);color:#fff;border:none;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;font-family:inherit">＋ New Contract</button>
  </div>

  <!-- KPI pills -->
  <div id="ctr-kpi-row" style="display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap"></div>

  <!-- Contracts table -->
  <div class="card" style="padding:0;overflow:hidden">
    <table class="tbl" id="ctr-table">
      <thead>
        <tr>
          <th>Contract No.</th>
          <th>Client</th>
          <th>Tour</th>
          <th>Pax</th>
          <th>Value</th>
          <th>Departure</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="ctr-tbody"></tbody>
    </table>
  </div>

  <!-- ── NEW CONTRACT MODAL ── -->
  <div id="ctr-new-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:900;display:none;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:14px;width:min(780px,96vw);max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.25)">
      <!-- Modal header -->
      <div style="background:linear-gradient(135deg,var(--gd),var(--g));padding:18px 22px;border-radius:14px 14px 0 0;display:flex;align-items:center;justify-content:space-between">
        <div>
          <div style="color:#fff;font-weight:700;font-size:15px">📄 New Contract</div>
          <div style="color:rgba(255,255,255,.75);font-size:12px;margin-top:2px">Auto-fill from a confirmed booking or enter manually</div>
        </div>
        <button onclick="closeNewContractModal()" style="background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:50%;width:30px;height:30px;font-size:16px;cursor:pointer;font-family:inherit">✕</button>
      </div>
      <div style="padding:22px">

        <!-- Link to booking -->
        <div style="background:#E8F5EE;border:1px solid #b8dfc9;border-radius:9px;padding:12px 16px;margin-bottom:18px">
          <div style="font-size:12px;font-weight:700;color:var(--gd);margin-bottom:8px">🔗 LINK TO BOOKING (Auto-fill)</div>
          <div style="display:flex;gap:8px;align-items:center">
            <select id="ctr-booking-select" onchange="autoFillFromBooking()" style="flex:1;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px">
              <option value="">— Select a confirmed booking to auto-fill —</option>
            </select>
            <button onclick="clearAutoFill()" style="padding:6px 12px;background:#fff;border:1px solid var(--b);border-radius:7px;font-size:12px;cursor:pointer;font-family:inherit;color:var(--m)">Clear</button>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <!-- Client info -->
          <div>
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--m);margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid var(--g)">CLIENT INFORMATION</div>
            <div style="display:flex;flex-direction:column;gap:8px">
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Client Name *</label>
              <input id="ctr-client-name" placeholder="e.g. Co Thu" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Nationality</label>
              <input id="ctr-nationality" placeholder="e.g. Australian" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Number of Travellers *</label>
              <input id="ctr-pax" type="number" min="1" placeholder="4" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Room Configuration</label>
              <input id="ctr-rooms" placeholder="e.g. 2 Rooms — 1 Double + 1 Twin" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
            </div>
          </div>

          <!-- Tour info -->
          <div>
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--m);margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid var(--g)">TOUR DETAILS</div>
            <div style="display:flex;flex-direction:column;gap:8px">
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Tour Name *</label>
              <input id="ctr-tour-name" placeholder="e.g. Classic Vietnam 10D/9N" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Duration</label>
              <input id="ctr-duration" placeholder="e.g. 10 Days / 9 Nights" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Departure Date</label>
              <input id="ctr-dep-date" type="date" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
              <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Return Date</label>
              <input id="ctr-ret-date" type="date" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
            </div>
          </div>
        </div>

        <!-- Route -->
        <div style="margin-top:14px">
          <label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Route / Itinerary Summary</label>
          <input id="ctr-route" placeholder="e.g. Saigon › Hoi An › Hue › Hanoi › Halong Bay" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px">
        </div>

        <!-- Pricing -->
        <div style="margin-top:18px">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--m);margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid var(--g)">PRICING &amp; PAYMENT</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px">
            <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Currency</label>
            <select id="ctr-currency" style="width:100%;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px">
              <option>USD</option><option>EUR</option><option>AUD</option><option>VND</option>
            </select></div>
            <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Total Tour Value</label>
            <input id="ctr-total" type="number" placeholder="25532" oninput="calcDepositAmt()" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
            <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Deposit %</label>
            <select id="ctr-deposit-pct" onchange="calcDepositAmt()" style="width:100%;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px">
              <option value="30">30%</option><option value="50" selected>50%</option><option value="100">100%</option>
            </select></div>
            <div><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Deposit Amount</label>
            <input id="ctr-deposit-amt" readonly style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px;background:#f5f5f5"></div>
          </div>
          <div style="margin-top:8px"><label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">Balance Due Date</label>
          <input id="ctr-balance-date" type="date" style="width:240px;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12.5px"></div>
        </div>

        <!-- Inclusions / Exclusions / Flights -->
        <div style="margin-top:18px">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--m);margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid var(--g)">INCLUSIONS, EXCLUSIONS &amp; FLIGHTS</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
            <div>
              <label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">What's Included (one per line)</label>
              <textarea id="ctr-inclusions" rows="5" placeholder="Accommodation (twin share, breakfast included)&#10;Private transport throughout&#10;English-speaking local guide&#10;Domestic flights (as specified)&#10;Bhaya Cruise 3D/2N" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12px;resize:vertical"></textarea>
            </div>
            <div>
              <label style="font-size:11.5px;font-weight:600;color:var(--t);display:block;margin-bottom:3px">What's Excluded (one per line)</label>
              <textarea id="ctr-exclusions" rows="5" placeholder="International airfare&#10;Travel insurance&#10;Personal expenses, tips&#10;Entrance tickets&#10;Meals not stated as included" style="width:100%;box-sizing:border-box;padding:7px 10px;border:1px solid var(--b);border-radius:7px;font-family:inherit;font-size:12px;resize:vertical"></textarea>
            </div>
          </div>
