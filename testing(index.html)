// ── Lightweight toast notification helper ─────────────────────────
function _sbfToast(msg, type) {
  const colors = { success:'#2E7D52', error:'#C0392B', info:'#1565C0' };
  const bg = colors[type] || colors.info;
  const el = document.createElement('div');
  el.textContent = msg;
  el.style.cssText = `position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);
    background:${bg};color:#fff;padding:10px 22px;border-radius:50px;font-size:13px;font-weight:600;
    font-family:inherit;box-shadow:0 4px 18px rgba(0,0,0,.22);z-index:9999;
    opacity:0;transition:opacity .25s,transform .25s;pointer-events:none`;
  document.body.appendChild(el);
  requestAnimationFrame(() => { el.style.opacity='1'; el.style.transform='translateX(-50%) translateY(0)'; });
  setTimeout(() => {
    el.style.opacity='0'; el.style.transform='translateX(-50%) translateY(10px)';
    setTimeout(() => el.remove(), 300);
  }, 2800);
}

// ── TRANSPORT: regional daily schedule sections ───────────────────
// Detects North / Central / South from destination keywords.
// Renders one section per region, each with own header + day table.
const _TR_REGION_MAP = {
  North:   /hanoi|ha noi|halong|ha long|ninh binh|ha giang|sapa|lao cai|cat ba|bai chay/i,
  Central: /hue|hội an|hoi an|da nang|đà nẵng|danang|quang binh|phong nha|quang nam|quy nhon|nha trang|hội|lang co/i,
  South:   /ho chi minh|saigon|hcmc|can tho|mekong|phu quoc|mui ne|da lat|dalat|vung tau|ben tre/i
};
function _trDetectRegion(dest) {
  for (const [region, re] of Object.entries(_TR_REGION_MAP)) {
    if (re.test(dest)) return region;
  }
  return 'Other';
}

function buildTransportTable(itinerary, cinISO, pax, guide, guestName) {
  // Clear old single tbody approach — now use full panel container
  const panel = document.getElementById('sbf-panel-transport');
  // Keep the header and footer, replace only the table area
  const oldTable = document.getElementById('sbf-tr-regions-container');
  if (oldTable) oldTable.remove();

  const container = document.createElement('div');
  container.id = 'sbf-tr-regions-container';

  const DOW  = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const MONS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const startDate = cinISO ? new Date(cinISO) : null;
  const guideDisp = (guide && guide !== '—') ? guide : '';

  if (!itinerary || !itinerary.length) {
    container.innerHTML = `<div style="padding:18px;text-align:center;color:var(--m);font-size:12px;border:1px solid #E2E8E4;border-radius:9px">No itinerary data — please link a Tour Design first.</div>`;
    document.getElementById('sbf-tr-tbody').closest('div').before(container);
    return;
  }

  // ── Group days by region ─────────────────────────────────────
  const regionGroups = {}; // { North: [{dayObj, i}], Central: [...], South: [...] }
  const regionOrder  = [];
  itinerary.forEach((dayObj, i) => {
    const region = _trDetectRegion(dayObj.dest || '');
    if (!regionGroups[region]) { regionGroups[region] = []; regionOrder.push(region); }
    regionGroups[region].push({ dayObj, i });
  });

  const regionColors = { North:'#1565C0', Central:'#2E7D52', South:'#C0392B', Other:'#6B21A8' };
  const regionEmoji  = { North:'🔵', Central:'🟢', South:'🔴', Other:'⭐' };
  let sectionIdx = 0;

  regionOrder.forEach(region => {
    const days = regionGroups[region];
    sectionIdx++;

    // Section wrapper
    const section = document.createElement('div');
    section.id = `sbf-tr-section-${region.toLowerCase()}`;
    section.style.cssText = 'margin-bottom:20px;border:1px solid #E2E8E4;border-radius:9px;overflow:hidden';

    // Section header
    const color = regionColors[region] || '#2E7D52';
    section.innerHTML = `
      <div style="background:${color};color:#fff;padding:10px 14px;display:flex;align-items:center;gap:8px">
        <span style="font-size:13px;font-weight:700">${regionEmoji[region]} ${region} Vietnam — Transport Provider</span>
        <span style="font-size:11px;opacity:.8">(${days.length} day${days.length>1?'s':''})</span>
      </div>
      <!-- Provider fields for this region -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:12px;background:#F7F8F6;border-bottom:1px solid #E2E8E4">
        <div style="grid-column:1/3"><label class="sbf-lbl">Transport Company</label>
          <input id="sbf-tr-${region}-company" class="sbf-inp" placeholder="e.g. ${region} Transport Co."></div>
        <div><label class="sbf-lbl">Vehicle Type</label>
          <select id="sbf-tr-${region}-vehicle" class="sbf-inp">
            <option>Private Car (4-seat)</option><option>Private SUV (7-seat)</option>
            <option>Private Van (16-seat)</option><option>Private Bus (30-seat)</option>
            <option>Motorbike</option><option>Sleeper Bus</option>
          </select></div>
        <div><label class="sbf-lbl">Guide Name</label>
          <input id="sbf-tr-${region}-guide" class="sbf-inp" placeholder="e.g. Minh Nguyen" value="${guideDisp}"></div>
        <div><label class="sbf-lbl">Guide Phone</label>
          <input id="sbf-tr-${region}-phone" class="sbf-inp" placeholder="e.g. +84 90 123 4567"></div>
        <div><label class="sbf-lbl">Inclusions (this region)</label>
          <input id="sbf-tr-${region}-inclusions" class="sbf-inp" value="Bottled water, cold face towels, private A/C vehicle"></div>
      </div>
      <!-- Day table for this region -->
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:12px">
          <thead>
            <tr style="background:${color}22;color:${color}">
              <th style="padding:7px 8px;text-align:left;white-space:nowrap;min-width:90px;border-bottom:2px solid ${color}33">📅 Date</th>
              <th style="padding:7px 8px;text-align:left;min-width:110px;border-bottom:2px solid ${color}33">📍 Destination</th>
              <th style="padding:7px 8px;text-align:left;min-width:230px;border-bottom:2px solid ${color}33">🗓 Itinerary Brief</th>
              <th style="padding:7px 8px;text-align:left;min-width:100px;border-bottom:2px solid ${color}33">🧭 Guide</th>
              <th style="padding:7px 8px;text-align:left;min-width:160px;border-bottom:2px solid ${color}33">📝 Notes</th>
            </tr>
          </thead>
          <tbody id="sbf-tr-tbody-${region}"></tbody>
        </table>
      </div>
      <!-- Per-region action buttons -->
